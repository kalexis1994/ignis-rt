#version 460
#extension GL_EXT_ray_tracing : require
#extension GL_EXT_ray_query : require
#extension GL_EXT_buffer_reference : require
#extension GL_EXT_scalar_block_layout : require
#extension GL_EXT_shader_explicit_arithmetic_types_int64 : require
#extension GL_EXT_nonuniform_qualifier : require
#extension GL_EXT_shader_atomic_int64 : require
#extension GL_GOOGLE_include_directive : require
#extension GL_NV_shader_invocation_reorder : enable

// Scene data (set 0)
layout(binding = 0, set = 0) uniform accelerationStructureEXT topLevelAS;

layout(binding = 2, set = 0) uniform CameraProperties {
    mat4 viewInverse;
    mat4 projInverse;
    mat4 view;
    mat4 proj;
    mat4 viewPrev;
    mat4 projPrev;
    uvec4 parameters;
    vec4 jitterData;
    vec4 sunLight;
    vec4 ambientLight;
    vec4 skyLight;
    vec4 ptParams0;
    vec4 ptParams1;
    vec4 windParams;
    vec4 rainParams;
    vec4 dofParams;    // x=aperture, y=focusDist, z=blades, w=rotation
    vec4 dofParams2;   // x=ratio
    ivec4 jitterPattern[8];
    uint lightCount;
    uint lightPad0, lightPad1, lightPad2;
    vec4 lights[128];
    uint64_t sharcHashEntriesAddr;
    uint64_t sharcAccumulationAddr;
    uint64_t sharcResolvedAddr;
    uint sharcCapacity;
    float sharcSceneScale;
    float sharcRadianceScale;
    float sharcWarmupFactor;
} cam;

// Geometry metadata (same as raygen_blender.rgen)
struct GeometryMetadata {
    uint64_t vertexBufferAddress;
    uint64_t indexBufferAddress;
    uint64_t normalBufferAddress;
    uint64_t uvBufferAddress;
    uint64_t primMaterialBufferAddress;
    uint64_t bitangentBufferAddress;
    uint64_t primYBoundsAddress;
    uint64_t colorBufferAddress;
    uint vertexCount;
    uint indexCount;
};

layout(binding = 3, set = 0, scalar) buffer GeometryMetadataBuffer {
    GeometryMetadata geometries[];
} geometryMetadata;

struct Material {
    uint diffuseTexIndex;
    uint normalTexIndex;
    uint mapsTexIndex;
    uint detailTexIndex;

    uint normalDetailTexIndex;
    float ksAmbient;
    float ksDiffuse;
    float ksSpecular;

    float ksSpecularEXP;
    float emissiveR, emissiveG, emissiveB;

    float fresnelC;
    float fresnelEXP;
    float detailUVMultiplier;
    float detailNormalBlend;

    uint flags;
    float alphaRef;
    uint shaderType;
    float fresnelMaxLevel;

    uint maskTexIndex;
    uint detailRTexIndex;
    uint detailGTexIndex;
    uint detailBTexIndex;

    uint detailATexIndex;
    uint detailNMTexIndex;
    float multR;
    float multG;

    float multB;
    float multA;
    float magicMult;
    float detailNMMult;
    float detailNMMultV;

    float sunSpecular;
    float sunSpecularEXP;

    // Node VM bytecode
    uint nodeVmHeader;       // [7:0]=instrCount, [15:8]=flags
    uint nodeVmPad[3];
    uvec4 nodeVmCode[128];   // 128 instructions
};

layout(binding = 4, set = 0, scalar) buffer MaterialBuffer {
    Material materials[];
} materialBuffer;

layout(binding = 5, set = 0) uniform sampler2D textures[];
layout(binding = 12, set = 0) uniform sampler2D blueNoiseTexture;
layout(binding = 18, set = 0, r16f) uniform image2D penumbraImg;

// SHARC radiance cache (hash entries + combined accum/resolved/guide)
layout(binding = 20, set = 0, std430) buffer SHARCHashEntries { uint64_t keys[]; } _sharcHashEntries;
layout(binding = 21, set = 0, std430) buffer SHARCData        { uint data[];     } _sharcAccum;
#define _sharcResolved _sharcAccum

// ReSTIR DI reservoir buffers (ping-pong: current write, previous read)
layout(binding = 24, set = 0, std430) buffer DIReservoirCurrBuf { vec4 data[]; } diReservoirCurr;
layout(binding = 25, set = 0, std430) buffer DIReservoirPrevBuf { vec4 data[]; } diReservoirPrev;

// Emissive triangles for MIS (16 floats per triangle)
layout(binding = 26, set = 0, std430) buffer EmissiveTriBuf {
    vec4 data[];
} emissiveTris;

// Per-instance previous-frame transforms
layout(binding = 28, set = 0, std430) buffer PrevTransformBuf {
    vec4 data[];
} prevTransforms;

// ReSTIR GI reservoir buffers (ping-pong: current write, previous read)
layout(binding = 49, set = 0, std430) buffer GIReservoirCurrBuf { vec4 data[]; } giReservoirCurr;
layout(binding = 50, set = 0, std430) buffer GIReservoirPrevBuf { vec4 data[]; } giReservoirPrev;

// Buffer references
layout(buffer_reference, scalar) buffer Vertices { float v[]; };
layout(buffer_reference, scalar) buffer Indices { uint i[]; };
layout(buffer_reference, scalar) buffer Normals { float n[]; };
layout(buffer_reference, scalar) buffer UVs { float uv[]; };
layout(buffer_reference, scalar) buffer PrimMaterials { uint m[]; };
layout(buffer_reference, scalar) buffer Colors { float c[]; };
layout(buffer_reference, scalar) buffer Bitangents { float b[]; };

// Wavefront buffers (set 1)
#include "../include/pathstate.glsl"
layout(binding = 1, set = 1, scalar) buffer HitResultBuffer { float hitData[]; } hitResults;
layout(binding = 2, set = 1, scalar) buffer ShadowRayBuffer { float shadowData[]; } shadowRays;
layout(binding = 3, set = 1, scalar) buffer PixelRadianceBuffer { uint radDataU[]; } pixelRadiance;
layout(binding = 4, set = 1, scalar) buffer PrimaryGBufBuffer { float gbufData[]; } primaryGBuf;
layout(binding = 5, set = 1, scalar) buffer CountersBuffer {
    uint activeRayCount;
    uint shadowRayCount;
    uint nextActiveRayCount;
    uint pad0;
} counters;

// SHARC per-pixel state (persists across bounces, indexed by pixelIndex)
// Layout: 20 uints per pixel [cacheIndices(4) + sampleWeights(12) + pathLength(1) + pad(3)]
layout(binding = 8, set = 1, scalar) buffer SharcStateBuffer { uint sharcData[]; } sharcStates;

// Stable Planes (for glass plane routing)
layout(binding = 18, set = 1, std430) buffer SPHeaderBuf   { uvec4 data[]; } spHeader;

// Secondary radiance buffer for glass decomposition
layout(binding = 20, set = 1, scalar) buffer PixelRadianceAuxBuffer { uint radDataU[]; } pixelRadianceAux;

// Glass plane decomposition flag — bit 16 in pathState flags
const uint FLAG_SECONDARY_PLANE = 0x10000u;

layout(push_constant) uniform PushConst {
    uint width;
    uint height;
    uint frameIndex;
    uint maxBounces;
    uint currentBounce;
    uint spp;
    uint sampleIdx;
} pc;

// Material flags (must match raygen_blender.rgen)
const uint MAT_FLAG_HAIR = 32u;
const uint MAT_FLAG_DIFFUSE_SCENE_LINEAR = 64u;
const uint MAT_FLAG_THIN_TRANSMISSION = 128u;
const uint MAT_FLAG_LIGHTPATH_TRANSPARENT = 256u;
const uint VM_HEADER_FLAG_BASE_COLOR = 1u;
const uint VM_HEADER_FLAG_ALPHA = 2u;
const uint VM_HEADER_FLAG_TRANSMISSION = 4u;
const uint VM_HEADER_FLAG_SHADOW_DYNAMIC = 8u;

#include "../include/common.glsl"
#include "../include/sky.glsl"
#include "../include/pbr_brdf.glsl"
#include "../include/sampling.glsl"
#include "../include/nrd_encode.glsl"
#include "../include/emissive_sampling.glsl"
#include "../include/node_vm.glsl"
#include "../include/sharc_setup.glsl"
#include "../include/hair_bsdf.glsl"
#include "../include/hair_cylinder.glsl"
#include "../include/volume_march.glsl"
#include "../include/di_reservoir.glsl"
#include "../include/gi_reservoir.glsl"

// SHARC state load/store (20 uints per pixel, indexed by pixelIndex)
SharcState loadSharcState(uint pixelIndex) {
    uint base = pixelIndex * 20u;
    SharcState s;
    for (uint i = 0u; i < 4u; i++) s.cacheIndices[i] = sharcStates.sharcData[base + i];
    for (uint i = 0u; i < 4u; i++) {
        uint off = base + 4u + i * 3u;
        s.sampleWeights[i] = vec3(
            uintBitsToFloat(sharcStates.sharcData[off+0u]),
            uintBitsToFloat(sharcStates.sharcData[off+1u]),
            uintBitsToFloat(sharcStates.sharcData[off+2u]));
    }
    s.pathLength = sharcStates.sharcData[base + 16u];
    return s;
}

void storeSharcState(uint pixelIndex, SharcState s) {
    uint base = pixelIndex * 20u;
    for (uint i = 0u; i < 4u; i++) sharcStates.sharcData[base + i] = s.cacheIndices[i];
    for (uint i = 0u; i < 4u; i++) {
        uint off = base + 4u + i * 3u;
        sharcStates.sharcData[off+0u] = floatBitsToUint(s.sampleWeights[i].x);
        sharcStates.sharcData[off+1u] = floatBitsToUint(s.sampleWeights[i].y);
        sharcStates.sharcData[off+2u] = floatBitsToUint(s.sampleWeights[i].z);
    }
    sharcStates.sharcData[base + 16u] = s.pathLength;
}

vec3 cyclesPrincipledTransmissionTint(vec3 baseColor) {
    return sqrt(clamp(baseColor, vec3(0.0), vec3(1.0)));
}

bool gIsSecondaryPlane = false;  // future use

// Thread-safe float accumulation via uint CAS
void atomicAddFloat(uint index, float value) {
    if (value == 0.0) return;
    uint oldVal, newVal;
    do {
        oldVal = pixelRadiance.radDataU[index];
        newVal = floatBitsToUint(uintBitsToFloat(oldVal) + value);
    } while (atomicCompSwap(pixelRadiance.radDataU[index], oldVal, newVal) != oldVal);
}

// Append a shadow ray atomically
void appendShadowRay(vec3 origin, vec3 dir, float maxDist, uint pathIdx,
                     vec3 radiance, uint channel) {
    uint slot = atomicAdd(counters.shadowRayCount, 1u);
    // Limit to avoid buffer overflow (10x pixel count = MAX_SHADOW_RAYS_PER_PATH)
    if (slot >= pc.width * pc.height * 10u) return;
    uint base = slot * 12u; // 12 floats per ShadowRay
    shadowRays.shadowData[base+0] = origin.x;
    shadowRays.shadowData[base+1] = origin.y;
    shadowRays.shadowData[base+2] = origin.z;
    shadowRays.shadowData[base+3] = maxDist;
    shadowRays.shadowData[base+4] = dir.x;
    shadowRays.shadowData[base+5] = dir.y;
    shadowRays.shadowData[base+6] = dir.z;
    shadowRays.shadowData[base+7] = uintBitsToFloat(pathIdx);
    shadowRays.shadowData[base+8] = radiance.x;
    shadowRays.shadowData[base+9] = radiance.y;
    shadowRays.shadowData[base+10] = radiance.z;
    shadowRays.shadowData[base+11] = uintBitsToFloat(channel);
}

void main() {
    uint idx = gl_LaunchIDEXT.x;
    if (idx >= counters.activeRayCount) return;

    // Read PathState
    vec3 rayOrigin = psReadOrigin(idx);
    uint pixelIndex = psReadPixelIndex(idx);
    vec3 rayDir = psReadDirection(idx);
    rngState = psReadRngState(idx);
    vec3 throughput = psReadThroughput(idx);
    uint flags = psReadFlags(idx);

    // Skip terminated paths
    if ((flags & 0x20u) != 0u) return;

    uint bounce = flags & 0xFu;
    bool isDiffusePath = (flags & 0x10u) != 0u;
    uint glassBouncesPrev = (flags >> 8u) & 0xFu;  // glass bounces from previous iterations

    // Glass plane decomposition: route radiance to secondary buffer if needed
    gIsSecondaryPlane = (flags & FLAG_SECONDARY_PLANE) != 0u;

    // Read HitResult (20 floats: 8 base + 12 objToWorld)
    uint hBase = idx * 20u;
    uint hitType = floatBitsToUint(hitResults.hitData[hBase+6]);
    // SHARC setup
    bool sharcEnabled = (cam.sharcCapacity > 0u);
    uint sharcCapacity = cam.sharcCapacity;
    SharcGridParams sharcGrid;
    sharcGrid.cameraPosition = vec3(cam.viewInverse[3][0], cam.viewInverse[3][1], cam.viewInverse[3][2]);
    sharcGrid.sceneScale = cam.sharcSceneScale;
    uint pixX_s = pixelIndex % pc.width;
    uint pixY_s = pixelIndex / pc.width;
    float sharcWarmup = sharcEnabled ? cam.sharcWarmupFactor : 0.0;
    bool sharcUpdatePixel = sharcEnabled && isSharcUpdatePixel(uvec2(pixX_s, pixY_s), pc.frameIndex, sharcWarmup);

    if (hitType == 0u) {
        // Miss — sky already accumulated by K1. Do SHARC backpropagation if update pixel.
        if (sharcUpdatePixel) {
            SharcState state = loadSharcState(pixelIndex);
            if (state.pathLength > 0u) {
                // Re-evaluate sky for SHARC (K2 has rayDir from PathState)
                vec3 skyColor = evaluateSky(rayDir);
                int hdriIdx = int(cam.windParams.x);
                if (hdriIdx >= 0) {
                    float phi = atan(-rayDir.z, rayDir.x);
                    float u = 0.5 - phi / (2.0 * PI);
                    float v = acos(clamp(rayDir.y, -1.0, 1.0)) / PI;
                    skyColor = texture(textures[nonuniformEXT(uint(hdriIdx))], vec2(u, v)).rgb * cam.windParams.y;
                }
                SharcUpdateMiss(sharcGrid, state, skyColor, sharcCapacity);
            }
        }
        return;
    }

    float hitT = hitResults.hitData[hBase+0];
    uint customIndex = floatBitsToUint(hitResults.hitData[hBase+1]);
    int instanceId = floatBitsToInt(hitResults.hitData[hBase+2]);
    int primitiveId = floatBitsToInt(hitResults.hitData[hBase+3]);
    vec2 bary2 = vec2(hitResults.hitData[hBase+4], hitResults.hitData[hBase+5]);
    vec3 bary = vec3(1.0 - bary2.x - bary2.y, bary2.x, bary2.y);

    // Read objToWorld 3x4 matrix
    mat4x3 objToWorld;
    objToWorld[0] = vec3(hitResults.hitData[hBase+8],  hitResults.hitData[hBase+12], hitResults.hitData[hBase+16]);
    objToWorld[1] = vec3(hitResults.hitData[hBase+9],  hitResults.hitData[hBase+13], hitResults.hitData[hBase+17]);
    objToWorld[2] = vec3(hitResults.hitData[hBase+10], hitResults.hitData[hBase+14], hitResults.hitData[hBase+18]);
    objToWorld[3] = vec3(hitResults.hitData[hBase+11], hitResults.hitData[hBase+15], hitResults.hitData[hBase+19]);

    // Fetch geometry data via buffer references
    GeometryMetadata geo = geometryMetadata.geometries[customIndex];
    Indices indices = Indices(geo.indexBufferAddress);
    Vertices vertices = Vertices(geo.vertexBufferAddress);
    Normals normals = Normals(geo.normalBufferAddress);
    UVs uvData = UVs(geo.uvBufferAddress);

    uint i0 = indices.i[primitiveId * 3 + 0];
    uint i1 = indices.i[primitiveId * 3 + 1];
    uint i2 = indices.i[primitiveId * 3 + 2];

    vec3 p0 = vec3(vertices.v[i0*3+0], vertices.v[i0*3+1], vertices.v[i0*3+2]);
    vec3 p1 = vec3(vertices.v[i1*3+0], vertices.v[i1*3+1], vertices.v[i1*3+2]);
    vec3 p2 = vec3(vertices.v[i2*3+0], vertices.v[i2*3+1], vertices.v[i2*3+2]);

    // World position from objToWorld matrix
    vec3 localPos = p0 * bary.x + p1 * bary.y + p2 * bary.z;
    vec3 worldPos = objToWorld * vec4(localPos, 1.0);

    // World-space vertex positions (for TBN / normal mapping)
    vec3 wp0 = objToWorld * vec4(p0, 1.0);
    vec3 wp1 = objToWorld * vec4(p1, 1.0);
    vec3 wp2 = objToWorld * vec4(p2, 1.0);

    // Normals — transform to world space via objToWorld 3x3
    vec3 n0 = vec3(normals.n[i0*3+0], normals.n[i0*3+1], normals.n[i0*3+2]);
    vec3 n1 = vec3(normals.n[i1*3+0], normals.n[i1*3+1], normals.n[i1*3+2]);
    vec3 n2 = vec3(normals.n[i2*3+0], normals.n[i2*3+1], normals.n[i2*3+2]);
    vec3 localN = normalize(n0 * bary.x + n1 * bary.y + n2 * bary.z);
    vec3 worldN = normalize(mat3(objToWorld) * localN);

    // Save smooth-interpolated normal BEFORE shadow terminator fix — used for glass refraction.
    // Smooth shading should affect refraction (the surface IS smooth),
    // but the terminator snap should NOT (it's a shading correction, not geometry).
    vec3 smoothN = worldN;

    // Raw geometric normal (true triangle winding — unambiguous for glass entry/exit)
    vec3 geoNormalRaw = normalize(cross(wp1 - wp0, wp2 - wp0));

    // Shadow terminator fix (matching monolithic raygen_blender.rgen):
    // When interpolated normals cross below the geometric face plane on
    // smooth-shaded curved meshes, snap to geometric normal to prevent
    // dark silhouette edges.
    vec3 geoNormal = geoNormalRaw;
    if (dot(geoNormal, -rayDir) < 0.0) geoNormal = -geoNormal;
    float NdotNg = dot(worldN, geoNormal);
    if (NdotNg < 0.0) {
        worldN = geoNormal;
    }

    // UVs
    vec2 uv0_ = vec2(uvData.uv[i0*2+0], 1.0 - uvData.uv[i0*2+1]);
    vec2 uv1_ = vec2(uvData.uv[i1*2+0], 1.0 - uvData.uv[i1*2+1]);
    vec2 uv2_ = vec2(uvData.uv[i2*2+0], 1.0 - uvData.uv[i2*2+1]);
    vec2 hitUV = uv0_ * bary.x + uv1_ * bary.y + uv2_ * bary.z;

    // Fetch material
    uint matIdx = 0u;
    if (geo.primMaterialBufferAddress != 0u) {
        PrimMaterials primMats = PrimMaterials(geo.primMaterialBufferAddress);
        matIdx = primMats.m[primitiveId];
    }

    // SER: reorder threads by material for coherent Node VM execution
    // Hardware-accelerated on RTX 40+, software fallback on 30 series
#ifdef GL_NV_shader_invocation_reorder
    reorderThreadNV(matIdx, 16);
#endif

    Material mat = materialBuffer.materials[matIdx];

    // Vertex colors
    vec4 vertexColor = vec4(1.0);
    if (geo.colorBufferAddress != 0u) {
        Colors colorData = Colors(geo.colorBufferAddress);
        vec4 vc0 = vec4(colorData.c[i0*4+0], colorData.c[i0*4+1], colorData.c[i0*4+2], colorData.c[i0*4+3]);
        vec4 vc1 = vec4(colorData.c[i1*4+0], colorData.c[i1*4+1], colorData.c[i1*4+2], colorData.c[i1*4+3]);
        vec4 vc2 = vec4(colorData.c[i2*4+0], colorData.c[i2*4+1], colorData.c[i2*4+2], colorData.c[i2*4+3]);
        vertexColor = vc0 * bary.x + vc1 * bary.y + vc2 * bary.z;
    }

    // Hair detection + cylinder normal computation
    // Strategy (matching monolithic fast paths):
    //  - Bounce 0: full ray-cylinder intersection (60-70 buffer reads, quality primary hit)
    //  - Bounce 1: ribbon fallback (3 normal reads, tangent decode, cross-product normal)
    //  - Bounce 2+: terminated immediately (hair BRDF section handles this)
    bool isHairSurface = (geo.bitangentBufferAddress != 0u);
    vec3 hairSmoothT = vec3(1, 0, 0);
    float hairV = 0.0;
    vec3 hairShadePos = worldPos;
    uint hairStrandId = INVALID_HAIR_STRAND;
    if (isHairSurface) {
        if (bounce == 0u) {
            // Full cylinder intersection for primary hits (quality matters)
            vec3 hairCylN;
            computeHairCylinder(geo, vertices, indices, normals, objToWorld,
                rayOrigin, rayDir, worldPos, i0, i1, i2, wp0, wp1, wp2,
                bary, primitiveId,
                hairCylN, hairSmoothT, hairV, hairShadePos, hairStrandId);
            worldN = hairCylN;
            geoNormalRaw = hairCylN;
            geoNormal = hairCylN;
            smoothN = hairCylN;
        } else {
            // Ribbon fallback: decode tangent from packed normals, derive normal from cross product
            // Cost: 9 normal reads + tangent decode (vs 60-70 scattered reads for full cylinder)
            vec3 rawN = vec3(normals.n[i0*3+0], normals.n[i0*3+1], normals.n[i0*3+2]) * bary.x
                      + vec3(normals.n[i1*3+0], normals.n[i1*3+1], normals.n[i1*3+2]) * bary.y
                      + vec3(normals.n[i2*3+0], normals.n[i2*3+1], normals.n[i2*3+2]) * bary.z;
            hairSmoothT = normalize(mat3(objToWorld) * octDecode_hair(vec2(rawN.y, rawN.z)));
            // Use ribbon geometric normal (perpendicular to tangent and view)
            vec3 ribbonN = normalize(cross(hairSmoothT, -rayDir));
            ribbonN = normalize(cross(ribbonN, hairSmoothT));
            if (dot(ribbonN, -rayDir) < 0.0) ribbonN = -ribbonN;
            worldN = ribbonN;
            geoNormalRaw = ribbonN;
            geoNormal = ribbonN;
            smoothN = ribbonN;
        }
    }

    // ── Node VM: per-pixel node tree evaluation ──
    uint vmInstrCount = mat.nodeVmHeader & 0xFFu;
    bool vmActive = vmInstrCount > 0u;

    // Compute dP/du and dP/dv from triangle for bump mapping (Cycles-matching)
    vec2 duv1 = uv1_ - uv0_;
    vec2 duv2 = uv2_ - uv0_;
    vec3 dp1 = wp1 - wp0;
    vec3 dp2 = wp2 - wp0;
    float uvDet = duv1.x * duv2.y - duv1.y * duv2.x;
    float invUvDet = (abs(uvDet) > 1e-8) ? 1.0 / uvDet : 0.0;
    vec3 triDPdu = (dp1 * duv2.y - dp2 * duv1.y) * invUvDet;
    vec3 triDPdv = (dp2 * duv1.x - dp1 * duv2.x) * invUvDet;

    NodeVmResult vm;
    if (vmActive) {
        vm = executeNodeVm(matIdx, hitUV, worldPos, rayDir, worldN, vertexColor, uint(instanceId), localPos, triDPdu, triDPdv);
    } else {
        vm.hasBaseColor = false;
        vm.hasRoughness = false;
        vm.hasMetallic = false;
        vm.hasEmission = false;
        vm.hasAlpha = false;
        vm.hasIor = false;
        vm.hasTransmission = false;
        vm.hasTransformedUV = false;
        vm.hasNormalStrength = false;
        vm.hasBump = false;
    }

    // ── Material evaluation: VM is the single authority ──
    vec3 baseColor;
    float texAlpha = 1.0;
    vec2 texUV = (vmActive && vm.hasTransformedUV) ? vm.transformedUV : hitUV;
    float roughness = clamp(mat.ksSpecularEXP, 0.01, 1.0);
    float metallic = clamp(mat.fresnelC, 0.0, 1.0);
    float specularLevel = mat.fresnelEXP;
    float ior = mat.detailUVMultiplier;
    float transmission = mat.multR;
    float coatWeight = clamp(mat.detailNMMult, 0.0, 1.0);     // 0 = no coat
    float coatRoughness = clamp(mat.detailNMMultV, 0.01, 1.0); // coat surface roughness
    const float coatIOR = 1.5;  // standard coat IOR (lacquer/varnish)
    // Sheen (fabric/velvet edge-brightening)
    float sheenWeight = clamp(uintBitsToFloat(mat.detailATexIndex), 0.0, 1.0);
    float sheenRoughness = clamp(uintBitsToFloat(mat.detailNMTexIndex), 0.01, 1.0);
    vec3 sheenTint = vec3(1.0);
    // Anisotropic (brushed metal, hair)
    uint anisoPacked = mat.normalDetailTexIndex;
    float anisotropicFactor = (anisoPacked != 0xFFFFFFFFu) ? clamp(uintBitsToFloat(anisoPacked), 0.0, 1.0) : 0.0;
    float anisotropicRotation = 0.0;
    // Specular Tint + Diffuse Roughness from nodeVmPad
    uint specTintPacked = mat.nodeVmPad[0];
    vec3 specularTint = vec3(
        float((specTintPacked >> 0u) & 0x7FFu) / 2047.0,
        float((specTintPacked >> 11u) & 0x7FFu) / 2047.0,
        float((specTintPacked >> 22u) & 0x3FFu) / 1023.0
    );
    if (specTintPacked == 0u) specularTint = vec3(1.0);  // default white
    float diffuseRoughness = uintBitsToFloat(mat.nodeVmPad[1]);
    // SSS (subsurface scattering) — Barré-Brisebois translucency approximation
    float sssWeight = uintBitsToFloat(mat.maskTexIndex);         // 0 = no SSS
    vec3 sssRadius = vec3(
        uintBitsToFloat(mat.detailRTexIndex),
        uintBitsToFloat(mat.detailGTexIndex),
        uintBitsToFloat(mat.detailBTexIndex)
    );
    sssWeight = clamp(sssWeight, 0.0, 1.0);
    float hairShift = ((mat.flags & MAT_FLAG_HAIR) != 0u) ? mat.sunSpecular : 0.035;
    float hairRadialRoughness = ((mat.flags & MAT_FLAG_HAIR) != 0u) ?
                                clamp(mat.sunSpecularEXP, 0.01, 1.0) : roughness;

    // Stochastic passthrough disables glass refraction
    float tpCheck = mat.multB;
    if (tpCheck > 0.0) transmission = 0.0;

    if (vmActive && vm.hasBaseColor) {
        baseColor = vm.baseColor;
        if (vm.hasAlpha) {
            texAlpha = vm.alpha;
        } else if (mat.diffuseTexIndex != 0xFFFFFFFFu) {
            texAlpha = texture(textures[nonuniformEXT(mat.diffuseTexIndex)], texUV).a;
        }
    } else {
        if (mat.diffuseTexIndex != 0xFFFFFFFFu) {
            vec4 texColor = texture(textures[nonuniformEXT(mat.diffuseTexIndex)], hitUV);
            bool diffuseIsSceneLinear = (mat.flags & MAT_FLAG_DIFFUSE_SCENE_LINEAR) != 0u;
            baseColor = diffuseIsSceneLinear ? texColor.rgb : srgbToLinearExact(max(texColor.rgb, vec3(0.0)));
            texAlpha = texColor.a;
        } else {
            baseColor = vec3(mat.ksAmbient, mat.ksDiffuse, mat.ksSpecular);
        }
    }
    float alpha = texAlpha * mat.multG;

    // VM overrides
    if (vmActive) {
        if (vm.hasRoughness)    roughness = clamp(vm.roughness, 0.01, 1.0);
        if (vm.hasMetallic)     metallic = clamp(vm.metallic, 0.0, 1.0);
        if (vm.hasIor)          ior = vm.ior;
        if (vm.hasTransmission) transmission = vm.transmission;
    }

    // Shadow bias: larger for hair to avoid ribbon-on-ribbon self-shadowing
    float shadowBias = isHairSurface ? 0.1 : 0.002;

    // Material category for sort (bits [12:14] of PathState flags)
    // 0=opaque, 1=glass, 2=hair, 3=volume, 4=complex VM
    uint materialCategory = 0u;
    if (isHairSurface)                              materialCategory = 2u;
    else if ((mat.flags & 4u) != 0u)                materialCategory = 3u;  // volume
    else if ((1.0 - metallic) * transmission > 0.5) materialCategory = 1u;  // glass
    else if ((mat.nodeVmHeader & 0xFFu) > 16u)      materialCategory = 4u;  // complex VM
    uint matCatBits = (materialCategory & 0x7u) << 12u;

    // Capture secondary hit distance (bounce 1) for denoiser shadow guidance
    // DLSS RR uses diffuse hitT to guide spatial filtering — mixing in secondary
    // bounce distance helps resolve shadow penumbra (RTXPT technique)
    uint rBaseHit = pixelIndex * 8u;
    if (bounce == 1u && pc.sampleIdx == 0u) {
        // Store secondary hitDist — K5 will use max(secondary, primary) for diffuse hitT
        // Encode as negative to distinguish from primary (K5 checks sign)
        pixelRadiance.radDataU[rBaseHit+3] = floatBitsToUint(-hitT);
    }

    // Penumbra tracking for NRD SIGMA / DLSS RR (written at bounce 0 sun NEE)
    float primaryPenumbra = 65504.0;  // default = fully lit (max half-float)
    float primaryNdotL = 0.0;

    // Glass detection (after VM overrides, before emission/ambient)
    bool isGlass = ((1.0 - metallic) * transmission > 0.99);

    // ORM map (fills what VM didn't provide)
    if (mat.mapsTexIndex != 0xFFFFFFFFu) {
        vec4 orm = texture(textures[nonuniformEXT(mat.mapsTexIndex)], texUV);
        if (!(vmActive && vm.hasRoughness)) roughness = clamp(orm.g, 0.01, 1.0);
        if (!(vmActive && vm.hasMetallic))  metallic = clamp(orm.b, 0.0, 1.0);
    }

    // Normal mapping
    vec3 N = worldN;
    if (mat.normalTexIndex != 0xFFFFFFFFu) {
        vec3 T, B;
        computeTBN(wp0, wp1, wp2, uv0_, uv1_, uv2_, N, T, B);
        float rawStrength = mat.detailNormalBlend;
        if (rawStrength < 0.0) {
            // Bump/height map (Cycles-style)
            float packed = abs(rawStrength);
            float bumpDistance = floor(packed) / 100.0;
            float bumpStrength = fract(packed);
            ivec2 texDim = textureSize(textures[nonuniformEXT(mat.normalTexIndex)], 0);
            float texelSize = 1.0 / float(max(texDim.x, texDim.y));
            // Read height as luminance with sRGB gamma for proper contrast
            // Color textures used as height maps need gamma to preserve
            // dark-range gradients (linearized textures compress darks)
            vec3 hc_rgb = texture(textures[nonuniformEXT(mat.normalTexIndex)], texUV).rgb;
            vec3 hx_rgb = texture(textures[nonuniformEXT(mat.normalTexIndex)], texUV + vec2(texelSize, 0)).rgb;
            vec3 hy_rgb = texture(textures[nonuniformEXT(mat.normalTexIndex)], texUV + vec2(0, texelSize)).rgb;
            // Luminance weights (Rec.709)
            const vec3 lumW = vec3(0.2126, 0.7152, 0.0722);
            float h_c = pow(max(dot(hc_rgb, lumW), 0.0), 1.0/2.2);
            float h_x = pow(max(dot(hx_rgb, lumW), 0.0), 1.0/2.2);
            float h_y = pow(max(dot(hy_rgb, lumW), 0.0), 1.0/2.2);
            vec3 Tn = normalize(T);
            vec3 Bn = normalize(B);
            float texScale = pow(float(max(texDim.x, texDim.y)), 0.65);
            vec3 surfgrad = (h_x - h_c) * Tn + (h_y - h_c) * Bn;
            vec3 bumpN = normalize(N - bumpDistance * texScale * surfgrad);
            N = normalize(bumpStrength * bumpN + (1.0 - bumpStrength) * N);
        } else {
            vec3 texN = texture(textures[nonuniformEXT(mat.normalTexIndex)], texUV).rgb;
            float strength = rawStrength > 0.0 ? rawStrength : 1.0;
            N = applyNormalMap(texN, T, N, B, strength);
        }
    }
    // Bump from VM (procedural noise OR texture — Cycles svm_node_set_bump matching)
    if (vmActive && vm.hasBump) {
        vec3 T, B;
        computeTBN(wp0, wp1, wp2, uv0_, uv1_, uv2_, N, T, B);
        vec3 Tn = normalize(T);
        vec3 Bn = normalize(B);
        // Reconstruct world-space surfgrad from tangent-space components
        vec3 surfgrad = vm.bumpGradient.x * Tn + vm.bumpGradient.y * Bn;
        float absDet = vm.bumpDet;  // |det| from UV→world mapping (0 for noise bump)
        // Cycles formula: N' = normalize(filterWidth * |det| * N - scale * surfgrad)
        // For texture bump: absDet > 0, use Cycles formula
        // For noise bump: absDet = 0, use simplified formula
        vec3 bumpN;
        if (absDet > 1e-6) {
            bumpN = normalize(absDet * N - vm.bumpDistance * surfgrad);
        } else {
            bumpN = normalize(N - vm.bumpDistance * surfgrad);
        }
        N = normalize(vm.bumpStrength * bumpN + (1.0 - vm.bumpStrength) * N);
    }

    // frontFace + NdotV clamp (matching monolithic raygen_blender.rgen)
    vec3 gN = geoNormal;  // camera-facing geometric normal
    bool frontFace = dot(gN, -rayDir) >= 0.0;
    if (!frontFace) {
        gN = -gN;
        N = -N;
    }
    // Clamp perturbed normal: if normal map pushed N behind the surface,
    // blend back toward geometric normal to avoid black bands at grazing angles.
    float NdotV_check = dot(N, -rayDir);
    if (NdotV_check < 0.01) {
        float blend = clamp(-NdotV_check * 50.0 + 0.5, 0.0, 1.0);
        N = normalize(mix(N, gN, blend));
    }

    // Anisotropic tangent frame (from triangle UVs, optionally rotated)
    vec3 anisoT = normalize(triDPdu);
    vec3 anisoB = normalize(cross(N, anisoT));
    anisoT = cross(anisoB, N);  // re-orthogonalize
    if (anisotropicRotation > 0.001) {
        float rotAngle = anisotropicRotation * 2.0 * PI;
        float cr = cos(rotAngle), sr = sin(rotAngle);
        vec3 newT = cr * anisoT + sr * anisoB;
        anisoB = -sr * anisoT + cr * anisoB;
        anisoT = newT;
    }

    // Stochastic alpha test with INLINE re-trace (matching monolithic):
    // Instead of re-queuing (which consumes dispatch iterations), trace through
    // multiple transparent layers directly in K2. This handles stacked transparents
    // (fire, foliage, curtains) without exhausting the bounce budget.
    if ((mat.flags & 1u) != 0u && alpha < 0.999 && rand01() > alpha) {
        // Inline alpha skip loop: trace through up to 8 transparent layers
        vec3 skipOrigin = worldPos + rayDir * 0.002;
        bool foundOpaque = false;
        for (int alphaSkip = 0; alphaSkip < 8; alphaSkip++) {
            rayQueryEXT alphaRQ;
            rayQueryInitializeEXT(alphaRQ, topLevelAS, gl_RayFlagsOpaqueEXT,
                                  0xFF, skipOrigin, MIN_HIT_DIST, rayDir, 10000.0);
            while (rayQueryProceedEXT(alphaRQ)) {}

            if (rayQueryGetIntersectionTypeEXT(alphaRQ, true) == gl_RayQueryCommittedIntersectionNoneEXT) {
                // Sky miss — accumulate sky and terminate
                vec3 skyThroughput = throughput;
                vec3 skyColor = evaluateSky(rayDir);
                int hdriIdx = int(cam.windParams.x);
                if (hdriIdx >= 0) {
                    float phi = atan(-rayDir.z, rayDir.x);
                    float u = 0.5 - phi / (2.0 * PI);
                    float v = acos(clamp(rayDir.y, -1.0, 1.0)) / PI;
                    skyColor = texture(textures[nonuniformEXT(uint(hdriIdx))], vec2(u, v)).rgb * cam.windParams.y;
                }
                uint rBase = pixelIndex * 8u;
                // MIS: halve diffuse BSDF-miss sky contribution (other half comes from env NEE)
                float skyMis = (bounce > 0u && isDiffusePath) ? 0.5 : 1.0;
                vec3 skyContrib = skyColor * skyThroughput * skyMis;
                if (bounce == 0u) {
                    atomicAddFloat(rBase+0, skyContrib.x);
                    atomicAddFloat(rBase+1, skyContrib.y);
                    atomicAddFloat(rBase+2, skyContrib.z);
                } else if (isDiffusePath) {
                    float gi = cam.ptParams0.y;
                    atomicAddFloat(rBase+0, skyContrib.x * gi);
                    atomicAddFloat(rBase+1, skyContrib.y * gi);
                    atomicAddFloat(rBase+2, skyContrib.z * gi);
                } else {
                    float gi = cam.ptParams0.y;
                    atomicAddFloat(rBase+4, skyContrib.x * gi);
                    atomicAddFloat(rBase+5, skyContrib.y * gi);
                    atomicAddFloat(rBase+6, skyContrib.z * gi);
                }
                psTerminate(idx, flags);
                return;
            }

            // Hit something — check if it's also alpha-tested
            float aHitT = rayQueryGetIntersectionTEXT(alphaRQ, true);
            uint aCustIdx = rayQueryGetIntersectionInstanceCustomIndexEXT(alphaRQ, true);
            int aPrimId = rayQueryGetIntersectionPrimitiveIndexEXT(alphaRQ, true);
            GeometryMetadata aGeo = geometryMetadata.geometries[aCustIdx];
            uint aMatIdx = 0u;
            if (aGeo.primMaterialBufferAddress != 0u) {
                PrimMaterials aPM = PrimMaterials(aGeo.primMaterialBufferAddress);
                aMatIdx = aPM.m[aPrimId];
            }
            Material aMat = materialBuffer.materials[aMatIdx];

            // Glass/volume: pass through silently
            if ((aMat.flags & 6u) != 0u) {
                skipOrigin += rayDir * (aHitT + 0.003);
                continue;
            }

            // Check alpha of the new hit
            bool aAlphaTest = (aMat.flags & 1u) != 0u;
            if (aAlphaTest) {
                // Quick alpha sample from diffuse texture
                float aAlpha = aMat.multG; // default alpha multiplier
                if (aMat.diffuseTexIndex != 0xFFFFFFFFu && aGeo.uvBufferAddress != 0u) {
                    Indices aIdx = Indices(aGeo.indexBufferAddress);
                    UVs aUV = UVs(aGeo.uvBufferAddress);
                    uint ai0 = aIdx.i[aPrimId*3+0], ai1 = aIdx.i[aPrimId*3+1], ai2 = aIdx.i[aPrimId*3+2];
                    vec2 aBary2 = rayQueryGetIntersectionBarycentricsEXT(alphaRQ, true);
                    vec3 aBary = vec3(1.0-aBary2.x-aBary2.y, aBary2.x, aBary2.y);
                    vec2 aHitUV = vec2(aUV.uv[ai0*2], 1.0-aUV.uv[ai0*2+1]) * aBary.x
                                + vec2(aUV.uv[ai1*2], 1.0-aUV.uv[ai1*2+1]) * aBary.y
                                + vec2(aUV.uv[ai2*2], 1.0-aUV.uv[ai2*2+1]) * aBary.z;
                    aAlpha = texture(textures[nonuniformEXT(aMat.diffuseTexIndex)], aHitUV).a * aMat.multG;
                } else if (aMat.detailTexIndex != 0xFFFFFFFFu && aGeo.uvBufferAddress != 0u) {
                    Indices aIdx = Indices(aGeo.indexBufferAddress);
                    UVs aUV = UVs(aGeo.uvBufferAddress);
                    uint ai0 = aIdx.i[aPrimId*3+0], ai1 = aIdx.i[aPrimId*3+1], ai2 = aIdx.i[aPrimId*3+2];
                    vec2 aBary2 = rayQueryGetIntersectionBarycentricsEXT(alphaRQ, true);
                    vec3 aBary = vec3(1.0-aBary2.x-aBary2.y, aBary2.x, aBary2.y);
                    vec2 aHitUV = vec2(aUV.uv[ai0*2], 1.0-aUV.uv[ai0*2+1]) * aBary.x
                                + vec2(aUV.uv[ai1*2], 1.0-aUV.uv[ai1*2+1]) * aBary.y
                                + vec2(aUV.uv[ai2*2], 1.0-aUV.uv[ai2*2+1]) * aBary.z;
                    aAlpha = texture(textures[nonuniformEXT(aMat.detailTexIndex)], aHitUV).a * aMat.multG;
                }
                if (aAlpha < 0.999 && rand01() > aAlpha) {
                    skipOrigin += rayDir * (aHitT + 0.002);
                    continue; // transparent — skip this layer too
                }
            }

            // Opaque hit found — re-queue for full shading at this position
            foundOpaque = true;
            // Write HitResult so K2 can process it on re-entry
            // Actually, just re-queue the path to this new origin for next iteration
            uint nextIdx = atomicAdd(counters.nextActiveRayCount, 1u);
            uint nBase = nextIdx * 12u;
            vec3 newOrigin = skipOrigin; // already past all transparent layers
            psWriteAll(nextIdx, newOrigin, pixelIndex, rayDir, rngState, throughput, flags | matCatBits);
            break;
        }
        psTerminate(idx, flags);
        return;
    }

    // ---- SHARC cache query (bounce 1+): early-out with cached GI ----
    if (sharcEnabled && bounce >= 1u) {
        vec3 cachedRadiance;
        if (SharcGetCachedRadiance(sharcGrid, worldPos, N, sharcCapacity, cachedRadiance)) {
            cachedRadiance *= cam.ptParams0.y; // giIntensity
            uint rBase = pixelIndex * 8u;
            vec3 contrib = cachedRadiance * throughput;
            if (isDiffusePath) {
                atomicAddFloat(rBase+0, contrib.x);
                atomicAddFloat(rBase+1, contrib.y);
                atomicAddFloat(rBase+2, contrib.z);
            } else {
                atomicAddFloat(rBase+4, contrib.x);
                atomicAddFloat(rBase+5, contrib.y);
                atomicAddFloat(rBase+6, contrib.z);
            }
            // Backpropagate cached radiance through SHARC state history
            if (sharcUpdatePixel) {
                SharcState state = loadSharcState(pixelIndex);
                for (uint i = 0u; i < state.pathLength; i++) {
                    sharcAccumulate(state.cacheIndices[i], cachedRadiance, state.sampleWeights[i]);
                }
            }
            psTerminate(idx, flags);
            return;
        }
    }

    // ---- Volume rendering (replaces surface BRDF for volume materials) ----
    bool isVolumeOnly = (mat.flags & 4u) != 0u && (mat.flags & 8u) != 0u;
    bool hasSurfaceVolume = (mat.flags & 4u) != 0u && (mat.flags & 8u) == 0u;
    bool isHetero = (mat.flags & 16u) != 0u;
    if (isVolumeOnly || hasSurfaceVolume) {
        // Skip volume march on deep bounces (matching monolithic: volume only at primary/first hit)
        if (bounce >= 2u) {
            psTerminate(idx, flags);
            return;
        }

        // Only enter from front face
        bool entering = dot(geoNormalRaw, -rayDir) > 0.0;
        if (!entering) {
            // Pass through back face
            uint nextIdx = atomicAdd(counters.nextActiveRayCount, 1u);
            uint nBase = nextIdx * 12u;
            vec3 skipOrigin = worldPos + rayDir * 0.002;
            psWriteAll(nextIdx, skipOrigin, pixelIndex, rayDir, rngState, throughput, flags);
            psTerminate(idx, flags);
            return;
        }

        // Volume material properties
        float volumeDensity = mat.sunSpecular;
        float volumeAnisotropy = mat.sunSpecularEXP;
        vec3 volumeColor = baseColor;
        vec3 absorptionColor = vec3(uintBitsToFloat(mat.nodeVmCode[2].x),
                                     uintBitsToFloat(mat.nodeVmCode[2].y),
                                     uintBitsToFloat(mat.nodeVmCode[2].z));
        float emStrength = uintBitsToFloat(mat.nodeVmCode[2].w);
        vec3 emColor = vec3(uintBitsToFloat(mat.nodeVmCode[3].x),
                            uintBitsToFloat(mat.nodeVmCode[3].y),
                            uintBitsToFloat(mat.nodeVmCode[3].z));
        float temperature = uintBitsToFloat(mat.nodeVmCode[3].w);
        float blackbodyIntensity = uintBitsToFloat(mat.nodeVmCode[4].x);

        // Find exit distance AND inner geometry
        vec3 entryPos = worldPos + rayDir * 0.0005;
        float marchDist = traceVolumeExit(topLevelAS, entryPos, rayDir, instanceId);

        // Check for geometry INSIDE the volume — if found, clip march
        // and re-queue PAST the inner surface (not before) to avoid re-entering volume loop
        bool hasInnerHit = false;
        {
            rayQueryEXT innerRQ;
            rayQueryInitializeEXT(innerRQ, topLevelAS, gl_RayFlagsOpaqueEXT,
                                  0xFF, entryPos, MIN_HIT_DIST, rayDir, marchDist - 0.001);
            while (rayQueryProceedEXT(innerRQ)) {}
            if (rayQueryGetIntersectionTypeEXT(innerRQ, true) != gl_RayQueryCommittedIntersectionNoneEXT) {
                int iInstId = rayQueryGetIntersectionInstanceIdEXT(innerRQ, true);
                if (iInstId != instanceId) {
                    float iHitT = rayQueryGetIntersectionTEXT(innerRQ, true);
                    marchDist = iHitT;  // clip march to inner surface
                    hasInnerHit = true;
                }
            }
        }

        // Sky/sun for in-scattering
        vec3 sunDir = normalize(cam.sunLight.xyz);
        float sunIntensity = cam.sunLight.w;
        vec3 sunColor = cam.skyLight.rgb;

        // Evaluate sky for ambient in-scattering (use HDRI if available)
        int hdriIdx = int(cam.windParams.x);
        vec3 skyColor;
        if (hdriIdx >= 0) {
            float hdriStr = cam.windParams.y;
            // Simple sky approximation for volume (average of a few directions)
            skyColor = vec3(hdriStr * 0.5);
        } else {
            vec3 ambColor = cam.ambientLight.rgb;
            skyColor = ambColor * max(sunDir.y * 3.0 + 0.3, 0.05);
        }

        // Accumulate radiance
        uint rBase = pixelIndex * 8u;
        vec3 volRadiance = vec3(0.0);

        if (!isHetero) {
            // Homogeneous volume (analytic)
            marchVolumeHomogeneous(entryPos, rayDir, marchDist,
                volumeColor, absorptionColor, volumeDensity, volumeAnisotropy,
                emColor, emStrength, temperature, blackbodyIntensity,
                sunDir, sunIntensity, sunColor, skyColor,
                volRadiance, throughput);
        } else {
            // Heterogeneous volume (ray march with noise)
            // Noise parameters from material
            float noiseScale = uintBitsToFloat(mat.nodeVmPad[0]);
            float noiseDetail = uintBitsToFloat(mat.nodeVmPad[1]);
            float noiseBrightness = uintBitsToFloat(mat.nodeVmPad[2]);
            float noiseRoughness_ = uintBitsToFloat(mat.nodeVmCode[0].x);
            float noiseLacunarity = uintBitsToFloat(mat.nodeVmCode[0].y);
            float noiseContrast = uintBitsToFloat(mat.nodeVmCode[0].z);
            vec3 mappingOffset = vec3(uintBitsToFloat(mat.nodeVmCode[1].x),
                                      uintBitsToFloat(mat.nodeVmCode[1].y),
                                      uintBitsToFloat(mat.nodeVmCode[1].z));
            uint noiseTypePacked = mat.nodeVmCode[4].y;
            int noiseType = int(noiseTypePacked & 0xFFFFu);
            bool noiseNormalize = (noiseTypePacked >> 16u) != 0u;
            float noiseOffset = uintBitsToFloat(mat.nodeVmCode[4].z);
            float noiseGain = uintBitsToFloat(mat.nodeVmCode[4].w);
            uint noiseDimensions = mat.nodeVmCode[0].w;
            float noiseW = uintBitsToFloat(mat.nodeVmCode[1].w);

            vec3 volBboxMin = vec3(uintBitsToFloat(mat.nodeVmCode[5].x),
                                   uintBitsToFloat(mat.nodeVmCode[5].y),
                                   uintBitsToFloat(mat.nodeVmCode[5].z));
            vec3 volBboxMax = vec3(uintBitsToFloat(mat.nodeVmCode[6].x),
                                   uintBitsToFloat(mat.nodeVmCode[6].y),
                                   uintBitsToFloat(mat.nodeVmCode[6].z));
            vec3 volBboxRange = max(volBboxMax - volBboxMin, vec3(0.001));

            // Extended volume chain (nodeVmCode[7..14])
            uint volFlags2 = mat.nodeVmCode[10].w;
            bool useObjectCoords = (volFlags2 & 1u) != 0u;
            bool hasFullMatrix = (volFlags2 & 2u) != 0u;
            bool hasGradient = (volFlags2 & 4u) != 0u;
            bool hasMix = (volFlags2 & 8u) != 0u;
            bool hasRamp = (volFlags2 & 16u) != 0u;
            bool hasDistortion = (volFlags2 & 32u) != 0u;
            uint chainTarget = (volFlags2 >> 8u) & 0xFu;

            vec4 mapRow0 = vec4(uintBitsToFloat(mat.nodeVmCode[7].x), uintBitsToFloat(mat.nodeVmCode[7].y),
                                uintBitsToFloat(mat.nodeVmCode[7].z), uintBitsToFloat(mat.nodeVmCode[7].w));
            vec4 mapRow1 = vec4(uintBitsToFloat(mat.nodeVmCode[8].x), uintBitsToFloat(mat.nodeVmCode[8].y),
                                uintBitsToFloat(mat.nodeVmCode[8].z), uintBitsToFloat(mat.nodeVmCode[8].w));
            vec4 mapRow2 = vec4(uintBitsToFloat(mat.nodeVmCode[9].x), uintBitsToFloat(mat.nodeVmCode[9].y),
                                uintBitsToFloat(mat.nodeVmCode[9].z), uintBitsToFloat(mat.nodeVmCode[9].w));
            float noiseDistortion = uintBitsToFloat(mat.nodeVmCode[10].x);
            int gradientType = int(mat.nodeVmCode[10].y);
            float mixFactor = uintBitsToFloat(mat.nodeVmCode[10].z);
            vec4 rampLut0 = vec4(uintBitsToFloat(mat.nodeVmCode[11].x), uintBitsToFloat(mat.nodeVmCode[11].y),
                                 uintBitsToFloat(mat.nodeVmCode[11].z), uintBitsToFloat(mat.nodeVmCode[11].w));
            vec4 rampLut1 = vec4(uintBitsToFloat(mat.nodeVmCode[12].x), uintBitsToFloat(mat.nodeVmCode[12].y),
                                 uintBitsToFloat(mat.nodeVmCode[12].z), uintBitsToFloat(mat.nodeVmCode[12].w));
            vec4 rampLut2 = vec4(uintBitsToFloat(mat.nodeVmCode[13].x), uintBitsToFloat(mat.nodeVmCode[13].y),
                                 uintBitsToFloat(mat.nodeVmCode[13].z), uintBitsToFloat(mat.nodeVmCode[13].w));
            vec4 rampLut3 = vec4(uintBitsToFloat(mat.nodeVmCode[14].x), uintBitsToFloat(mat.nodeVmCode[14].y),
                                 uintBitsToFloat(mat.nodeVmCode[14].z), uintBitsToFloat(mat.nodeVmCode[14].w));

            // Compute worldToObj (inverse of objToWorld 3x3 + translation)
            mat3 m3 = mat3(objToWorld);
            mat4x3 worldToObj;
            mat3 inv3 = inverse(m3);
            vec3 trans = objToWorld[3];
            worldToObj[0] = inv3[0];
            worldToObj[1] = inv3[1];
            worldToObj[2] = inv3[2];
            worldToObj[3] = -(inv3 * trans);

            marchVolumeHeterogeneous(entryPos, rayDir, marchDist, worldToObj,
                volumeColor, absorptionColor, volumeDensity, volumeAnisotropy,
                emColor, emStrength, temperature, blackbodyIntensity,
                noiseScale, noiseDetail, noiseBrightness, noiseRoughness_,
                noiseLacunarity, noiseContrast, mappingOffset,
                noiseType, noiseNormalize, noiseOffset, noiseGain,
                noiseDimensions, noiseW, noiseDistortion,
                hasDistortion, hasFullMatrix, mapRow0, mapRow1, mapRow2,
                gradientType, hasGradient, mixFactor, hasMix,
                hasRamp, rampLut0, rampLut1, rampLut2, rampLut3,
                chainTarget, useObjectCoords, volBboxMin, volBboxRange,
                sunDir, sunIntensity, sunColor, skyColor,
                cam.lightCount, cam.lights,
                volRadiance, throughput);
        }

        // Accumulate volume radiance
        atomicAddFloat(rBase+0, volRadiance.x);
        atomicAddFloat(rBase+1, volRadiance.y);
        atomicAddFloat(rBase+2, volRadiance.z);

        // Write G-buffer for volume surface (bounce 0)
        if (bounce == 0u && pc.sampleIdx == 0u) {
            uint gBase = pixelIndex * 16u;
            primaryGBuf.gbufData[gBase+0] = N.x;
            primaryGBuf.gbufData[gBase+1] = N.y;
            primaryGBuf.gbufData[gBase+2] = N.z;
            primaryGBuf.gbufData[gBase+3] = 1.0; // roughness = 1 for volume
            primaryGBuf.gbufData[gBase+4] = worldPos.x;
            primaryGBuf.gbufData[gBase+5] = worldPos.y;
            primaryGBuf.gbufData[gBase+6] = worldPos.z;
            vec4 viewPos = cam.view * vec4(worldPos, 1.0);
            primaryGBuf.gbufData[gBase+7] = viewPos.z;
            primaryGBuf.gbufData[gBase+8] = baseColor.x;
            primaryGBuf.gbufData[gBase+9] = baseColor.y;
            primaryGBuf.gbufData[gBase+10] = baseColor.z;
            primaryGBuf.gbufData[gBase+11] = hitT;
            primaryGBuf.gbufData[gBase+12] = localPos.x;
            primaryGBuf.gbufData[gBase+13] = localPos.y;
            primaryGBuf.gbufData[gBase+14] = localPos.z;
            primaryGBuf.gbufData[gBase+15] = uintBitsToFloat(uint(instanceId));
            pixelRadiance.radDataU[rBase+7] = floatBitsToUint(0.0);
            pixelRadiance.radDataU[rBase+3] = floatBitsToUint(hitT);
        }

        // Continue ray past the volume or to inner surface
        uint nextIdx = atomicAdd(counters.nextActiveRayCount, 1u);
        uint nBase = nextIdx * 12u;
        vec3 volExit;
        if (hasInnerHit) {
            // Position just before inner surface — K1 will find it (not the volume
            // front face, which is behind us since we're inside the volume)
            volExit = entryPos + rayDir * max(marchDist - 0.001, 0.0);
        } else {
            volExit = entryPos + rayDir * (marchDist + 0.002);
        }
        uint volFlags = bounce | (isDiffusePath ? 0x10u : 0u) | (flags & 0x1FF00u) | matCatBits;
        psWriteAll(nextIdx, volExit, pixelIndex, rayDir, rngState, throughput, volFlags);
        psTerminate(idx, flags);
        return;
    }

    // Emission (VM-aware, matching raygen_blender.rgen)
    vec3 emission;
    if (vmActive && vm.hasEmission) {
        emission = vm.emission * PI;
    } else {
        vec3 emissionColor = vec3(mat.emissiveR, mat.emissiveG, mat.emissiveB);
        if (mat.detailTexIndex != 0xFFFFFFFFu) {
            vec3 emTex = texture(textures[nonuniformEXT(mat.detailTexIndex)], hitUV).rgb;
            if (dot(emissionColor, emissionColor) < 0.001) {
                emissionColor = emTex;
            } else {
                emissionColor *= emTex;
            }
        }
        emission = emissionColor * mat.fresnelMaxLevel * PI;
    }
    vec3 emissionContrib = emission * throughput;

    // Accumulate emission (atomic for thread safety across bounces)
    // Accumulate emission (atomic for thread safety across bounces)
    uint rBase = pixelIndex * 8u;
    if (bounce == 0u) {
        atomicAddFloat(rBase+0, emissionContrib.x);
        atomicAddFloat(rBase+1, emissionContrib.y);
        atomicAddFloat(rBase+2, emissionContrib.z);
    } else {
        if (isDiffusePath) {
            atomicAddFloat(rBase+0, emissionContrib.x);
            atomicAddFloat(rBase+1, emissionContrib.y);
            atomicAddFloat(rBase+2, emissionContrib.z);
        } else {
            atomicAddFloat(rBase+4, emissionContrib.x);
            atomicAddFloat(rBase+5, emissionContrib.y);
            atomicAddFloat(rBase+6, emissionContrib.z);
        }
    }

    // Bounce 0, first sample: write primary G-buffer data
    // Early glass returns before here, so this only fires for non-glass or
    // the resolved surface behind glass (last surface at bounce 0 wins).
    if (bounce == 0u && pc.sampleIdx == 0u) {
        uint gBase = pixelIndex * 16u;
        primaryGBuf.gbufData[gBase+0] = N.x;
        primaryGBuf.gbufData[gBase+1] = N.y;
        primaryGBuf.gbufData[gBase+2] = N.z;
        primaryGBuf.gbufData[gBase+3] = roughness;
        primaryGBuf.gbufData[gBase+4] = worldPos.x;
        primaryGBuf.gbufData[gBase+5] = worldPos.y;
        primaryGBuf.gbufData[gBase+6] = worldPos.z;
        vec4 viewPos = cam.view * vec4(worldPos, 1.0);
        primaryGBuf.gbufData[gBase+7] = viewPos.z; // viewZ
        primaryGBuf.gbufData[gBase+8] = baseColor.x;
        primaryGBuf.gbufData[gBase+9] = baseColor.y;
        primaryGBuf.gbufData[gBase+10] = baseColor.z;
        primaryGBuf.gbufData[gBase+11] = hitT; // hitDist
        // localPos for motion vectors
        primaryGBuf.gbufData[gBase+12] = localPos.x;
        primaryGBuf.gbufData[gBase+13] = localPos.y;
        primaryGBuf.gbufData[gBase+14] = localPos.z;
        primaryGBuf.gbufData[gBase+15] = uintBitsToFloat(uint(instanceId));

        // Extended G-buffer fields (PrimaryGBuffer struct offsets 16-19)
        // customIndex, metallic, specularLevel, ior
        // We need separate storage but primaryGBuf is only 16 floats.
        // Store metallic in the hitDist field's unused w component — actually
        // use the radiance buffer's pad slot for metallic.
        // Alternatively, reuse the existing layout by packing.
        // For now, store metallic alongside pixel radiance padding.
        pixelRadiance.radDataU[rBase+7] = floatBitsToUint(metallic);

        // Store hitDist in pixel radiance (bounce 0 only, no contention)
        pixelRadiance.radDataU[rBase+3] = floatBitsToUint(hitT);

        // Store penumbra + NdotL in G-buffer for NRD SIGMA shadow denoising
        // Uses last 2 floats of PrimaryGBuffer (customIndex, metallic, penumbra, primaryNdotL)
        // These get updated again AFTER sun NEE runs, so we init here
    }

    // ---- Glass/thin transmission detection ----
    float glassProb_pre = (1.0 - metallic) * transmission;
    bool thinTransmissionMaterial = (mat.flags & MAT_FLAG_THIN_TRANSMISSION) != 0u;
    uint materialVmHeaderFlags = (mat.nodeVmHeader >> 8u) & 0xFFu;
    bool mappedTransmissionMaterial = (materialVmHeaderFlags & VM_HEADER_FLAG_TRANSMISSION) != 0u;
    bool partialTransmissionHit = (glassProb_pre < 0.98) || (alpha < 0.999);
    bool useThinTransmissionPath = thinTransmissionMaterial || (mappedTransmissionMaterial && partialTransmissionHit);

    // ---- Early glass fast path (pure glass — skip NEE/ambient, refract immediately) ----
    // Matching monolithic earlyGlassExit: glass doesn't scatter via diffuse NEE.
    float transparentProb_check = mat.multB;
    bool earlyGlassExit =
        glassProb_pre > 0.99 &&
        !useThinTransmissionPath &&
        transparentProb_check <= 0.0 &&
        alpha >= 0.999 &&
        metallic <= 0.001;
    if (earlyGlassExit) {
        uint glassBounces = glassBouncesPrev + 1u;
        if (glassBounces >= 16u) {
            psTerminate(idx, flags);
            return;
        }

        vec3 Veg = -rayDir;
        // Entry/exit from smoothN (matching monolithic — smooth shading for curved glass)
        bool enteringGlass = dot(smoothN, -rayDir) >= 0.0;
        bool hasBumpMap = (mat.normalTexIndex != 0xFFFFFFFFu);
        bool isBumpNotNormalMap = hasBumpMap && (mat.detailNormalBlend < 0.0);
        vec3 refractN = enteringGlass
            ? (isBumpNotNormalMap ? N : smoothN)
            : (isBumpNotNormalMap ? -N : -smoothN);
        float eta = enteringGlass ? (1.0 / max(ior, 1.01)) : ior;
        float alphaGlass = roughness * roughness;

        if (hasBumpMap && alphaGlass < 0.001) {
            float bumpCos = dot(N, smoothN);
            if (bumpCos < 0.9999) {
                alphaGlass = max(alphaGlass, max(1.0 - bumpCos * bumpCos, 0.0));
            }
        }

        vec3 Hglass;
        if (alphaGlass >= 0.0005) {
            alphaGlass = max(alphaGlass, 0.001);
            Hglass = sampleGGX_VNDF(rand2(), Veg, refractN, alphaGlass);
        } else {
            Hglass = refractN;
        }

        float cosI = abs(dot(Veg, Hglass));
        float F = fresnelDielectric(cosI, eta);
        vec3 refracted = refract(-Veg, Hglass, eta);
        bool canRefract = dot(refracted, refracted) > 0.0001;

        vec3 tint = cyclesPrincipledTransmissionTint(baseColor);
        vec3 R = vec3(F);
        vec3 T = canRefract ? (1.0 - F) * tint : vec3(0.0);
        float avgR = dot(R, vec3(1.0/3.0));
        float avgT = dot(T, vec3(1.0/3.0));
        float pReflect = (!canRefract) ? 1.0 : avgR / max(avgR + avgT, 1e-6);

        float pTransmit = 1.0 - pReflect;
        vec3 newDir, newOrigin;
        bool pathReflects = (!canRefract || rand01() < pReflect);
        if (pathReflects) {
            newDir = reflect(rayDir, Hglass);
            newOrigin = worldPos + refractN * 0.001;
            throughput *= R / max(glassProb_pre * pReflect, 1e-4);
        } else {
            newDir = refracted;
            newOrigin = worldPos - refractN * 0.001;
            throughput *= T / max(glassProb_pre * pTransmit, 1e-4);
        }

        // Glass plane decomposition: determine dominant vs secondary
        uint secondaryBit = flags & FLAG_SECONDARY_PLANE;
        if (glassBouncesPrev == 0u && secondaryBit == 0u) {
            uvec4 spH = spHeader.data[pixelIndex];
            uint dominantPlaneIdx = spH.w & 3u;
            uint pathPlaneIdx = pathReflects ? 0u : 1u;
            if (pathPlaneIdx != dominantPlaneIdx) secondaryBit = FLAG_SECONDARY_PLANE;
        }

        uint nextIdx = atomicAdd(counters.nextActiveRayCount, 1u);
        uint nBase = nextIdx * 12u;
        uint glassFlags = bounce | ((glassBounces & 0xFu) << 8u) | matCatBits | secondaryBit;
        psWriteAll(nextIdx, newOrigin, pixelIndex, newDir, rngState, throughput, glassFlags);
        psTerminate(idx, flags);
        return;
    }

    // ---- NEE: Direct sun light ----
    vec3 sunDir = normalize(cam.sunLight.xyz);
    float sunIntensity = cam.sunLight.w;
    vec3 sunColor = cam.skyLight.rgb;

    // Cycles-matching uniform cone sampling for sun disk (soft shadows)
    // sun_size from Blender is angular DIAMETER; Cycles uses half_angle internally
    vec3 shadowSunDir = sunDir;
    {
        float sunDiameter = intBitsToFloat(cam.jitterPattern[2].x);
        if (sunDiameter <= 0.0) sunDiameter = 0.009512;  // Nishita default
        float halfAngle = sunDiameter * 0.5;

        if (halfAngle > 1e-5) {
            // Cycles: 1 - cos(x) = 2*sin²(x/2) for numerical stability at small angles
            float sinHalf = sin(halfAngle * 0.5);
            float oneMinusCosAngle = 2.0 * sinHalf * sinHalf;

            // Concentric disk sampling (Shirley mapping) with blue noise + temporal
            uint pixX = pixelIndex % pc.width;
            uint pixY = pixelIndex / pc.width;
            ivec2 bnCoord = ivec2((pixX + pc.frameIndex * 7u) & 63, (pixY + pc.frameIndex * 11u) & 63);
            vec2 diskRand = vec2(
                texelFetch(blueNoiseTexture, bnCoord, 0).r,
                texelFetch(blueNoiseTexture, ivec2(bnCoord.y, bnCoord.x), 0).r
            );
            // Shirley concentric mapping [0,1]² → unit disk
            float a = 2.0 * diskRand.x - 1.0;
            float b = 2.0 * diskRand.y - 1.0;
            float r, phi;
            if (abs(a) > abs(b)) {
                r = a;
                phi = (PI / 4.0) * (b / max(abs(a), 1e-8));
            } else if (abs(b) > 1e-8) {
                r = b;
                phi = (PI / 2.0) - (PI / 4.0) * (a / max(abs(b), 1e-8));
            } else {
                r = 0.0; phi = 0.0;
            }
            vec2 xy = vec2(r * cos(phi), r * sin(phi));
            float r2 = dot(xy, xy);

            // Cycles: cos_theta = 1 - r² * (1 - cos(halfAngle))
            // uniform w.r.t. solid angle on the cone
            float cosTheta = 1.0 - r2 * oneMinusCosAngle;
            // Scale xy to sphere: sin_theta via stable formula
            xy *= sqrt(oneMinusCosAngle * (2.0 - oneMinusCosAngle * r2));

            // Build frame and compute cone direction
            vec3 sunT = abs(sunDir.y) < 0.999
                ? normalize(cross(sunDir, vec3(0, 1, 0)))
                : normalize(cross(sunDir, vec3(1, 0, 0)));
            vec3 sunB = cross(sunDir, sunT);
            shadowSunDir = normalize(xy.x * sunT + xy.y * sunB + cosTheta * sunDir);
        }
    }

    // Throughput early-out for deep bounces
    float maxT = max(throughput.r, max(throughput.g, throughput.b));
    // Hair fast paths (matching monolithic hairFastPrimary/Secondary):
    // - Hair bounce 1+: skip all local NEE (hair inter-strand scattering doesn't need it)
    // - Hair bounce 0: still gets sun + stochastic lights (but fewer, via neeScale)
    bool hairFastSecondary = isHairSurface && (bounce > 0u);
    bool skipSunNEE = (bounce >= 2u && maxT < 0.01) || hairFastSecondary;
    bool skipLocalNEE = (bounce >= pc.maxBounces && maxT < 0.01) || hairFastSecondary;

    // Glass/transmission surfaces don't scatter light — skip NEE entirely
    if (isGlass) skipSunNEE = true;
    if (isGlass) skipLocalNEE = true;

    if (!skipSunNEE && sunIntensity > 0.0 && sunDir.y > -0.01) {
        float NdotL = dot(N, sunDir);
        if (NdotL > 0.0) {
            vec3 V = -rayDir;
            vec3 sunRadiance = sunColor * sunIntensity;
            vec3 diffContrib, specContrib;
            if (isHairSurface) {
                diffContrib = hair_eval(V, sunDir, hairSmoothT,
                    baseColor, max(roughness, 0.05), max(hairRadialRoughness, 0.05),
                    hairShift, max(ior, 1.01), hairV);
                specContrib = vec3(0.0);
            } else {
                evaluateCookTorrance(N, V, sunDir, baseColor, roughness, metallic, specularLevel, ior, transmission,
                                     diffContrib, specContrib, coatWeight, coatRoughness, coatIOR, sheenWeight, sheenTint, sheenRoughness, anisotropicFactor, anisoT, anisoB, specularTint, diffuseRoughness);
            }

            if (bounce == 0u) {
                // Bounce 0: multi-sample inline sun shadow for soft penumbra
                // Trace N shadow rays with different cone-sampled directions, average visibility.
                // This resolves penumbra per-pixel per-frame (no temporal accumulation needed).
                const int SUN_SHADOW_SAMPLES = 4;
                float sunVisibility = 0.0;
                vec3 sunVisibility_filter = vec3(1.0);  // volume transmittance accumulator
                float closestShadowDist = 65504.0;

                vec3 sunT = abs(sunDir.y) < 0.999
                    ? normalize(cross(sunDir, vec3(0, 1, 0)))
                    : normalize(cross(sunDir, vec3(1, 0, 0)));
                vec3 sunB = cross(sunDir, sunT);

                float sunDiameter = intBitsToFloat(cam.jitterPattern[2].x);
                if (sunDiameter <= 0.0) sunDiameter = 0.009512;
                float halfAngle = sunDiameter * 0.5;
                float sinHalfA = sin(halfAngle * 0.5);
                float oneMinusCosA = 2.0 * sinHalfA * sinHalfA;

                for (int si = 0; si < SUN_SHADOW_SAMPLES; si++) {
                    // Different random per sample using stratified RNG
                    vec2 sampleXi = rand2();

                    // Cycles uniform cone sampling
                    vec3 sampleDir;
                    if (oneMinusCosA > 1e-8) {
                        float a = 2.0 * sampleXi.x - 1.0;
                        float b = 2.0 * sampleXi.y - 1.0;
                        float r, phi;
                        if (abs(a) > abs(b)) { r = a; phi = (PI/4.0) * (b / max(abs(a), 1e-8)); }
                        else if (abs(b) > 1e-8) { r = b; phi = (PI/2.0) - (PI/4.0) * (a / max(abs(b), 1e-8)); }
                        else { r = 0.0; phi = 0.0; }
                        vec2 xy = vec2(r * cos(phi), r * sin(phi));
                        float r2 = dot(xy, xy);
                        float cosT = 1.0 - r2 * oneMinusCosA;
                        xy *= sqrt(oneMinusCosA * (2.0 - oneMinusCosA * r2));
                        sampleDir = normalize(xy.x * sunT + xy.y * sunB + cosT * sunDir);
                    } else {
                        sampleDir = sunDir;
                    }

                    // Trace shadow ray (simple: opaque + terminate on first hit)
                    vec3 sOrigin = worldPos + N * shadowBias;
                    bool sOccluded = false;
                    for (int skip = 0; skip < 8; skip++) {
                        rayQueryEXT srq;
                        rayQueryInitializeEXT(srq, topLevelAS,
                            gl_RayFlagsOpaqueEXT,  // NO TerminateOnFirstHit: need closest hit for glass skip
                            0xFF, sOrigin, 0.0, sampleDir, 10000.0);
                        while (rayQueryProceedEXT(srq)) {}
                        if (rayQueryGetIntersectionTypeEXT(srq, true) == gl_RayQueryCommittedIntersectionNoneEXT) {
                            break;  // lit
                        }
                        float sT = rayQueryGetIntersectionTEXT(srq, true);
                        uint sCIdx = rayQueryGetIntersectionInstanceCustomIndexEXT(srq, true);
                        int sPId = rayQueryGetIntersectionPrimitiveIndexEXT(srq, true);
                        GeometryMetadata sG = geometryMetadata.geometries[sCIdx];
                        uint sMI = 0u;
                        if (sG.primMaterialBufferAddress != 0u) {
                            PrimMaterials sPM = PrimMaterials(sG.primMaterialBufferAddress);
                            sMI = sPM.m[sPId];
                        }
                        Material sM = materialBuffer.materials[sMI];
                        // Glass/volume: pass through with volume attenuation
                        if ((sM.flags & 6u) != 0u) {
                            if ((sM.flags & 4u) != 0u && rayQueryGetIntersectionFrontFaceEXT(srq, true)) {
                                int sInstId = rayQueryGetIntersectionInstanceIdEXT(srq, true);
                                vec3 vCol = vec3(sM.ksAmbient, sM.ksDiffuse, sM.ksSpecular);
                                vec3 vAbs = vec3(uintBitsToFloat(sM.nodeVmCode[2].x),
                                                 uintBitsToFloat(sM.nodeVmCode[2].y),
                                                 uintBitsToFloat(sM.nodeVmCode[2].z));
                                sunVisibility_filter *= evaluateVolumeShadowTransmittance(
                                    topLevelAS, vCol, vAbs, sM.sunSpecular,
                                    sOrigin, sampleDir, sT, sInstId);
                            }
                            sOrigin += sampleDir * (sT + 0.003);
                            continue;
                        }
                        // Lightpath transparent / stochastic passthrough: always pass through
                        if ((sM.flags & MAT_FLAG_LIGHTPATH_TRANSPARENT) != 0u || sM.multB > 0.0) {
                            sOrigin += sampleDir * (sT + 0.003);
                            continue;
                        }
                        // Alpha-tested: only pass through if actually transparent
                        if ((sM.flags & 1u) != 0u && sM.multG < 0.999) {
                            // Quick alpha check — sample texture if available
                            bool alphaTransparent = false;
                            if (sG.uvBufferAddress != 0u) {
                                Indices sIdx = Indices(sG.indexBufferAddress);
                                UVs sUV = UVs(sG.uvBufferAddress);
                                uint si0 = sIdx.i[sPId*3+0], si1 = sIdx.i[sPId*3+1], si2 = sIdx.i[sPId*3+2];
                                vec2 sBary2 = rayQueryGetIntersectionBarycentricsEXT(srq, true);
                                vec3 sBary = vec3(1.0-sBary2.x-sBary2.y, sBary2.x, sBary2.y);
                                vec2 sHitUV = vec2(sUV.uv[si0*2], 1.0-sUV.uv[si0*2+1]) * sBary.x
                                            + vec2(sUV.uv[si1*2], 1.0-sUV.uv[si1*2+1]) * sBary.y
                                            + vec2(sUV.uv[si2*2], 1.0-sUV.uv[si2*2+1]) * sBary.z;
                                float sAlpha = 1.0;
                                if (sM.diffuseTexIndex != 0xFFFFFFFFu)
                                    sAlpha = texture(textures[nonuniformEXT(sM.diffuseTexIndex)], sHitUV).a * sM.multG;
                                else if (sM.detailTexIndex != 0xFFFFFFFFu)
                                    sAlpha = texture(textures[nonuniformEXT(sM.detailTexIndex)], sHitUV).a * sM.multG;
                                alphaTransparent = (sAlpha < 0.999 && rand01() > sAlpha);
                            }
                            if (alphaTransparent) {
                                sOrigin += sampleDir * (sT + 0.003);
                                continue;
                            }
                        }
                        // Opaque hit
                        sOccluded = true;
                        closestShadowDist = min(closestShadowDist, sT);
                        break;
                    }
                    if (!sOccluded) sunVisibility += 1.0;
                }

                float shadowFactor = sunVisibility / float(SUN_SHADOW_SAMPLES);

                // Accumulate sun contribution with soft shadow + volume transmittance
                vec3 sunDiffResult = diffContrib * sunRadiance * throughput * shadowFactor * sunVisibility_filter;
                vec3 sunSpecResult = specContrib * sunRadiance * throughput * shadowFactor * sunVisibility_filter;
                atomicAddFloat(rBase+0, sunDiffResult.x);
                atomicAddFloat(rBase+1, sunDiffResult.y);
                atomicAddFloat(rBase+2, sunDiffResult.z);
                atomicAddFloat(rBase+4, sunSpecResult.x);
                atomicAddFloat(rBase+5, sunSpecResult.y);
                atomicAddFloat(rBase+6, sunSpecResult.z);

                // Penumbra for denoiser
                float sigmaTanAngle = 0.04;
                primaryPenumbra = (shadowFactor < 0.999)
                    ? min(closestShadowDist * sigmaTanAngle * 0.5, 32768.0) : 65504.0;
                primaryNdotL = NdotL;
                if (pc.sampleIdx == 0u) {
                    ivec2 penPix = ivec2(pixelIndex % pc.width, pixelIndex / pc.width);
                    imageStore(penumbraImg, penPix, vec4(primaryPenumbra));
                }
            } else {
                // Bounce 1+: deferred shadow ray via K3 (no penumbra needed)
                vec3 contrib = (diffContrib + specContrib) * sunRadiance * throughput;
                if (bounce > 0u) contrib *= cam.ptParams0.y;
                appendShadowRay(worldPos + N * shadowBias, shadowSunDir, 10000.0, idx, contrib,
                                isDiffusePath ? 0u : 1u);
            }
        }
    }

    // ---- SSS: Subsurface translucency for sun light ----
    if (sssWeight > 0.001 && !isGlass && sunIntensity > 0.0 && !skipSunNEE) {
        vec3 V = -rayDir;
        vec3 sunRadSSS = cam.skyLight.rgb * sunIntensity;
        vec3 sssContrib = evaluateSSS(N, V, sunDir, baseColor, sssWeight, sssRadius, 1.0);
        sssContrib *= sunRadSSS * throughput;
        if (bounce > 0u) sssContrib *= cam.ptParams0.y;
        // SSS translucency: trace shadow ray from BACK side (light passing through)
        appendShadowRay(worldPos - N * shadowBias, sunDir, 10000.0, idx, sssContrib,
                        0u); // diffuse channel
    }

    // ---- ReSTIR DI: Reservoir-based light sampling (bounce 0 only) ----
    bool restirDone = false;
    bool restirEnabled = (cam.lightPad2 & 2u) != 0u;
    if (restirEnabled && !skipLocalNEE && bounce == 0u && cam.lightCount > 0u && !isHairSurface) {
        DIReservoir reservoir = emptyDIReservoir();
        vec3 V = -rayDir;
        uint localRng = rngState;

        // Phase 1: Candidate generation — sample M=min(lightCount, 8) random lights
        uint M = min(cam.lightCount, 8u);
        float sourcePDF = 1.0 / float(cam.lightCount);
        for (uint m = 0u; m < M; m++) {
            localRng ^= localRng << 13u; localRng ^= localRng >> 17u; localRng ^= localRng << 5u;
            uint li = min(uint(float(localRng) / 4294967295.0 * float(cam.lightCount)), cam.lightCount - 1u);

            vec4 lPR = cam.lights[li*4u]; vec4 lCI = cam.lights[li*4u+1u];
            vec4 lDS = cam.lights[li*4u+2u]; vec4 lTS = cam.lights[li*4u+3u];
            vec3 toL = lPR.xyz - worldPos;
            float dist = length(toL);
            if (dist < 0.001) continue;
            vec3 L = toL / dist;
            float NdotL_r = dot(N, L);
            if (NdotL_r <= 0.0) continue;

            float spotA = 1.0;
            bool isSpec = (lPR.w < 0.0);
            bool isSp = isSpec && lTS.w < 0.0;
            bool isAr = isSpec && !isSp;
            if (isSp) {
                float cH = lDS.w, sm = abs(lTS.w), cA = dot(-L, lDS.xyz);
                float st = clamp((cA - cH) * sm, 0.0, 1.0);
                spotA = st*st*(3.0-2.0*st);
                if (spotA <= 0.0) continue;
            }
            float att = 1.0 / (dist*dist + 0.001);
            if (isAr) {
                float fd = max(dot(-L, lDS.xyz), 0.0);
                if (fd <= 0.0) continue;
                att *= fd * lDS.w * lTS.w;
            }
            vec3 lRad = lCI.rgb * lCI.w * att * spotA;
            float pHat = diTargetPDF(N, V, L, NdotL_r, baseColor, roughness, metallic, lRad);
            diReservoirUpdate(reservoir, li, lPR.xyz, pHat, sourcePDF, localRng);
        }

        // Phase 2: Temporal reuse
        uint pixLin = pixelIndex;
        uint prevBase = pixLin * 3u;
        vec4 prevD2 = diReservoirPrev.data[prevBase + 2u];
        bool prevFresh = diReservoirIsFresh(prevD2, pc.frameIndex);
        if (prevFresh) {
            DIReservoir prev = diUnpack(diReservoirPrev.data[prevBase], diReservoirPrev.data[prevBase+1u]);
            if (prev.M > 0.0 && prev.lightIndex < cam.lightCount && prev.age < 20.0) {
                uint pLi = prev.lightIndex;
                vec4 pPR = cam.lights[pLi*4u]; vec4 pCI = cam.lights[pLi*4u+1u];
                vec4 pDS = cam.lights[pLi*4u+2u]; vec4 pTS = cam.lights[pLi*4u+3u];
                vec3 pTL = pPR.xyz - worldPos; float pD = length(pTL);
                vec3 pL = pTL / max(pD, 0.001); float pNdL = dot(N, pL);
                float pA = 1.0/(pD*pD+0.001); float pSA = 1.0;
                bool pSpec = (pPR.w < 0.0); bool pSp = pSpec && pTS.w < 0.0; bool pAr = pSpec && !pSp;
                if (pSp) { float c=pDS.w,s=abs(pTS.w),a=dot(-pL,pDS.xyz); float t=clamp((a-c)*s,0.0,1.0); pSA=t*t*(3.0-2.0*t); }
                if (pAr) { pA *= max(dot(-pL, pDS.xyz), 0.0) * pDS.w * pTS.w; }
                vec3 pRad = pCI.rgb * pCI.w * pA * pSA;
                float prevTP = diTargetPDF(N, V, pL, max(pNdL,0.0), baseColor, roughness, metallic, pRad);
                DIReservoir cp = prev;
                float mc = min(cp.M, 20.0);
                if (mc < cp.M) cp.weightSum *= mc / cp.M;
                cp.M = mc;
                diReservoirMerge(reservoir, cp, prevTP, localRng);
            }
        }

        // Phase 3: Spatial reuse (RTXPT parameters: 1 neighbor, 32px radius)
        // Normal threshold 0.5 (cosine) + depth threshold 0.1 (10% relative)
        // to prevent light leaking across geometry edges
        uint pixX = pixelIndex % pc.width;
        uint pixY = pixelIndex / pc.width;
        float myViewZ = dot(vec3(cam.view[0][2], cam.view[1][2], cam.view[2][2]), worldPos)
                      + cam.view[3][2];  // linear view-space depth

        // RTXPT: 1 spatial sample normally, 8 for disoccluded pixels (no temporal history)
        int spatialCount = (prevFresh && prevBase < pc.width * pc.height * 3u) ? 1 : 4;
        for (int sn = 0; sn < spatialCount; sn++) {
            localRng ^= localRng << 13u; localRng ^= localRng >> 17u; localRng ^= localRng << 5u;
            float ang = float(localRng) / 4294967295.0 * 6.28318;
            localRng ^= localRng << 13u; localRng ^= localRng >> 17u; localRng ^= localRng << 5u;
            float rad = sqrt(float(localRng) / 4294967295.0) * 32.0;  // RTXPT: 32px radius
            ivec2 nb = ivec2(int(pixX) + int(cos(ang)*rad), int(pixY) + int(sin(ang)*rad));
            nb = clamp(nb, ivec2(0), ivec2(pc.width-1u, pc.height-1u));
            uint nIdx = uint(nb.y) * pc.width + uint(nb.x);
            uint nBase = nIdx * 3u;
            if (!diReservoirIsFresh(diReservoirPrev.data[nBase+2u], pc.frameIndex)) continue;
            DIReservoir nr = diUnpack(diReservoirPrev.data[nBase], diReservoirPrev.data[nBase+1u]);
            if (nr.M <= 0.0 || nr.lightIndex >= cam.lightCount) continue;

            // Normal similarity check (RTXPT: threshold 0.5 cosine = ~60°)
            // Read neighbor's primary normal from G-buffer (stored in primaryGBuf)
            uint ngBase = nIdx * 16u;
            vec3 neighborN = vec3(primaryGBuf.gbufData[ngBase+0],
                                  primaryGBuf.gbufData[ngBase+1],
                                  primaryGBuf.gbufData[ngBase+2]);
            if (dot(N, neighborN) < 0.5) continue;

            // Depth similarity check (RTXPT: threshold 0.1 = 10% relative)
            float neighborViewZ = primaryGBuf.gbufData[ngBase+7];
            if (abs(myViewZ) > 0.01 && abs(neighborViewZ - myViewZ) / abs(myViewZ) > 0.1) continue;

            uint nLi = nr.lightIndex;
            vec4 nPR = cam.lights[nLi*4u]; vec4 nCI = cam.lights[nLi*4u+1u];
            vec4 nDS = cam.lights[nLi*4u+2u]; vec4 nTS = cam.lights[nLi*4u+3u];
            vec3 nTL = nPR.xyz - worldPos; float nD = length(nTL);
            vec3 nL = nTL / max(nD, 0.001); float nNdL = dot(N, nL);
            float nA = 1.0/(nD*nD+0.001); float nSA = 1.0;
            bool nSpc = (nPR.w < 0.0); bool nSp = nSpc && nTS.w < 0.0; bool nAr = nSpc && !nSp;
            if (nSp) { float c=nDS.w,s=abs(nTS.w),a=dot(-nL,nDS.xyz); float t=clamp((a-c)*s,0.0,1.0); nSA=t*t*(3.0-2.0*t); }
            if (nAr) { nA *= max(dot(-nL, nDS.xyz), 0.0) * nDS.w * nTS.w; }
            vec3 nRad = nCI.rgb * nCI.w * nA * nSA;
            float nTP = diTargetPDF(N, V, nL, max(nNdL,0.0), baseColor, roughness, metallic, nRad);
            DIReservoir cn = nr;
            float nmc = min(cn.M, 10.0);
            if (nmc < cn.M) cn.weightSum *= nmc / cn.M;
            cn.M = nmc;
            diReservoirMerge(reservoir, cn, nTP, localRng);
        }

        // Phase 4: Final shading — trace ONE shadow ray to selected light
        if (reservoir.lightIndex < cam.lightCount && reservoir.targetPDF > 0.0) {
            uint fLi = reservoir.lightIndex;
            vec4 fPR = cam.lights[fLi*4u]; vec4 fCI = cam.lights[fLi*4u+1u];
            vec4 fDS = cam.lights[fLi*4u+2u]; vec4 fTS = cam.lights[fLi*4u+3u];
            vec3 fTL = fPR.xyz - worldPos; float fD = length(fTL);
            vec3 fL = fTL / max(fD, 0.001);

            // Inline shadow trace with transparency skip
            vec3 fSO = worldPos + N * shadowBias;
            bool fOcc = false;
            vec3 fSF = vec3(1.0);
            for (int fs = 0; fs < 8; fs++) {
                rayQueryEXT fsrq;
                rayQueryInitializeEXT(fsrq, topLevelAS, gl_RayFlagsOpaqueEXT,
                    0xFF, fSO, 0.0, fL, fD - 0.004);
                while (rayQueryProceedEXT(fsrq)) {}
                if (rayQueryGetIntersectionTypeEXT(fsrq, true) == gl_RayQueryCommittedIntersectionNoneEXT) break;
                float fHT = rayQueryGetIntersectionTEXT(fsrq, true);
                uint fCI2 = rayQueryGetIntersectionInstanceCustomIndexEXT(fsrq, true);
                int fPI = rayQueryGetIntersectionPrimitiveIndexEXT(fsrq, true);
                GeometryMetadata fGeo = geometryMetadata.geometries[fCI2];
                uint fMI = 0u;
                if (fGeo.primMaterialBufferAddress != 0u) { PrimMaterials fPM = PrimMaterials(fGeo.primMaterialBufferAddress); fMI = fPM.m[fPI]; }
                Material fMat = materialBuffer.materials[fMI];
                if ((fMat.flags & 6u) != 0u) {
                    if ((fMat.flags & 4u) != 0u && rayQueryGetIntersectionFrontFaceEXT(fsrq, true)) {
                        int fVolInst = rayQueryGetIntersectionInstanceIdEXT(fsrq, true);
                        vec3 fvCol = vec3(fMat.ksAmbient, fMat.ksDiffuse, fMat.ksSpecular);
                        vec3 fvAbs = vec3(uintBitsToFloat(fMat.nodeVmCode[2].x),
                                         uintBitsToFloat(fMat.nodeVmCode[2].y),
                                         uintBitsToFloat(fMat.nodeVmCode[2].z));
                        fSF *= evaluateVolumeShadowTransmittance(
                            topLevelAS, fvCol, fvAbs, fMat.sunSpecular, fSO, fL, fHT, fVolInst);
                    }
                    fSO += fL*(fHT+0.004); continue;
                }
                if ((fMat.flags & MAT_FLAG_LIGHTPATH_TRANSPARENT) != 0u || fMat.multB > 0.0) { fSO += fL*(fHT+0.002); continue; }
                // Alpha-tested: check actual alpha before skipping
                if ((fMat.flags & 1u) != 0u && fMat.multG < 0.999) {
                    vec2 fBary2 = rayQueryGetIntersectionBarycentricsEXT(fsrq, true);
                    bool fAlphaSkip = false;
                    if (fGeo.uvBufferAddress != 0u) {
                        Indices fIdx2 = Indices(fGeo.indexBufferAddress);
                        UVs fUV2 = UVs(fGeo.uvBufferAddress);
                        uint fi0=fIdx2.i[fPI*3],fi1=fIdx2.i[fPI*3+1],fi2=fIdx2.i[fPI*3+2];
                        vec3 fB=vec3(1.0-fBary2.x-fBary2.y,fBary2.x,fBary2.y);
                        vec2 fHUV=vec2(fUV2.uv[fi0*2],1.0-fUV2.uv[fi0*2+1])*fB.x
                                 +vec2(fUV2.uv[fi1*2],1.0-fUV2.uv[fi1*2+1])*fB.y
                                 +vec2(fUV2.uv[fi2*2],1.0-fUV2.uv[fi2*2+1])*fB.z;
                        float fA=1.0;
                        if(fMat.diffuseTexIndex!=0xFFFFFFFFu) fA=texture(textures[nonuniformEXT(fMat.diffuseTexIndex)],fHUV).a*fMat.multG;
                        else if(fMat.detailTexIndex!=0xFFFFFFFFu) fA=texture(textures[nonuniformEXT(fMat.detailTexIndex)],fHUV).a*fMat.multG;
                        fAlphaSkip=(fA<0.999 && rand01()>fA);
                    }
                    if (fAlphaSkip) { fSO += fL*(fHT+0.002); continue; }
                }
                fOcc = true; break;
            }

            if (!fOcc) {
                float W = diReservoirWeight(reservoir);
                float fAtt = 1.0 / (fD*fD + 0.001); float fSA = 1.0;
                bool fSpec = (fPR.w < 0.0); bool fSp = fSpec && fTS.w < 0.0; bool fAr = fSpec && !fSp;
                if (fSp) { float c=fDS.w,s=abs(fTS.w),a=dot(-fL,fDS.xyz); float t=clamp((a-c)*s,0.0,1.0); fSA=t*t*(3.0-2.0*t); }
                if (fAr) { fAtt *= max(dot(-fL, fDS.xyz), 0.0) * fDS.w * fTS.w; }
                vec3 fRad = fCI.rgb * fCI.w * fAtt * fSA;

                vec3 fDC, fSC;
                evaluateCookTorrance(N, V, fL, baseColor, roughness, metallic, specularLevel, ior, transmission, fDC, fSC, coatWeight, coatRoughness, coatIOR, sheenWeight, sheenTint, sheenRoughness, anisotropicFactor, anisoT, anisoB, specularTint, diffuseRoughness);
                vec3 fDiffR = fDC * fRad * W * throughput * fSF;
                vec3 fSpecR = fSC * fRad * W * throughput * fSF;
                // RTXPT: DenoiserRadianceClampK = 8.0
                fDiffR = min(fDiffR, vec3(MAX_RADIANCE));
                fSpecR = min(fSpecR, vec3(MAX_RADIANCE));
                atomicAddFloat(rBase+0, fDiffR.x); atomicAddFloat(rBase+1, fDiffR.y); atomicAddFloat(rBase+2, fDiffR.z);
                atomicAddFloat(rBase+4, fSpecR.x); atomicAddFloat(rBase+5, fSpecR.y); atomicAddFloat(rBase+6, fSpecR.z);
            }
        }

        // Store reservoir for next frame
        reservoir.age += 1.0;
        uint currBase = pixLin * 3u;
        diReservoirCurr.data[currBase + 0u] = diPackV0(reservoir);
        diReservoirCurr.data[currBase + 1u] = diPackV1(reservoir);
        diReservoirCurr.data[currBase + 2u] = vec4(uintBitsToFloat(pc.frameIndex), 0, 0, 0);
        rngState = localRng;
        restirDone = true;
    }

    // ---- NEE: Point/spot/area lights (fallback when ReSTIR skipped) ----
    // Independent random light selection (not contiguous block) so every light
    // has equal probability of being sampled — fixes missing shadows from specific lights
    uint neeLightIndices[4];
    uint neeLightCount = min(cam.lightCount, 32u);
    float neeScale = 1.0;
    bool neeUseRandomSet = false;
    bool hairFastPrimary = isHairSurface && (bounce == 0u);
    if (!skipLocalNEE && !restirDone) {
        if ((bounce >= 2u || hairFastPrimary) && cam.lightCount > 1u) {
            // Bounce 2+ or hair primary: 1 random light
            neeLightIndices[0] = min(uint(rand01() * float(cam.lightCount)), cam.lightCount - 1u);
            neeLightCount = 1u;
            neeScale = float(cam.lightCount);
            neeUseRandomSet = true;
        } else if (cam.lightCount > 4u) {
            // 4 INDEPENDENT random lights (not contiguous block)
            for (uint ri = 0u; ri < 4u; ri++) {
                neeLightIndices[ri] = min(uint(rand01() * float(cam.lightCount)), cam.lightCount - 1u);
            }
            neeLightCount = 4u;
            neeScale = float(cam.lightCount) / 4.0;
            neeUseRandomSet = true;
        }
    }
    if (!skipLocalNEE) {
        for (uint lii = 0u; lii < neeLightCount; lii++) {
            uint li = neeUseRandomSet ? neeLightIndices[lii] : lii;
            vec4 lightPosRange = cam.lights[li * 4u];
            vec4 lightColInt   = cam.lights[li * 4u + 1u];
            vec4 lightDirSizeX = cam.lights[li * 4u + 2u];
            vec4 lightTanSizeY = cam.lights[li * 4u + 3u];

            vec3 lightPos   = lightPosRange.xyz;
            float rawRange  = lightPosRange.w;
            vec3 lightColor = lightColInt.rgb;
            float lightInt  = lightColInt.w;

            // Classify light type: negative range = area or spot light
            bool isSpecialLight = (rawRange < 0.0);
            float sizeY = lightTanSizeY.w;
            bool isSpotLight = isSpecialLight && sizeY < 0.0;
            bool isAreaLight = isSpecialLight && !isSpotLight;

            // Compute effective range
            float lightRange;
            if (isAreaLight) {
                float sizeX = lightDirSizeX.w;
                float sizeYa = lightTanSizeY.w;
                float diagonal = sqrt(sizeX * sizeX + sizeYa * sizeYa) * 0.5;
                float falloffRange = max(sqrt(lightInt * sizeX * sizeYa / 0.01), 1.0);
                lightRange = diagonal + falloffRange;
            } else if (isSpotLight) {
                lightRange = -rawRange;
            } else {
                lightRange = rawRange;
            }
            // No hard range cutoff — 1/r² attenuation handles falloff naturally (Cycles-matching)
            vec3 toLight = lightPos - worldPos;
            float dist = length(toLight);
            if (dist < 0.001) continue;
            vec3 L = toLight / dist;
            float NdotL_pt = dot(N, L);
            if (!isAreaLight && NdotL_pt <= 0.0) continue;

            // Spot light: cone attenuation (Cycles formula)
            if (isSpotLight) {
                vec3 spotDir = lightDirSizeX.xyz;
                float cosHalfAngle = lightDirSizeX.w;
                float spotSmooth = abs(lightTanSizeY.w);
                float cosAngle = dot(-L, spotDir);
                float t = clamp((cosAngle - cosHalfAngle) * spotSmooth, 0.0, 1.0);
                float spotAtten = t * t * (3.0 - 2.0 * t);
                if (spotAtten <= 0.0) continue;
                lightInt *= spotAtten;
            }

            // Area light sampling / point light soft shadow jitter
            vec3 shadowTarget;
            if (isAreaLight) {
                vec3 lightNormal = lightDirSizeX.xyz;
                vec3 lightTangent = lightTanSizeY.xyz;
                float sizeX = lightDirSizeX.w;
                float sizeYa = lightTanSizeY.w;
                vec3 lightBitangent = cross(lightNormal, lightTangent);
                vec2 areaRnd = rand2() * 2.0 - 1.0;
                shadowTarget = lightPos
                    + lightTangent * (areaRnd.x * sizeX * 0.5)
                    + lightBitangent * (areaRnd.y * sizeYa * 0.5);
            } else {
                // Point/spot: soft shadow from source radius (shadow_soft_size)
                // Point lights: size_x = shadow_soft_size from Blender
                // Spot lights: use angular extent as soft radius
                // Cycles-matching: use shadow_soft_size directly (0 = hard shadow, no fallback)
                float sourceRadius = isSpotLight ? 0.0 : lightDirSizeX.w;
                float softRadius = clamp(sourceRadius * 0.5, 0.0, 2.0);
                vec2 diskSample = rand2();
                float diskR = sqrt(diskSample.x) * softRadius;
                float diskAngle = diskSample.y * 2.0 * PI;
                vec3 lTangent = abs(L.y) < 0.999 ? normalize(cross(L, vec3(0,1,0))) : normalize(cross(L, vec3(1,0,0)));
                vec3 lBitangent = cross(L, lTangent);
                shadowTarget = lightPos + lTangent * (cos(diskAngle) * diskR) + lBitangent * (sin(diskAngle) * diskR);
            }

            vec3 toSample = shadowTarget - worldPos;
            float sampleDist = length(toSample);
            vec3 shadowDir = toSample / sampleDist;

            // Attenuation
            float effectiveDist = isAreaLight ? sampleDist : dist;
            float attenuation = 1.0 / (effectiveDist * effectiveDist + 0.001);

            // Area light geometric term
            if (isAreaLight) {
                vec3 lightNormal = lightDirSizeX.xyz;
                float cosAtLight = max(dot(-shadowDir, lightNormal), 0.0);
                if (cosAtLight <= 0.0) continue;
                attenuation *= cosAtLight * (lightDirSizeX.w * lightTanSizeY.w);
            }

            // BRDF evaluation (area lights use shadowDir, others use L)
            vec3 brdfL = isAreaLight ? shadowDir : L;
            float brdfNdotL = dot(N, brdfL);
            if (brdfNdotL <= 0.0 && !isAreaLight) continue;

            vec3 V = -rayDir;
            vec3 diffC, specC;
            if (isHairSurface) {
                diffC = hair_eval(V, brdfL, hairSmoothT,
                    baseColor, max(roughness, 0.05), max(hairRadialRoughness, 0.05),
                    hairShift, max(ior, 1.01), hairV);
                specC = vec3(0.0);
            } else {
                evaluateCookTorrance(N, V, brdfL, baseColor, roughness, metallic, specularLevel, ior, transmission, diffC, specC, coatWeight, coatRoughness, coatIOR, sheenWeight, sheenTint, sheenRoughness, anisotropicFactor, anisoT, anisoB, specularTint, diffuseRoughness);
            }

            vec3 lightRadiance = lightColor * lightInt * attenuation;
            vec3 contrib = (diffC + specC) * lightRadiance * throughput * neeScale;
            if (bounce > 0u) contrib *= cam.ptParams0.y;

            appendShadowRay(worldPos + N * shadowBias, shadowDir, sampleDist - 0.004, idx, contrib,
                            isDiffusePath ? 0u : 1u);

            // SSS translucency for local lights
            if (sssWeight > 0.001 && !isGlass) {
                vec3 sssC = evaluateSSS(N, V, L, baseColor, sssWeight, sssRadius, attenuation);
                vec3 sssContrib = sssC * lightColor * lightInt * throughput * neeScale;
                if (bounce > 0u) sssContrib *= cam.ptParams0.y;
                appendShadowRay(worldPos - N * shadowBias, shadowDir, sampleDist - 0.004, idx, sssContrib,
                                0u);
            }
        }
    }

    // ---- NEE: Emissive triangle lights with MIS (bounce 0-1 only) ----
    uint emissiveTriCount = cam.lightPad0;
    if (!skipLocalNEE && emissiveTriCount > 0u) {
        EmissiveSample eSample = sampleEmissiveTriangle(emissiveTriCount, rand01(), rand2());
        if (eSample.pdf > 0.0) {
            vec3 toEmissive = eSample.position - worldPos;
            float eDist = length(toEmissive);
            vec3 eDir = toEmissive / eDist;
            float eNdotL = dot(N, eDir);
            float eCosTheta = dot(-eDir, eSample.normal);

            if (eNdotL > 0.0 && eCosTheta > 0.0 && eDist > 0.01) {
                // BRDF evaluation
                vec3 V = -rayDir;
                vec3 eDiffC, eSpecC;
                if (isHairSurface) {
                    eDiffC = hair_eval(V, eDir, hairSmoothT,
                        baseColor, max(roughness, 0.05), max(hairRadialRoughness, 0.05),
                        hairShift, max(ior, 1.01), hairV);
                    eSpecC = vec3(0.0);
                } else {
                    evaluateCookTorrance(N, V, eDir, baseColor, roughness, metallic, specularLevel, ior, transmission,
                                         eDiffC, eSpecC, coatWeight, coatRoughness, coatIOR, sheenWeight, sheenTint, sheenRoughness, anisotropicFactor, anisoT, anisoB, specularTint, diffuseRoughness);
                }

                // Geometric term
                vec3 eRadiance = eSample.emission * eCosTheta / (eDist * eDist);

                // MIS weight: power heuristic (lightPdf² / (lightPdf² + bsdfPdf²))
                float bsdfPdf = eNdotL / PI;
                float lightPdf = eSample.pdf * eDist * eDist / eCosTheta;
                float misWeight = (lightPdf * lightPdf) / (lightPdf * lightPdf + bsdfPdf * bsdfPdf + 1e-8);

                vec3 eContrib = (eDiffC + eSpecC) * eRadiance * misWeight / eSample.pdf * throughput;
                if (bounce > 0u) eContrib *= cam.ptParams0.y;

                // Shadow ray to emissive surface
                appendShadowRay(worldPos + N * shadowBias, eDir, eDist - 0.01, idx, eContrib,
                                isDiffusePath ? 0u : 1u);
            }
        }
    }

    // ---- NEE: Environment/Sky light (direct sampling of background as light source) ----
    // Cosine-weighted hemisphere sample toward sky, with shadow ray for occlusion.
    // This gives every surface a direct sample of the environment, dramatically
    // improving indirect lighting quality compared to relying on BSDF miss rays alone.
    vec3 envLe = max(vec3(cam.windParams.z, cam.windParams.w, cam.rainParams.w), vec3(0.0));
    int hdriTexIdx = int(cam.windParams.x);
    float envLum = dot(envLe, vec3(0.2126, 0.7152, 0.0722));
    bool hasEnvLight = (envLum > 0.001) || (hdriTexIdx >= 0);

    if (!skipLocalNEE && !isGlass && hasEnvLight) {
        vec3 envDir = sampleCosineHemisphere(rand2(), N);
        float envNdotL = max(dot(N, envDir), 0.0);

        if (envNdotL > 0.0) {
            // Evaluate environment radiance in sampled direction
            vec3 envColor;
            if (hdriTexIdx >= 0) {
                float phi = atan(-envDir.z, envDir.x);
                float u = 0.5 - phi / (2.0 * PI);
                float v = acos(clamp(envDir.y, -1.0, 1.0)) / PI;
                envColor = texture(textures[nonuniformEXT(uint(hdriTexIdx))], vec2(u, v)).rgb * cam.windParams.y;
            } else {
                envColor = envLe;
            }

            // Evaluate BRDF
            vec3 V = -rayDir;
            vec3 eDiffC, eSpecC;
            if (isHairSurface) {
                eDiffC = hair_eval(V, envDir, hairSmoothT,
                    baseColor, max(roughness, 0.05), max(hairRadialRoughness, 0.05),
                    hairShift, max(ior, 1.01), hairV);
                eSpecC = vec3(0.0);
            } else {
                evaluateCookTorrance(N, V, envDir, baseColor, roughness, metallic,
                                     specularLevel, ior, transmission,
                                     eDiffC, eSpecC, coatWeight, coatRoughness, coatIOR, sheenWeight, sheenTint, sheenRoughness, anisotropicFactor, anisoT, anisoB, specularTint, diffuseRoughness);
            }

            // Cosine-weighted pdf = NdotL / PI
            // Only use diffuse contribution — specular env reflections come from BSDF bounce
            float envPdf = envNdotL * INV_PI;
            vec3 envContrib = eDiffC * envColor / max(envPdf, 1e-6) * throughput;
            if (bounce > 0u) envContrib *= cam.ptParams0.y;

            // Shadow ray toward sky (maxDist = 10000 = effectively infinity)
            appendShadowRay(worldPos + N * shadowBias, envDir, 10000.0, idx, envContrib,
                            isDiffusePath ? 0u : 1u);
        }
    }

    // ---- SHARC update: accumulate direct lighting + guide bins + backpropagation ----
    // NVIDIA official: directLighting must be PRE-THROUGHPUT (just the local illumination).
    // Throughput is applied separately via SharcSetThroughput for backpropagation weighting.
    if (sharcUpdatePixel && !isGlass) {
        SharcState state = loadSharcState(pixelIndex);

        // Direct lighting at this vertex (PRE-throughput, matching NVIDIA SDK)
        vec3 directLighting = emission;  // emission only — NEE contributions deferred to K3
        directLighting = max(directLighting, vec3(0.0));

        // Anti-firefly filter: clamp directLighting relative to resolved cache luminance
        // (NVIDIA SharcAddVoxelData includes this internally; we apply it before update)
        {
            uint64_t ffKey = sharcHashKey(worldPos, N, sharcGrid);
            uint ffSlot = sharcFind(ffKey, sharcCapacity);
            if (ffSlot != 0xFFFFFFFFu) {
                uint rOff = sharcCapacity * 4u + ffSlot * 4u;
                float resolvedLum = dot(vec3(
                    uintBitsToFloat(_sharcResolved.data[rOff + 0u]),
                    uintBitsToFloat(_sharcResolved.data[rOff + 1u]),
                    uintBitsToFloat(_sharcResolved.data[rOff + 2u])),
                    vec3(0.2126, 0.7152, 0.0722));
                float directLum = dot(directLighting, vec3(0.2126, 0.7152, 0.0722));
                // Clamp new sample to 10x resolved luminance (anti-firefly)
                if (resolvedLum > 0.001 && directLum > resolvedLum * 10.0) {
                    directLighting *= (resolvedLum * 10.0) / directLum;
                }
            }
        }

        // Guide bin accumulation: record light direction
        float directLum = dot(directLighting, vec3(0.2126, 0.7152, 0.0722));
        if (directLum > 0.001) {
            uint64_t guideKey = sharcHashKey(worldPos, N, sharcGrid);
            uint guideSlot = sharcInsert(guideKey, sharcCapacity);
            if (guideSlot != 0xFFFFFFFFu) {
                guideAccumulate(guideSlot, -rayDir, directLum, sharcCapacity);
            }
        }

        // SharcUpdateHit: insert/update cache, possibly early-out
        // directLighting is PRE-throughput; throughput applied via SharcSetThroughput
        float sharcRandom = rand01();  // standard 50% resampling (warmup burst disabled)
        bool continueTracing = SharcUpdateHit(sharcGrid, state,
            worldPos, N, directLighting, sharcRandom, sharcCapacity, hitT);
        SharcSetThroughput(state, throughput);
        storeSharcState(pixelIndex, state);

        if (!continueTracing) {
            psTerminate(idx, flags);
            return;
        }
    }

    // ---- Russian roulette (Cycles-style: sqrt perceptual, min bounce guard) ----
    uint minBounces = 2u;
    if (bounce >= minBounces) {
        float maxC = max(throughput.r, max(throughput.g, throughput.b));
        float p = min(sqrt(maxC), 1.0);
        if (rand01() > p) {
            psTerminate(idx, flags);
            return;
        }
        throughput /= p;
        throughput = min(throughput, vec3(MAX_RADIANCE));
    }

    // ---- Thin transmission fast path (windows, curtains, VM-mapped partial glass) ----
    if (glassProb_pre > 0.01 && useThinTransmissionPath) {
        vec3 Vthin = -rayDir;
        float cosTheta = abs(dot(N, Vthin));
        float etaThin = 1.0 / max(ior, 1.01);
        float fresnelThin = fresnelDielectric(cosTheta, etaThin);
        float thinPassProb = glassProb_pre * (1.0 - fresnelThin);
        float thinReflectProb = glassProb_pre * fresnelThin;
        float thinTotalProb = thinPassProb + thinReflectProb;
        float thinRnd = rand01();

        if (thinPassProb > 0.01 && thinRnd < thinPassProb) {
            // Thin passthrough INLINE: trace through multiple thin layers without re-queue
            // This avoids consuming dispatch iterations for stacked thin glass
            throughput *= cyclesPrincipledTransmissionTint(baseColor) / max(thinPassProb, 0.01);
            vec3 thinOrigin = worldPos + rayDir * 0.002;

            // Inline skip loop: trace through up to 6 more thin/glass/transparent layers
            for (int thinSkip = 0; thinSkip < 6; thinSkip++) {
                rayQueryEXT thinRQ;
                rayQueryInitializeEXT(thinRQ, topLevelAS, gl_RayFlagsOpaqueEXT,
                    0xFF, thinOrigin, MIN_HIT_DIST, rayDir, 10000.0);
                while (rayQueryProceedEXT(thinRQ)) {}
                if (rayQueryGetIntersectionTypeEXT(thinRQ, true) == gl_RayQueryCommittedIntersectionNoneEXT) {
                    break; // sky miss — will be handled by re-queued path or next iteration
                }
                float tHitT = rayQueryGetIntersectionTEXT(thinRQ, true);
                uint tCustIdx = rayQueryGetIntersectionInstanceCustomIndexEXT(thinRQ, true);
                int tPrimId = rayQueryGetIntersectionPrimitiveIndexEXT(thinRQ, true);
                GeometryMetadata tGeo = geometryMetadata.geometries[tCustIdx];
                uint tMatIdx = 0u;
                if (tGeo.primMaterialBufferAddress != 0u) {
                    PrimMaterials tPM = PrimMaterials(tGeo.primMaterialBufferAddress);
                    tMatIdx = tPM.m[tPrimId];
                }
                Material tMat = materialBuffer.materials[tMatIdx];

                // Glass/volume: pass through
                if ((tMat.flags & 6u) != 0u) {
                    // Check if it's THIN transmission — apply tint and continue
                    if ((tMat.flags & 128u) != 0u) { // MAT_FLAG_THIN_TRANSMISSION
                        throughput *= cyclesPrincipledTransmissionTint(
                            vec3(tMat.ksAmbient, tMat.ksDiffuse, tMat.ksSpecular));
                    }
                    thinOrigin += rayDir * (tHitT + 0.003);
                    continue;
                }
                // Transparent/lightpath: pass through
                if ((tMat.flags & (1u | 256u)) != 0u || tMat.multB > 0.0) {
                    thinOrigin += rayDir * (tHitT + 0.002);
                    continue;
                }
                // Opaque hit — stop skipping
                break;
            }

            // Re-queue from the final position (past all thin/transparent layers)
            uint nextIdx = atomicAdd(counters.nextActiveRayCount, 1u);
            uint nBase = nextIdx * 12u;
            uint thinFlags = bounce | (flags & 0x1FF00u) | matCatBits;
            psWriteAll(nextIdx, thinOrigin, pixelIndex, rayDir, rngState, throughput, thinFlags);
            psTerminate(idx, flags);
            return;
        } else if (thinReflectProb > 0.001 && thinRnd < thinTotalProb) {
            // Thin reflection (GGX microfacet)
            float alphaThin = roughness * roughness;
            vec3 Hthin;
            if (alphaThin > 0.0005) {
                alphaThin = max(alphaThin, 0.001);
                Hthin = sampleGGX_VNDF(rand2(), Vthin, N, alphaThin);
            } else {
                Hthin = N;
            }
            vec3 newDir = reflect(rayDir, Hthin);
            throughput *= vec3(1.0) / max(thinReflectProb, 0.01);
            uint nextIdx = atomicAdd(counters.nextActiveRayCount, 1u);
            uint nBase = nextIdx * 12u;
            vec3 reflOrigin = worldPos + N * 0.001;
            uint reflFlags = bounce | (flags & 0x1FF00u) | matCatBits;
            psWriteAll(nextIdx, reflOrigin, pixelIndex, newDir, rngState, throughput, reflFlags);
            psTerminate(idx, flags);
            return;
        }
        // If neither passthrough nor reflect triggered, fall through to standard BRDF
    }

    // ---- Stochastic passthrough (Transparent BSDF) ----
    float transparentProb = mat.multB;
    if (transparentProb > 0.0) {
        float cosTheta = abs(dot(N, -rayDir));
        float iorGlass = max(ior, 1.01);
        float f0g = (iorGlass - 1.0) / (iorGlass + 1.0);
        f0g = f0g * f0g;
        float fresnelRefl = f0g + (1.0 - f0g) * pow(1.0 - cosTheta, 5.0);
        transparentProb = 1.0 - fresnelRefl;
    }
    if (transparentProb > 0.0 && rand01() < transparentProb) {
        // Ray passes through — no refraction, like Cycles Transparent BSDF
        // Does NOT consume bounce budget (monolithic uses bounce--)
        uint nextIdx = atomicAdd(counters.nextActiveRayCount, 1u);
        uint nBase = nextIdx * 12u;
        vec3 skipOrigin = worldPos + rayDir * 0.002;
        // Preserve bounce + glass counter, clear isDiffuse
        uint tpFlags = bounce | (flags & 0x1FF00u) | matCatBits;
        psWriteAll(nextIdx, skipOrigin, pixelIndex, rayDir, rngState, throughput, tpFlags);
        psTerminate(idx, flags);
        return;
    }

    // Lightpath transparent: secondary specular rays pass through cheaply
    if ((mat.flags & MAT_FLAG_LIGHTPATH_TRANSPARENT) != 0u && bounce > 0u && !isDiffusePath) {
        uint nextIdx = atomicAdd(counters.nextActiveRayCount, 1u);
        uint nBase = nextIdx * 12u;
        vec3 skipOrigin = worldPos + rayDir * 0.002;
        uint lpFlags = bounce | (flags & 0x1FF00u) | matCatBits;
        psWriteAll(nextIdx, skipOrigin, pixelIndex, rayDir, rngState, throughput, lpFlags);
        psTerminate(idx, flags);
        return;
    }

    // ---- BRDF sampling for next bounce ----
    float glassProb = (1.0 - metallic) * transmission;
    vec3 V = -rayDir;

    // Glass bounce counter stored in flags bits [8:11] (4 bits = max 15)
    uint glassBounces = (flags >> 8u) & 0xFu;
    const uint MAX_GLASS_BOUNCES = 16u;

    // Glass / Transmission (Cycles-matching Fresnel)
    // Glass does NOT consume main bounce budget — writes same bounce, early return.
    if (glassProb > 0.01 && rand01() < glassProb) {
        glassBounces++;
        if (glassBounces >= MAX_GLASS_BOUNCES) {
            psTerminate(idx, flags);
            return;
        }

        // Entry/exit from smoothN (matching monolithic — smooth shading for curved glass)
        bool enteringGlass = dot(smoothN, -rayDir) >= 0.0;
        bool hasBumpMap = (mat.normalTexIndex != 0xFFFFFFFFu);
        bool isBumpNotNormalMap = hasBumpMap && (mat.detailNormalBlend < 0.0);
        vec3 refractN = enteringGlass
            ? (isBumpNotNormalMap ? N : smoothN)
            : (isBumpNotNormalMap ? -N : -smoothN);
        float eta = enteringGlass ? (1.0 / max(ior, 1.01)) : ior;
        float alphaGlass = roughness * roughness;

        // Bump-to-roughness: only for smooth glass with bump map
        if (hasBumpMap && alphaGlass < 0.001) {
            float bumpCos = dot(N, smoothN);
            if (bumpCos < 0.9999) {
                alphaGlass = max(alphaGlass, max(1.0 - bumpCos * bumpCos, 0.0));
            }
        }

        vec3 Hglass;
        if (alphaGlass >= 0.0005) {
            alphaGlass = max(alphaGlass, 0.001);
            Hglass = sampleGGX_VNDF(rand2(), V, refractN, alphaGlass);
        } else {
            Hglass = refractN;
        }

        float cosI = abs(dot(V, Hglass));
        float F = fresnelDielectric(cosI, eta);
        vec3 refracted = refract(-V, Hglass, eta);
        bool canRefract = dot(refracted, refracted) > 0.0001;

        // Cycles: reflection=F*white, transmission=(1-F)*sqrt(baseColor)
        vec3 tint = cyclesPrincipledTransmissionTint(baseColor);
        vec3 R = vec3(F);
        vec3 T = canRefract ? (1.0 - F) * tint : vec3(0.0);
        float avgR = dot(R, vec3(1.0/3.0));
        float avgT = dot(T, vec3(1.0/3.0));
        float pReflect = (!canRefract) ? 1.0 : avgR / max(avgR + avgT, 1e-6);

        bool pathReflects2 = (!canRefract || rand01() < pReflect);
        if (pathReflects2) {
            rayDir = reflect(rayDir, Hglass);
            rayOrigin = worldPos + refractN * 0.001;
            throughput *= R / max(glassProb * pReflect, 1e-4);
        } else {
            rayDir = refracted;
            rayOrigin = worldPos - refractN * 0.001;
            throughput *= T / max(glassProb * (1.0 - pReflect), 1e-4);
        }

        // Glass plane decomposition (same logic as earlyGlassExit)
        uint secondaryBit2 = flags & FLAG_SECONDARY_PLANE;
        if (glassBouncesPrev == 0u && secondaryBit2 == 0u) {
            uvec4 spH2 = spHeader.data[pixelIndex];
            uint domIdx2 = spH2.w & 3u;
            uint pathPlane2 = pathReflects2 ? 0u : 1u;
            if (pathPlane2 != domIdx2) secondaryBit2 = FLAG_SECONDARY_PLANE;
        }

        // Write PathState at SAME bounce (glass doesn't consume bounce budget)
        uint nextIdx = atomicAdd(counters.nextActiveRayCount, 1u);
        uint nBase = nextIdx * 12u;
        // Same bounce, not diffuse, updated glass counter + plane flag
        uint glassFlags = bounce | ((glassBounces & 0xFu) << 8u) | matCatBits | secondaryBit2;
        psWriteAll(nextIdx, rayOrigin, pixelIndex, rayDir, rngState, throughput, glassFlags);
        psTerminate(idx, flags);
        return;

    } else if (isHairSurface) {
        // ---- Hair BSDF: Karis simplified Marschner (R + TT + TRT) ----
        if (bounce > 1u) {
            psTerminate(idx, flags);
            return;
        }

        float NdotV = max(dot(N, V), 0.001);
        float f0_d = (ior - 1.0) / (ior + 1.0);
        f0_d = f0_d * f0_d;
        vec3 F0 = mix(vec3(f0_d * specularLevel * 2.0), baseColor, metallic);
        vec3 Fh = fresnelSchlick(NdotV, F0);
        float specWeight = (Fh.r + Fh.g + Fh.b) / 3.0;

        float hairRoughness = max(roughness, 0.05);
        float hairIor = max(ior, 1.01);
        float hairSpecularWeight = max(specularLevel * 2.0, 0.0);
        float hairF0 = (hairIor - 1.0) / (hairIor + 1.0);
        hairF0 *= hairF0;
        float specProb = clamp(hairSpecularWeight * (0.35 + 0.45 * (1.0 - hairRoughness)) + hairF0 * 2.0,
                               0.12, 0.9);
        if (hairSpecularWeight <= 1e-5) specProb = 0.0;

        vec3 bounceN = N;
        bool chooseHairSpec = specProb > 0.0 && rand01() < specProb;
        vec3 newDir;

        if (chooseHairSpec) {
            float a2 = max(hairRoughness * hairRoughness, 0.001);
            vec3 H = sampleGGX_VNDF(rand2(), V, bounceN, a2);
            newDir = reflect(-V, H);
            float NdotL = max(dot(bounceN, newDir), 0.0);
            float VdotH = max(dot(V, H), 1e-6);
            if (NdotL <= 0.0 || VdotH <= 1e-6) {
                psTerminate(idx, flags);
                return;
            }
            float NdotH = max(dot(bounceN, H), 0.0);
            float NdotVHair = max(dot(bounceN, V), 0.001);
            float specPdf = (GGX_D(NdotH, a2) * SmithG1(NdotVHair, a2) * VdotH)
                          / max(4.0 * NdotVHair * VdotH, 1e-6);
            vec3 hairSpec = hair_eval(V, newDir, hairSmoothT,
                                      baseColor, hairRoughness, max(hairRadialRoughness, 0.05),
                                      hairShift, hairIor, hairV);
            float branchPdf = specProb * max(specPdf, 1e-6);
            throughput *= hairSpec / branchPdf;
            isDiffusePath = false;
        } else {
            newDir = sampleCosineHemisphere(rand2(), bounceN);
            vec3 hairDiffuse = hair_eval(V, newDir, hairSmoothT,
                                         baseColor, hairRoughness, max(hairRadialRoughness, 0.05),
                                         hairShift, hairIor, hairV);
            float cosPdf = max(dot(newDir, bounceN), 0.0) * INV_PI;
            float branchPdf = max((1.0 - specProb) * cosPdf, 1e-6);
            if (branchPdf <= 1e-6) {
                psTerminate(idx, flags);
                return;
            }
            throughput *= hairDiffuse / branchPdf;
            isDiffusePath = true;
        }
        throughput = min(throughput, vec3(MAX_RADIANCE));
        rayDir = newDir;
        rayOrigin = worldPos + N * 0.02;

    } else {
        // ---- Coat layer (clearcoat) ----
        // If coat is active, evaluate coat GGX lobe first.
        // Coat reflects some light (dielectric Fresnel); remainder passes to base material.
        if (coatWeight > 0.001) {
            float coatAlpha = coatRoughness * coatRoughness;
            float NdotVcoat = max(dot(N, V), 0.001);
            float coatF = fresnelDielectric(NdotVcoat, 1.0 / coatIOR);
            float coatReflectance = coatWeight * coatF;

            // Russian Roulette: coat reflect vs pass-through to base
            if (rand01() < coatReflectance) {
                // Coat reflection — GGX specular with coat params
                vec3 Hcoat = sampleGGX_VNDF(rand2(), V, N, coatAlpha);
                vec3 coatDir = reflect(-V, Hcoat);
                if (dot(coatDir, N) <= 0.0) {
                    psTerminate(idx, flags);
                    return;
                }
                float NdotLcoat = max(dot(N, coatDir), 0.0);
                float G2coat = SmithG2(NdotLcoat, NdotVcoat, coatAlpha);
                float G1coat = SmithG1(NdotVcoat, coatAlpha);
                throughput *= vec3(coatF) * (G2coat / max(G1coat, 0.001)) / max(coatReflectance, 1e-4);
                isDiffusePath = false;
                rayDir = coatDir;
                rayOrigin = worldPos + N * 0.002;

                uint nextBounce = bounce + 1u;
                if (nextBounce < pc.maxBounces) {
                    uint nextIdx = atomicAdd(counters.nextActiveRayCount, 1u);
                    uint nBase = nextIdx * 12u;
                    uint newFlags = nextBounce | matCatBits | (flags & FLAG_SECONDARY_PLANE);
                    psWriteAll(nextIdx, rayOrigin, pixelIndex, rayDir, rngState, throughput, newFlags);
                }
                psTerminate(idx, flags);
                return;
            }
            // Pass-through: attenuate throughput by (1 - coat reflectance)
            throughput *= (1.0 - coatReflectance);
        }

        // ---- Standard BRDF lobe selection ----
        float NdotV = max(dot(N, V), 0.001);
        float f0_d = (ior - 1.0) / (ior + 1.0);
        f0_d = f0_d * f0_d;
        vec3 F0 = mix(vec3(f0_d * specularLevel * 2.0), baseColor, metallic);
        float alpha2 = roughness * roughness;
        vec3 F = fresnelGeneralized(NdotV, F0, ior, metallic);
        float specWeight = (F.r + F.g + F.b) / 3.0;

        float diffuseWeight = (1.0 - metallic) * (1.0 - transmission);
        float dielectricSpecWeight = (1.0 - metallic) * (1.0 - transmission);
        float metalSpecWeight = metallic;
        float nonGlassCompensation = (glassProb > 0.01) ? 1.0 / max(1.0 - glassProb, 0.5) : 1.0;
        bool chooseDiffuse = (diffuseWeight > 0.001) ? (rand01() > specWeight) : false;

        if (chooseDiffuse && metallic < 1.0) {
            // Diffuse — with SHARC path guiding for bounce 1+
            bool useGuide = false;
            if (sharcEnabled && bounce >= 1u) {
                uint64_t guideKey = sharcHashKey(worldPos, N, sharcGrid);
                uint guideSlot = sharcFind(guideKey, sharcCapacity);
                if (guideSlot != 0xFFFFFFFFu) {
                    float guidePdf;
                    vec3 guideDir = guideSampleDirection(guideSlot, N, rand01(), rand01(),
                                                         sharcCapacity, guidePdf);
                    if (guidePdf > 0.0 && dot(guideDir, N) > 0.0) {
                        rayDir = guideDir;
                        float cosinePdf = max(dot(rayDir, N), 0.0) * INV_PI;
                        float misWeight = guideMISWeight(cosinePdf, guidePdf, 0.5);
                        throughput *= baseColor * (1.0 - metallic) * nonGlassCompensation * misWeight;
                        useGuide = true;
                    }
                }
            }
            if (!useGuide) {
                rayDir = sampleCosineHemisphere(rand2(), N);
                throughput *= baseColor * (1.0 - metallic) * nonGlassCompensation;
            }
            isDiffusePath = true;
        } else {
            // Specular (anisotropic when anisotropicFactor > 0)
            float alpha2 = roughness * roughness;
            float anisoAspect = sqrt(max(1.0 - anisotropicFactor * 0.9, 0.01));
            float spec_alpha_x = alpha2 / anisoAspect;
            float spec_alpha_y = alpha2 * anisoAspect;
            vec3 H = (anisotropicFactor > 0.001)
                ? sampleGGX_VNDF_aniso(rand2(), V, anisoT, anisoB, N, spec_alpha_x, spec_alpha_y)
                : sampleGGX_VNDF(rand2(), V, N, alpha2);
            rayDir = reflect(-V, H);
            if (dot(rayDir, N) <= 0.0) {
                psTerminate(idx, flags);
                return;
            }
            float NdotL = max(dot(N, rayDir), 0.0);
            float NdotH = max(dot(N, H), 0.0);
            float VdotH = max(dot(V, H), 0.0);
            // Cycles-accurate metallic-dielectric lobe separation (commit 2c069d0):
            // Separate Fresnel weighting for dielectric and metallic components
            float f0_die = (ior - 1.0) / (ior + 1.0);
            f0_die = f0_die * f0_die;
            vec3 dielectricF0 = vec3(f0_die * specularLevel * 2.0);
            vec3 dielectricFw = fresnelGeneralized(VdotH, dielectricF0, ior, 0.0) * dielectricSpecWeight;
            vec3 metalFw = fresnelGeneralized(VdotH, baseColor, ior, 1.0) * metalSpecWeight;
            float G2, G1;
            if (anisotropicFactor > 0.001) {
                vec3 L_local = vec3(dot(rayDir, anisoT), dot(rayDir, anisoB), dot(rayDir, N));
                vec3 V_local = vec3(dot(V, anisoT), dot(V, anisoB), dot(V, N));
                G2 = SmithG2_aniso(L_local, V_local, spec_alpha_x, spec_alpha_y);
                G1 = SmithG1_aniso(V_local, spec_alpha_x, spec_alpha_y);
            } else {
                G2 = SmithG2(NdotL, NdotV, alpha2);
                G1 = SmithG1(NdotV, alpha2);
            }
            throughput *= (dielectricFw + metalFw) * (G2 / max(G1, 0.001)) * nonGlassCompensation;
            isDiffusePath = false;
        }
        rayOrigin = worldPos + N * 0.002;
    }

    // ---- ReSTIR GI: Indirect lighting temporal reuse ----
    // Bounce 0: apply previous frame's GI reservoir (temporal reuse)
    // Bounce 1: capture current hit as new GI sample
    bool giReservoirEnabled = (cam.lightPad2 & 8u) != 0u;  // bit 3 of lightPad2
    if (giReservoirEnabled && !isGlass && !isHairSurface) {
        float giIntensity = cam.ptParams0.y; // same GI intensity used for bounce > 0
        int pixelLinearIdx = int(pixelIndex);
        ivec2 launchSize = ivec2(pc.width, pc.height);
        ivec2 pixel = ivec2(pixelIndex % pc.width, pixelIndex / pc.width);

        if (bounce == 1u) {
            // Capture: indirect hit as GI reservoir sample
            vec3 sampleRadiance = emission;
            float sunInt = cam.sunLight.w;
            if (sunInt > 0.0) {
                vec3 sunDir = normalize(cam.sunLight.xyz);
                float sNdotL = max(dot(N, sunDir), 0.0);
                sampleRadiance += baseColor * sNdotL * sunInt * 0.3183; // 1/PI
            }
            sampleRadiance *= giIntensity;

            if (dot(sampleRadiance, vec3(0.2126, 0.7152, 0.0722)) > 0.001) {
                GIReservoir newSample;
                newSample.position = worldPos;
                newSample.normal = N;
                newSample.radiance = sampleRadiance;
                newSample.hitDist = hitT;
                newSample.age = 0.0;
                newSample.weightSum = 0.0;
                newSample.M = 0.0;

                uint gBase = pixelIndex * 16u;
                vec3 primaryN = vec3(primaryGBuf.gbufData[gBase+0],
                                     primaryGBuf.gbufData[gBase+1],
                                     primaryGBuf.gbufData[gBase+2]);
                vec3 primaryPos = vec3(primaryGBuf.gbufData[gBase+4],
                                       primaryGBuf.gbufData[gBase+5],
                                       primaryGBuf.gbufData[gBase+6]);

                float pHat = giTargetPDF(primaryN, primaryPos, newSample);
                if (pHat > 0.0) {
                    GIReservoir curr = emptyReservoir();
                    float rng = rand01();
                    reservoirUpdate(curr, newSample, pHat, rng);
                    writeReservoir(pixelLinearIdx, curr);
                }
            }
        }

        if (bounce == 0u && pc.sampleIdx == 0u) {
            vec3 primaryN = N;
            vec3 primaryPos = worldPos;

            vec4 currClip = cam.proj * cam.view * vec4(worldPos, 1.0);
            vec2 currNDC = currClip.xy / currClip.w;
            vec2 currUV = vec2(currNDC.x * 0.5 + 0.5, 0.5 - currNDC.y * 0.5);

            uint rBase3 = uint(instanceId) * 3u;
            vec4 rRow0 = prevTransforms.data[rBase3 + 0u];
            vec4 rRow1 = prevTransforms.data[rBase3 + 1u];
            vec4 rRow2 = prevTransforms.data[rBase3 + 2u];
            vec3 prevWorldPos = vec3(dot(rRow0, vec4(localPos, 1.0)),
                                     dot(rRow1, vec4(localPos, 1.0)),
                                     dot(rRow2, vec4(localPos, 1.0)));
            vec4 prevClip = cam.projPrev * cam.viewPrev * vec4(prevWorldPos, 1.0);
            vec2 prevNDC = prevClip.xy / prevClip.w;
            vec2 prevUV = vec2(prevNDC.x * 0.5 + 0.5, 0.5 - prevNDC.y * 0.5);
            vec2 motionVec = prevUV - currUV;

            GIReservoir reservoir = emptyReservoir();
            float rng = rand01();
            bool reused = reservoirTemporalReuse(reservoir, primaryN, primaryPos,
                                                  motionVec, launchSize, pixel, rng);

            if (reused && reservoir.weightSum > 0.0 && reservoir.M > 0.0) {
                float finalPHat = giTargetPDF(primaryN, primaryPos, reservoir);
                if (finalPHat > 0.0) {
                    float W = reservoir.weightSum / (reservoir.M * finalPHat);
                    vec3 reusedGI = reservoir.radiance * finalPHat * W;
                    float blendWeight = clamp(reservoir.M / 10.0, 0.0, 0.5);
                    uint rBase = pixelIndex * 8u;
                    vec3 giContrib = reusedGI * blendWeight * 0.3;
                    atomicAddFloat(rBase + 0u, giContrib.r);
                    atomicAddFloat(rBase + 1u, giContrib.g);
                    atomicAddFloat(rBase + 2u, giContrib.b);
                }
            }
        }
    }

    // Write next-bounce PathState
    uint nextBounce = bounce + 1u;
    if (nextBounce < pc.maxBounces) {
        uint nextIdx = atomicAdd(counters.nextActiveRayCount, 1u);
        uint nBase = nextIdx * 12u;
        uint newFlags = nextBounce | (isDiffusePath ? 0x10u : 0u) | matCatBits | (flags & FLAG_SECONDARY_PLANE);
        psWriteAll(nextIdx, rayOrigin, pixelIndex, rayDir, rngState, throughput, newFlags);
    }

    // Mark current path as processed (not terminated — it continues via nextActiveRayCount)
    psTerminate(idx, flags);
}
