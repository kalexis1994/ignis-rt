#version 460
#extension GL_EXT_ray_tracing : require
#extension GL_EXT_ray_query : require
#extension GL_EXT_buffer_reference : require
#extension GL_EXT_scalar_block_layout : require
#extension GL_EXT_shader_explicit_arithmetic_types_int64 : require
#extension GL_EXT_nonuniform_qualifier : require
#extension GL_EXT_shader_atomic_int64 : require
#extension GL_GOOGLE_include_directive : require
#extension GL_NV_ray_tracing_invocation_reorder : enable
#extension GL_ARB_shader_clock : enable

// ============================================================
// Descriptor bindings — IDENTICAL layout to raygen.rgen (0-23)
// ============================================================

layout(binding = 0, set = 0) uniform accelerationStructureEXT topLevelAS;
layout(binding = 1, set = 0) writeonly uniform image2D image;

layout(binding = 2, set = 0) uniform CameraProperties {
    mat4 viewInverse;
    mat4 projInverse;
    mat4 view;
    mat4 proj;
    mat4 viewPrev;
    mat4 projPrev;
    uvec4 parameters;
    vec4 jitterData;
    vec4 sunLight;
    vec4 ambientLight;
    vec4 skyLight;
    vec4 ptParams0;  // x=exposure, y=giIntensity, z=saturation, w=contrast
    vec4 ptParams1;  // x=skyReflIntensity, y=ambientMax, z=sunMinIntensity, w=skyBounceIntensity
    vec4 windParams;
    vec4 rainParams;
    vec4 dofParams;    // x=aperture, y=focusDist, z=blades, w=rotation
    vec4 dofParams2;   // x=ratio
    ivec4 jitterPattern[8];
    // Point/spot lights
    uint lightCount;
    uint lightPad0, lightPad1, lightPad2;
    vec4 lights[128]; // 32 lights × 4 vec4s: [pos.xyz+range, col.rgb+intensity, dir.xyz+sizeX, tan.xyz+sizeY]
    // SHARC radiance cache (buffer device addresses + grid config)
    uint64_t sharcHashEntriesAddr;
    uint64_t sharcAccumulationAddr;
    uint64_t sharcResolvedAddr;
    uint sharcCapacity;
    float sharcSceneScale;
    float sharcRadianceScale;
    uint sharcPad;
} cam;

// Geometry metadata
struct GeometryMetadata {
    uint64_t vertexBufferAddress;
    uint64_t indexBufferAddress;
    uint64_t normalBufferAddress;
    uint64_t uvBufferAddress;
    uint64_t primMaterialBufferAddress;
    uint64_t bitangentBufferAddress;
    uint64_t primYBoundsAddress;
    uint64_t colorBufferAddress;    // float4 RGBA vertex colors
    uint vertexCount;
    uint indexCount;
};

layout(binding = 3, set = 0, scalar) buffer GeometryMetadataBuffer {
    GeometryMetadata geometries[];
} geometryMetadata;

// Material buffer
struct Material {
    uint diffuseTexIndex;
    uint normalTexIndex;
    uint mapsTexIndex;
    uint detailTexIndex;

    uint normalDetailTexIndex;
    float ksAmbient;
    float ksDiffuse;
    float ksSpecular;

    float ksSpecularEXP;
    float emissiveR, emissiveG, emissiveB;

    float fresnelC;
    float fresnelEXP;
    float detailUVMultiplier;
    float detailNormalBlend;

    uint flags;
    float alphaRef;
    uint shaderType;
    float fresnelMaxLevel;

    uint maskTexIndex;
    uint detailRTexIndex;
    uint detailGTexIndex;
    uint detailBTexIndex;

    uint detailATexIndex;
    uint detailNMTexIndex;
    float multR;
    float multG;

    float multB;
    float multA;
    float magicMult;
    float detailNMMult;
    float detailNMMultV;

    float sunSpecular;
    float sunSpecularEXP;

    // Node VM bytecode
    uint nodeVmHeader;       // [7:0]=instrCount, [15:8]=flags
    uint nodeVmPad[3];
    uvec4 nodeVmCode[128];   // 128 instructions (supports complex Mix Shader materials)
};

layout(binding = 4, set = 0, scalar) buffer MaterialBuffer {
    Material materials[];
} materialBuffer;

// Texture array
layout(binding = 5, set = 0) uniform sampler2D textures[];

// NRD G-buffers
layout(binding = 6, set = 0, rgba16f) uniform image2D normalRoughnessImg;
layout(binding = 7, set = 0, r32f)    uniform image2D viewDepthImg;
layout(binding = 8, set = 0, rgba16f) uniform image2D motionVectorsImg;
layout(binding = 9, set = 0, rgba16f) uniform image2D diffuseRadianceImg;
layout(binding = 10, set = 0, rgba16f) uniform image2D specularRadianceImg;
layout(binding = 13, set = 0, rgba16f) uniform image2D specularMVImg;
layout(binding = 15, set = 0, rgba16f) uniform image2D specularAlbedoImg;
layout(binding = 16, set = 0, rgba16f) uniform image2D albedoBufferImg;

// Blue noise
layout(binding = 12, set = 0) uniform sampler2D blueNoiseTexture;

// Shadow-related (declared for layout compatibility, not used by this shader)
layout(binding = 18, set = 0, r16f) uniform image2D penumbraImg;
layout(binding = 19, set = 0) uniform sampler2D shadowAccumPrevious;

// DLSS depth
layout(binding = 22, set = 0, r32f) uniform image2D dlssDepthImg;

// Cloud shadow (declared for layout compatibility)
layout(binding = 23, set = 0) uniform sampler2D cloudShadowMap;

// SHARC radiance cache — 2 SSBOs (hash entries + combined accum/resolved)
// Based on NVIDIA SHARC algorithm (https://github.com/NVIDIA-RTX/SHARC)
// Binding 20: hash entries (uint64 per slot)
// Binding 21: combined buffer — first half = accumulation (uint×4 per slot),
//             second half = resolved (uint×4 per slot). Offset = capacity×4.
layout(binding = 20, set = 0, std430) buffer SHARCHashEntries { uint64_t keys[]; } _sharcHashEntries;
layout(binding = 21, set = 0, std430) buffer SHARCData        { uint data[];     } _sharcAccum;

// Resolved data accessed via offset into the same buffer
#define _sharcResolved _sharcAccum  // resolved region starts at capacity*4

#include "include/sharc_setup.glsl"
// surfel_gi.glsl included AFTER buffer declarations (needs _surfelHashEntries, _surfelData)

// GI Reservoir buffers for ReSTIR temporal reuse (3 vec4s per pixel)
layout(binding = 24, set = 0, std430) buffer GIReservoirCurrBuf { vec4 data[]; } giReservoirCurr;
layout(binding = 25, set = 0, std430) buffer GIReservoirPrevBuf { vec4 data[]; } giReservoirPrev;

// Emissive triangles for MIS (16 floats per triangle)
// Layout: [v0.xyz, area, v1.xyz, cdf, v2.xyz, totalPower, emission.rgb, pad]
layout(binding = 26, set = 0, std430) buffer EmissiveTriBuf {
    vec4 data[];  // 4 vec4s per triangle
} emissiveTris;

// Surfel GI cache (experimental)
layout(binding = 32, set = 0, std430) buffer SurfelHashBuf {
    uint64_t keys[];
} _surfelHashEntries;

layout(binding = 33, set = 0, std430) buffer SurfelDataBuf {
    uint data[];
} _surfelData;

#include "include/surfel_gi.glsl"

// Per-instance previous-frame transforms (3 vec4s per instance: row0, row1, row2 of 3x4 row-major)
layout(binding = 28, set = 0, std430) buffer PrevTransformBuf {
    vec4 data[];  // 3 vec4s per instance
} prevTransforms;

// Confidence and reactive masks (infrastructure for dynamic objects)
layout(binding = 29, set = 0, r8) uniform image2D reactiveMaskImg;
layout(binding = 30, set = 0, r8) uniform image2D diffConfidenceImg;
layout(binding = 31, set = 0, r8) uniform image2D specConfidenceImg;

// Hair contour: per-pixel hairV for screen-space edge detection
layout(binding = 34, set = 0, r16f) uniform image2D hairVImg;

// Hybrid G-buffer (rasterized primary visibility)
layout(binding = 35, set = 0, r32ui) uniform uimage2D hybridPrimIdImg;
layout(binding = 36, set = 0, rg32ui) uniform uimage2D hybridInstanceInfoImg;
layout(binding = 37, set = 0, r32f) uniform image2D hybridDepthImg;

// Pick buffer
layout(binding = 17, set = 0, scalar) buffer PickBuffer {
    uint pickCustomIndex;
    uint pickPrimitiveId;
    uint pickMaterialId;
    uint pickValid;
} pickResult;

// ── NRC (Neural Radiance Cache) buffers ──
// Declared unconditionally; only written when ENABLE_NRC=1 in the shader.
// Struct types from nrc.glsl (included below with NRC_STRUCTURES_ONLY).
#define NRC_STRUCTURES_ONLY
#include "include/nrc.glsl"
#undef NRC_STRUCTURES_ONLY

layout(binding = 38, set = 0, std430) buffer NrcCounterBuf      { uint nrcCounters[]; };
layout(binding = 39, set = 0, std430) buffer NrcQueryPathBuf     { NrcPackedQueryPathInfo nrcQueryPathInfo[]; };
layout(binding = 40, set = 0, std430) buffer NrcTrainPathBuf     { NrcPackedTrainingPathInfo nrcTrainingPathInfo[]; };
layout(binding = 41, set = 0, std430) buffer NrcTrainVertBuf     { NrcPackedPathVertex nrcTrainingPathVertices[]; };
layout(binding = 42, set = 0, std430) buffer NrcQueryRadBuf      { NrcRadianceParams nrcQueryRadianceParams[]; };

// Define custom buffer accessors for nrc.glsl functions
#define NRC_USE_CUSTOM_BUFFER_ACCESSORS 1
#define NRC_BUFFER_QUERY_PATH_INFO         nrcQueryPathInfo
#define NRC_BUFFER_TRAINING_PATH_INFO      nrcTrainingPathInfo
#define NRC_BUFFER_TRAINING_PATH_VERTICES  nrcTrainingPathVertices
#define NRC_BUFFER_QUERY_RADIANCE_PARAMS   nrcQueryRadianceParams
#define NRC_BUFFER_QUERY_COUNTERS_DATA     nrcCounters

// NRC constants UBO (binding 43, populated by NRC SDK)
layout(binding = 43, set = 0) uniform NrcConstantsUBO {
    NrcConstants nrcConstants;
};

// NRC mode: controlled at runtime via nrcConstants.enableTerminationHeuristic > 0.
// Compiled with ENABLE_NRC=1 but all NRC functions check NrcIsEnabled() which
// tests g_nrcMode. We set g_nrcMode based on a runtime flag in the constants UBO.
#define ENABLE_NRC 1
// Don't define NRC_QUERY or NRC_UPDATE — let g_nrcMode be set at runtime
#include "include/nrc.glsl"

// Buffer references
layout(buffer_reference, scalar) buffer Vertices { float v[]; };
layout(buffer_reference, scalar) buffer Indices { uint i[]; };
layout(buffer_reference, scalar) buffer Normals { float n[]; };
layout(buffer_reference, scalar) buffer UVs { float uv[]; };
layout(buffer_reference, scalar) buffer Colors { float c[]; };  // float4 RGBA per vertex
layout(buffer_reference, scalar) buffer PrimMaterials { uint m[]; };
layout(buffer_reference, scalar) readonly buffer CurveKeys { vec4 k[]; };

// ── NIRC (custom Neural Incident Radiance Cache) buffers ──
// 44: training samples (written by raygen), 45: hash features (read for inference)
// 46: MLP weights (read for inference), 47: query input, 48: query output
struct NircTrainingSample {
    vec3 position; float roughness;
    vec3 direction; float _pad0;
    vec3 radiance;  float _pad1;
};
layout(binding = 44, set = 0, scalar) buffer NircTrainBuf  { NircTrainingSample nircSamples[]; };
layout(binding = 45, set = 0, scalar) buffer NircHashBuf   { float nircHashFeatures[]; };
layout(binding = 46, set = 0, scalar) buffer NircWeightBuf { float nircWeights[]; };
layout(binding = 47, set = 0, scalar) buffer NircQueryIn   { float nircQueryInput[]; };
layout(binding = 48, set = 0, scalar) buffer NircQueryOut  { vec4  nircQueryOutput[]; };

// ============================================================
// Shared includes (extracted for reuse across shaders)
// ============================================================

#include "include/common.glsl"
#include "include/pbr_brdf.glsl"
#include "include/sampling.glsl"
#include "include/nrd_encode.glsl"
#include "include/tonemap.glsl"
#include "include/gi_reservoir.glsl"
#include "include/di_reservoir.glsl"
#include "include/node_vm.glsl"
#include "include/hair_bsdf.glsl"
// octDecode already defined in gi_reservoir.glsl

const uint SHADER_BLENDER_PBR = 100u;

// EnvBRDFApprox — Epic/Karis approximation for split-sum specular albedo
// Returns the specular color that RR needs for correct denoising
vec3 EnvBRDFApprox(vec3 F0, float roughness, float NdotV) {
    const vec4 c0 = vec4(-1.0, -0.0275, -0.572, 0.022);
    const vec4 c1 = vec4(1.0, 0.0425, 1.04, -0.04);
    vec4 r = roughness * c0 + c1;
    float a004 = min(r.x * r.x, exp2(-9.28 * NdotV)) * r.x + r.y;
    vec2 AB = vec2(-1.04, 1.04) * a004 + r.zw;
    return F0 * AB.x + vec3(AB.y);
}

const uint INVALID_HAIR_STRAND = 0xFFFFFFFFu;
const uint MAT_FLAG_HAIR = 32u;
const uint MAT_FLAG_DIFFUSE_SCENE_LINEAR = 64u;
const uint MAT_FLAG_THIN_TRANSMISSION = 128u;
const uint MAT_FLAG_LIGHTPATH_TRANSPARENT = 256u;
const uint VM_HEADER_FLAG_BASE_COLOR = 1u;
const uint VM_HEADER_FLAG_ALPHA = 2u;
const uint VM_HEADER_FLAG_TRANSMISSION = 4u;
const uint VM_HEADER_FLAG_SHADOW_DYNAMIC = 8u;

bool getHairRibbonLayout(GeometryMetadata geo,
                         out uint strandCount,
                         out uint vertsPerStrand,
                         out uint trisPerStrand)
{
    strandCount = 0u;
    vertsPerStrand = 0u;
    trisPerStrand = 0u;

    if (geo.bitangentBufferAddress == 0u || geo.indexCount < 12u || geo.vertexCount < 8u)
        return false;

    uint totalTris = geo.indexCount / 3u;
    if (geo.vertexCount <= totalTris)
        return false;

    uint vertexMinusTris = geo.vertexCount - totalTris;
    if ((vertexMinusTris & 3u) != 0u)
        return false;

    strandCount = vertexMinusTris / 4u;
    if (strandCount == 0u || (totalTris % strandCount) != 0u)
        return false;

    trisPerStrand = totalTris / strandCount;
    if ((trisPerStrand & 3u) != 0u)
        return false;

    vertsPerStrand = trisPerStrand + 4u;
    if (geo.vertexCount != strandCount * vertsPerStrand)
        return false;

    return true;
}

uint getHairStrandId(GeometryMetadata geo, uint primId)
{
    uint strandCount, vertsPerStrand, trisPerStrand;
    if (!getHairRibbonLayout(geo, strandCount, vertsPerStrand, trisPerStrand) || trisPerStrand == 0u)
        return INVALID_HAIR_STRAND;

    return primId / trisPerStrand;
}

vec3 fetchHairVertexWorld(Vertices vertices, mat4x3 objToWorld, uint vertexIndex)
{
    return (objToWorld * vec4(
        vec3(vertices.v[vertexIndex*3u + 0u],
             vertices.v[vertexIndex*3u + 1u],
             vertices.v[vertexIndex*3u + 2u]), 1.0));
}

vec3 fetchHairSectionCenter(Vertices vertices, mat4x3 objToWorld, uint baseVertex)
{
    return (fetchHairVertexWorld(vertices, objToWorld, baseVertex + 0u)
          + fetchHairVertexWorld(vertices, objToWorld, baseVertex + 1u)
          + fetchHairVertexWorld(vertices, objToWorld, baseVertex + 2u)
          + fetchHairVertexWorld(vertices, objToWorld, baseVertex + 3u)) * 0.25;
}

float hairSegmentParamFromRay(vec3 rayO, vec3 rayD, vec3 p0, vec3 p1)
{
    vec3 axis = p1 - p0;
    float axisLen2 = dot(axis, axis);
    if (axisLen2 < 1e-8) return 0.0;

    vec3 rel = rayO - p0;
    float rayAxis = dot(rayD, axis);
    float rayRel = dot(rayD, rel);
    float axisRel = dot(axis, rel);
    float denom = axisLen2 - rayAxis * rayAxis;  // rayD assumed normalized

    if (abs(denom) > 1e-8) {
        return clamp((rayAxis * rayRel - axisRel) / denom, 0.0, 1.0);
    }

    return clamp(dot(-rel, axis) / axisLen2, 0.0, 1.0);
}

float hermiteScalar(float p0, float p1, float m0, float m1, float t)
{
    float t2 = t * t;
    float t3 = t2 * t;
    return (2.0 * t3 - 3.0 * t2 + 1.0) * p0
         + (-2.0 * t3 + 3.0 * t2) * p1
         + (t3 - 2.0 * t2 + t) * m0
         + (t3 - t2) * m1;
}

float computeHairSectionRadius(vec3 center, vec3 tangent, vec3 a, vec3 b, vec3 c, vec3 d)
{
    vec3 ao = a - center - tangent * dot(a - center, tangent);
    vec3 bo = b - center - tangent * dot(b - center, tangent);
    vec3 co = c - center - tangent * dot(c - center, tangent);
    vec3 dO = d - center - tangent * dot(d - center, tangent);
    return max((length(ao) + length(bo) + length(co) + length(dO)) * 0.25, 1e-6);
}

vec2 computeHairSectionSupportRadii(vec3 center, vec3 dir, vec3 a, vec3 b, vec3 c, vec3 d)
{
    float pa = dot(a - center, dir);
    float pb = dot(b - center, dir);
    float pc = dot(c - center, dir);
    float pd = dot(d - center, dir);
    float minProj = min(min(pa, pb), min(pc, pd));
    float maxProj = max(max(pa, pb), max(pc, pd));
    return vec2(max(-minProj, 1e-6), max(maxProj, 1e-6));
}

float evalHairCylinderFalloff(vec3 cylN, vec3 lightDir)
{
    float front = max(dot(cylN, lightDir), 0.0);
    float back = max(dot(cylN, -lightDir), 0.0);
    return max(front, back * 0.35);
}

void evaluateHairCylinderBSDF(
    vec3 cylN, vec3 viewDir, vec3 lightDir, vec3 hairT,
    vec3 baseColor, float roughness, float radialRoughness, float specularLevel,
    float ior, float hairShift, float hairV,
    out vec3 diffuseContrib, out vec3 specularContrib)
{
    // Cycles hair: all energy via R+TT+TRT with Beer-Lambert absorption.
    float hairIor = max(ior, 1.01);
    float hairRoughness = max(roughness, 0.05);
    float hairRadialRoughness = max(radialRoughness, 0.05);
    vec3 hairBSDF = hair_eval(viewDir, lightDir, hairT,
                              baseColor, hairRoughness, hairRadialRoughness, hairShift, hairIor, hairV);

    // hair_eval already includes geometric terms (M, N gaussians).
    // No extra sinTL or specularWeight — those would double-count.
    diffuseContrib = hairBSDF;
    specularContrib = vec3(0.0);
}

// ============================================================
// Sky Environment — Procedural Preetham/Rayleigh+Mie scattering
// Ported from ac-path-tracer (physically plausible, ~30 ALU ops)
// ============================================================

// Core sky evaluation: returns HDR sky radiance for any direction.
vec3 proceduralSky(vec3 dir, vec3 sunDirL, vec3 ambColor, vec3 sunTint,
                   float airDensity, float dustDensity, float sunSize) {
    float sunAlt = sunDirL.y;  // sun elevation [-1, 1]
    float cosTheta = max(dir.y, 0.001);     // view elevation
    float cosGamma = dot(dir, sunDirL);     // angle to sun

    // Rayleigh scattering: blue overhead, warmer at horizon
    // airDensity modulates scattering strength (default 1.0)
    float rayleighPhase = 0.75 * (1.0 + cosGamma * cosGamma);
    vec3 rayleighColor = vec3(0.30, 0.42, 0.68);

    // Low sun → orange/red shift (sunset/sunrise)
    float sunsetShift = clamp(1.0 - sunAlt * 2.0, 0.0, 1.0);
    rayleighColor = mix(rayleighColor, vec3(0.7, 0.35, 0.15), sunsetShift * 0.6);

    // Optical depth: thicker at horizon (Preetham approximation)
    float opticalDepth = 1.0 / (cosTheta + 0.15 * pow(93.885 - degrees(acos(cosTheta)), -1.253));
    opticalDepth = min(opticalDepth, 40.0);

    vec3 rayleigh = rayleighColor * rayleighPhase * exp(-opticalDepth * 0.1 * airDensity);

    // Mie forward scattering (Henyey-Greenstein, g=0.76)
    // dustDensity modulates haze/glow intensity (default 1.0)
    float g = 0.76;
    float miePhase = 1.5 * ((1.0 - g*g) / (2.0 + g*g))
                   * (1.0 + cosGamma*cosGamma) / pow(1.0 + g*g - 2.0*g*cosGamma, 1.5);
    vec3 mie = sunTint * miePhase * 0.02 * dustDensity;

    float sunInt = clamp(sunAlt * 3.0 + 0.3, 0.05, 1.0);
    vec3 clearSky = (rayleigh + mie) * sunInt * ambColor * 2.0;

    // Sun disk: angular radius from Blender's sun_size (default 0.009512 rad ≈ 0.545°)
    // cosAngle threshold for the disk edge
    float cosHalfAngle = cos(sunSize * 0.5);
    // Sharp disk + softer glow using sun_size-derived exponents
    float diskSharpness = 1.0 / max(1.0 - cosHalfAngle, 1e-5);
    float diskFactor = clamp((cosGamma - cosHalfAngle) * diskSharpness, 0.0, 1.0);
    clearSky += sunTint * diskFactor * diskFactor * 5.0;
    // Wider glow (corona), scales with dust density
    clearSky += sunTint * pow(max(cosGamma, 0.0), 16.0) * 0.4 * dustDensity;

    // Horizon haze — continuous with scene fog
    vec3 fogColor = ambColor * 0.6 + sunTint * 0.3 + vec3(0.1);
    fogColor = mix(fogColor, vec3(dot(fogColor, vec3(0.33))), 0.3);
    float hazeT = 1.0 - smoothstep(0.0, 0.25, dir.y);
    clearSky = mix(clearSky, fogColor * sunInt, hazeT * 0.8 * dustDensity);

    return max(clearSky, vec3(0.0));
}

vec2 directionToEquirectangular(vec3 dir) {
    // Match Cycles' equirectangular mapping (Z-up → our Y-up):
    // Cycles: u = atan2(cy, cx) / (-2*PI) + 0.5  where cx=dir.x, cy=dir.y (Z-up)
    // Our Y-up: Cycles.x = our.x, Cycles.y = -our.z, Cycles.z = our.y
    float phi = atan(-dir.z, dir.x);
    float u = 0.5 - phi / (2.0 * PI);
    float v = acos(clamp(dir.y, -1.0, 1.0)) / PI;
    return vec2(u, v);
}

vec3 evaluateSky(vec3 dir) {
    // HDRI environment map: sample equirectangular texture if available
    int hdriIdx = int(cam.windParams.x);
    if (hdriIdx >= 0) {
        float hdriStrength = cam.windParams.y;
        vec2 uv = directionToEquirectangular(dir);
        // Sample HDRI — float16 texture preserves full HDR range natively
        vec3 hdriColor = texture(textures[nonuniformEXT(uint(hdriIdx))], uv).rgb;

        return hdriColor * hdriStrength;
    }

    // Fallback: procedural sky
    float sunIntensitySky = cam.sunLight.w;

    // No sun in scene → return World background color from Blender's
    // World → Surface → Background node (color × strength).
    // Default is 0.05 gray (set in ignis_config.h when no World exists).
    if (sunIntensitySky <= 0.0) {
        return vec3(cam.windParams.z, cam.windParams.w, cam.rainParams.w);
    }

    vec3 sunDir = normalize(cam.sunLight.xyz);
    vec3 ambColor = cam.ambientLight.rgb;
    vec3 sunTint = cam.skyLight.rgb;

    // Sky Texture atmosphere properties (from jitterPattern[2..3])
    float skyAirDensity = intBitsToFloat(cam.jitterPattern[2].z);
    float skyDustDensity = intBitsToFloat(cam.jitterPattern[2].w);
    float skySunSize = intBitsToFloat(cam.jitterPattern[2].x);
    if (skyAirDensity <= 0.0) skyAirDensity = 1.0;
    if (skyDustDensity <= 0.0) skyDustDensity = 1.0;
    if (skySunSize <= 0.0) skySunSize = 0.009512;

    // Fallback for zero-initialized colors
    if (dot(ambColor, ambColor) < 0.001) ambColor = vec3(0.5, 0.6, 0.8);
    if (dot(sunTint, sunTint) < 0.001) sunTint = vec3(1.0, 0.92, 0.85);

    if (dir.y > 0.0) {
        return proceduralSky(dir, sunDir, ambColor, sunTint, skyAirDensity, skyDustDensity, skySunSize);
    } else {
        // Below horizon: dark ground fading to horizon fog
        vec3 fogColor = ambColor * 0.6 + sunTint * 0.3 + vec3(0.1);
        fogColor = mix(fogColor, vec3(dot(fogColor, vec3(0.33))), 0.3);
        float sunInt = clamp(sunDir.y * 3.0 + 0.3, 0.05, 1.0);
        float groundT = clamp(-dir.y * 5.0, 0.0, 1.0);
        return mix(fogColor * sunInt, ambColor * 0.15, groundT);
    }
}

// ============================================================
// Henyey-Greenstein Phase Function (for Volume Scatter)
// ============================================================

// Evaluate HG phase function value (for NEE in volumes)
float henyeyGreensteinPhase(float cosTheta, float g) {
    if (abs(g) < 1e-4) return 0.25 * INV_PI;  // isotropic
    float g2 = g * g;
    float denom = 1.0 + g2 - 2.0 * g * cosTheta;
    return (1.0 - g2) / (4.0 * PI * denom * sqrt(denom));
}

// Importance-sample HG phase function, returns new direction
vec3 sampleHenyeyGreenstein(vec3 inDir, float g) {
    vec2 xi = rand2();
    float cosTheta;
    if (abs(g) < 1e-4) {
        cosTheta = 1.0 - 2.0 * xi.x;
    } else {
        float k = (1.0 - g * g) / (1.0 - g + 2.0 * g * xi.x);
        cosTheta = (1.0 + g * g - k * k) / (2.0 * g);
    }
    float sinTheta = sqrt(max(0.0, 1.0 - cosTheta * cosTheta));
    float phi = 2.0 * PI * xi.y;
    // Build orthonormal basis around incoming direction
    vec3 w = inDir;
    vec3 u = abs(w.y) < 0.999 ? normalize(cross(w, vec3(0, 1, 0))) : normalize(cross(w, vec3(1, 0, 0)));
    vec3 v = cross(w, u);
    return normalize(u * (cos(phi) * sinTheta) + v * (sin(phi) * sinTheta) + w * cosTheta);
}

// ============================================================
// PBR Material Evaluation for Blender Principled BSDF
// ============================================================

struct PBRHit {
    vec3  baseColor;
    float roughness;
    float metallic;
    float specularLevel;
    vec3  emission;
    vec3  worldPos;
    vec3  worldNormal;
    float hitDist;
    float alpha;
    float ior;
    float transmission;
    float hairShift;
    float hairRadialRoughness;
};

vec3 cyclesPrincipledTransmissionTint(vec3 baseColor)
{
    // Cycles Principled transmission tints the transmitted lobe with
    // sqrt(clamped_base_color).
    // Blender reference:
    // - intern/cycles/kernel/osl/shaders/node_principled_bsdf.osl
    //   TransmissionBSDF = generalized_schlick_bsdf(..., sqrt(clamped_base_color), ...)
    return sqrt(clamp(baseColor, vec3(0.0), vec3(1.0)));
}

PBRHit evaluateBlenderMaterial(
    Material mat, uint matIdx,
    vec3 worldPos, vec3 geoNormal,
    vec3 v0, vec3 v1, vec3 v2,
    vec2 uv0, vec2 uv1, vec2 uv2,
    vec2 uv, vec3 rayDir,
    vec4 vertexColor,
    uint instanceId,
    vec3 localPos
) {
    PBRHit hit;
    hit.worldPos = worldPos;
    hit.roughness = clamp(mat.ksSpecularEXP, 0.01, 1.0);
    hit.metallic = clamp(mat.fresnelC, 0.0, 1.0);
    hit.specularLevel = mat.fresnelEXP;
    hit.hairShift = ((mat.flags & MAT_FLAG_HAIR) != 0u) ? mat.sunSpecular : 0.035;
    hit.hairRadialRoughness = ((mat.flags & MAT_FLAG_HAIR) != 0u) ?
                              clamp(mat.sunSpecularEXP, 0.01, 1.0) :
                              hit.roughness;

    // If material has stochastic passthrough, disable glass refraction.
    // Passthrough handles transparency; remaining rays do reflection (metallic=1).
    float tpCheck = mat.multB;
    hit.transmission = (tpCheck > 0.0) ? 0.0 : mat.multR;
    hit.ior = mat.detailUVMultiplier;
    // transmission already set above (with passthrough override)

    // ── Node VM: per-pixel node tree evaluation ──
    // Skip VM call entirely when material has no bytecode (instrCount == 0).
    // This avoids function call + 20-field struct init for simple materials.
    uint vmInstrCount = mat.nodeVmHeader & 0xFFu;
    bool vmActive = vmInstrCount > 0u;
    NodeVmResult vm;
    if (vmActive) {
        vm = executeNodeVm(matIdx, uv, worldPos, rayDir, geoNormal, vertexColor, uint(instanceId), localPos);
    } else {
        // Minimal init — only flags that are checked below
        vm.hasBaseColor = false;
        vm.hasRoughness = false;
        vm.hasMetallic = false;
        vm.hasEmission = false;
        vm.hasAlpha = false;
        vm.hasIor = false;
        vm.hasTransmission = false;
        vm.hasTransformedUV = false;
        vm.hasNormalStrength = false;
        vm.hasBump = false;
    }

    // ── Material evaluation: VM is the single authority ──
    // VM always runs. When it provides a property, that's final.
    // Legacy pipeline only fills in what the VM doesn't provide.
    float texAlpha = 1.0;
    vec2 texUV = (vmActive && vm.hasTransformedUV) ? vm.transformedUV : uv;

    if (vmActive && vm.hasBaseColor) {
        // VM provided base color (texture sampling, ColorRamp, Mix, etc.)
        hit.baseColor = vm.baseColor;
        // Alpha: read from legacy diffuse texture (VM doesn't extract alpha
        // because intermediate nodes like Mix/ColorRamp don't preserve .w)
        if (vm.hasAlpha) {
            texAlpha = vm.alpha;
        } else if (mat.diffuseTexIndex != 0xFFFFFFFFu) {
            texAlpha = texture(textures[nonuniformEXT(mat.diffuseTexIndex)], texUV).a;
        } else if (mat.detailTexIndex != 0xFFFFFFFFu) {
            texAlpha = texture(textures[nonuniformEXT(mat.detailTexIndex)], texUV).a;
        }
    } else {
        // No VM or VM didn't compile base color — legacy fallback
        if (mat.diffuseTexIndex != 0xFFFFFFFFu) {
            vec4 texColor = texture(textures[nonuniformEXT(mat.diffuseTexIndex)], uv);
            bool diffuseIsSceneLinear = (mat.flags & MAT_FLAG_DIFFUSE_SCENE_LINEAR) != 0u;
            hit.baseColor = diffuseIsSceneLinear ?
                            texColor.rgb :
                            srgbToLinearExact(max(texColor.rgb, vec3(0.0)));
            texAlpha = texColor.a;  // alpha stays linear
        } else {
            hit.baseColor = vec3(mat.ksAmbient, mat.ksDiffuse, mat.ksSpecular);
            if (mat.detailTexIndex != 0xFFFFFFFFu) {
                texAlpha = texture(textures[nonuniformEXT(mat.detailTexIndex)], uv).a;
            }
        }
        // Hue/Saturation/Value adjustment (legacy path only)
        float colorValue = mat.detailNMMult;
        float colorSaturation = mat.detailNMMultV;
        if (colorValue != 1.0 || colorSaturation != 1.0) {
            hit.baseColor *= colorValue;
            if (colorSaturation < 1.0) {
                float lum = dot(hit.baseColor, vec3(0.2126, 0.7152, 0.0722));
                hit.baseColor = mix(vec3(lum), hit.baseColor, colorSaturation);
            }
        }
    }
    hit.alpha = texAlpha * mat.multG;

    // VM overrides for roughness/metallic/etc.
    if (vmActive) {
        if (vm.hasRoughness)    hit.roughness = clamp(vm.roughness, 0.01, 1.0);
        if (vm.hasMetallic)     hit.metallic = clamp(vm.metallic, 0.0, 1.0);
        if (vm.hasIor)          hit.ior = vm.ior;
        if (vm.hasTransmission) hit.transmission = vm.transmission;
    }

    // ORM map: R=occlusion, G=roughness, B=metallic (standard convention)
    // Read per-channel: VM overrides individual channels, ORM fills the rest
    if (mat.mapsTexIndex != 0xFFFFFFFFu) {
        vec4 orm = texture(textures[nonuniformEXT(mat.mapsTexIndex)], texUV);
        if (!(vmActive && vm.hasRoughness)) hit.roughness = clamp(orm.g, 0.01, 1.0);
        if (!(vmActive && vm.hasMetallic))  hit.metallic = clamp(orm.b, 0.0, 1.0);
    }

    // Normal map
    vec3 N = geoNormal;
    if (mat.normalTexIndex != 0xFFFFFFFFu) {
        vec3 T, B;
        computeTBN(v0, v1, v2, uv0, uv1, uv2, N, T, B);
        float rawStrength = mat.detailNormalBlend;

        if (rawStrength < 0.0) {
            // Negative strength = bump/height map (Cycles-style)
            // Cycles formula (svm_node_set_bump in displace.h):
            //   Rx = cross(dP.dy, N), Ry = cross(N, dP.dx)
            //   det = dot(dP.dx, Rx)
            //   surfgrad = (h_x - h_c) * Rx + (h_y - h_c) * Ry
            //   N' = normalize(|det| * N - distance * sign(det) * surfgrad)
            //   N_final = normalize(strength * N' + (1 - strength) * N)

            // Decode packed: abs(rawStrength) = strength + distance * 100
            // e.g. Strength=0.06, Distance=0.1 → 0.06 + 10.0 = 10.06
            float packed = abs(rawStrength);
            float bumpDistance = floor(packed) / 100.0;  // 10 / 100 = 0.1
            float bumpStrength = fract(packed);          // 0.06

            ivec2 texDim = textureSize(textures[nonuniformEXT(mat.normalTexIndex)], 0);
            float texelSize = 1.0 / float(max(texDim.x, texDim.y));
            float h_c = texture(textures[nonuniformEXT(mat.normalTexIndex)], texUV).r;
            float h_x = texture(textures[nonuniformEXT(mat.normalTexIndex)], texUV + vec2(texelSize, 0)).r;
            float h_y = texture(textures[nonuniformEXT(mat.normalTexIndex)], texUV + vec2(0, texelSize)).r;

            // Cycles uses ray differentials to auto-scale bump. Without them,
            // we normalize T/B and use a scale that approximates Cycles' result.
            // The per-texel height differences are very small, so we amplify by
            // sqrt(texDim) which approximates the dP/texel relationship.
            vec3 Tn = normalize(T);
            vec3 Bn = normalize(B);
            float texScale = pow(float(max(texDim.x, texDim.y)), 0.65);
            vec3 surfgrad = (h_x - h_c) * Tn + (h_y - h_c) * Bn;

            // Cycles: N' = normalize(N - distance * surfgrad_scaled)
            vec3 bumpN = normalize(N - bumpDistance * texScale * surfgrad);

            // Cycles: N_final = normalize(strength * N' + (1-strength) * N)
            N = normalize(bumpStrength * bumpN + (1.0 - bumpStrength) * N);
        } else {
            // Positive strength = RGB normal map
            vec3 texN = texture(textures[nonuniformEXT(mat.normalTexIndex)], texUV).rgb;
            float strength = rawStrength > 0.0 ? rawStrength : 1.0;
            N = applyNormalMap(texN, T, N, B, strength);
        }
    }
    // Procedural bump from VM (Noise Texture → Bump)
    if (vmActive && vm.hasBump) {
        vec3 T, B;
        computeTBN(v0, v1, v2, uv0, uv1, uv2, N, T, B);
        vec3 Tn = normalize(T);
        vec3 Bn = normalize(B);
        vec3 surfgrad = vm.bumpGradient.x * Tn + vm.bumpGradient.y * Bn;
        vec3 bumpN = normalize(N - vm.bumpDistance * surfgrad);
        N = normalize(vm.bumpStrength * bumpN + (1.0 - vm.bumpStrength) * N);
    }

    hit.worldNormal = N;

    // Emission (with optional emission texture)
    // Multiply by PI to compensate the BRDF's 1/PI diffuse term in indirect
    // bounces, so emission_strength=1 matches Cycles perceived brightness.
    if (vmActive && vm.hasEmission) {
        // VM compiled emission (includes texture sampling + strength)
        hit.emission = vm.emission * PI;
    } else {
        vec3 emissionColor = vec3(mat.emissiveR, mat.emissiveG, mat.emissiveB);
        if (mat.detailTexIndex != 0xFFFFFFFFu) {
            vec3 emTex = texture(textures[nonuniformEXT(mat.detailTexIndex)], uv).rgb;
            // If scalar emission is black but texture exists, use texture directly
            // (Blender Emission Color default is black when texture provides the color)
            if (dot(emissionColor, emissionColor) < 0.001) {
                emissionColor = emTex;
            } else {
                emissionColor *= emTex;
            }
        }
        hit.emission = emissionColor * mat.fresnelMaxLevel * PI;
    }

    return hit;
}

PBRHit evaluateShadowMaterial(
    Material mat, uint matIdx,
    GeometryMetadata geo, int primId,
    vec3 bary, mat4x3 objToWorld,
    vec3 rayDir, uint instanceId
) {
    Indices idx = Indices(geo.indexBufferAddress);
    Vertices verts = Vertices(geo.vertexBufferAddress);
    uint i0 = idx.i[primId * 3 + 0];
    uint i1 = idx.i[primId * 3 + 1];
    uint i2 = idx.i[primId * 3 + 2];

    vec3 lp0 = vec3(verts.v[i0*3], verts.v[i0*3+1], verts.v[i0*3+2]);
    vec3 lp1 = vec3(verts.v[i1*3], verts.v[i1*3+1], verts.v[i1*3+2]);
    vec3 lp2 = vec3(verts.v[i2*3], verts.v[i2*3+1], verts.v[i2*3+2]);
    vec3 localPos = lp0 * bary.x + lp1 * bary.y + lp2 * bary.z;

    vec3 wp0 = objToWorld * vec4(lp0, 1.0);
    vec3 wp1 = objToWorld * vec4(lp1, 1.0);
    vec3 wp2 = objToWorld * vec4(lp2, 1.0);
    vec3 worldPos = objToWorld * vec4(localPos, 1.0);
    vec3 geoNormal = normalize(cross(wp1 - wp0, wp2 - wp0));

    vec2 uv0 = vec2(0.0);
    vec2 uv1 = vec2(0.0);
    vec2 uv2 = vec2(0.0);
    vec2 hitUV = vec2(0.0);
    if (geo.uvBufferAddress != 0u) {
        UVs uvData = UVs(geo.uvBufferAddress);
        uv0 = vec2(uvData.uv[i0*2+0], 1.0 - uvData.uv[i0*2+1]);
        uv1 = vec2(uvData.uv[i1*2+0], 1.0 - uvData.uv[i1*2+1]);
        uv2 = vec2(uvData.uv[i2*2+0], 1.0 - uvData.uv[i2*2+1]);
        hitUV = uv0 * bary.x + uv1 * bary.y + uv2 * bary.z;
    }

    vec4 hitVertexColor = vec4(1.0);
    if (geo.colorBufferAddress != 0u) {
        Colors colorData = Colors(geo.colorBufferAddress);
        vec4 vc0 = vec4(colorData.c[i0*4+0], colorData.c[i0*4+1], colorData.c[i0*4+2], colorData.c[i0*4+3]);
        vec4 vc1 = vec4(colorData.c[i1*4+0], colorData.c[i1*4+1], colorData.c[i1*4+2], colorData.c[i1*4+3]);
        vec4 vc2 = vec4(colorData.c[i2*4+0], colorData.c[i2*4+1], colorData.c[i2*4+2], colorData.c[i2*4+3]);
        hitVertexColor = vc0 * bary.x + vc1 * bary.y + vc2 * bary.z;
    }

    return evaluateBlenderMaterial(
        mat, matIdx, worldPos, geoNormal,
        wp0, wp1, wp2, uv0, uv1, uv2, hitUV, rayDir,
        hitVertexColor, instanceId, localPos
    );
}

vec3 evaluateShadowMaterialTransmittance(
    Material mat, uint matIdx,
    GeometryMetadata geo, int primId,
    vec3 bary, mat4x3 objToWorld,
    vec3 rayDir, uint instanceId
) {
    if ((mat.flags & MAT_FLAG_LIGHTPATH_TRANSPARENT) != 0u) {
        return vec3(1.0);
    }

    if ((mat.flags & 4u) != 0u) {
        return vec3(1.0); // Volumes remain non-blocking in shadow queries.
    }

    uint vmHeaderFlags = (mat.nodeVmHeader >> 8u) & 0xFFu;
    bool vmShadowDynamic = (vmHeaderFlags & VM_HEADER_FLAG_SHADOW_DYNAMIC) != 0u;
    bool alphaDynamic =
        ((vmHeaderFlags & VM_HEADER_FLAG_ALPHA) != 0u && vmShadowDynamic) ||
        ((mat.flags & 1u) != 0u && mat.diffuseTexIndex != 0xFFFFFFFFu);

    // Cycles shadow transparency only follows actual transparent closures, not
    // plain Principled transmission/glass closures:
    // - intern/cycles/kernel/integrator/surface_shader.h:948
    // - intern/cycles/scene/shader_nodes.cpp:2815
    // That means solid glass should still block shadow rays unless Alpha or a
    // Transparent closure makes the surface transparent to shadows.
    float transparentProb = clamp(mat.multB, 0.0, 1.0);
    if ((mat.flags & 1u) == 0u && transparentProb <= 0.0) {
        return vec3(0.0);
    }

    if (!alphaDynamic) {
        float alpha = clamp(mat.multG, 0.0, 1.0);
        float passThrough = 1.0 - alpha * (1.0 - transparentProb);
        return vec3(clamp(passThrough, 0.0, 1.0));
    }

    // Fast texture-only alpha for shadow rays: sample the alpha-bearing texture
    // directly instead of running the full Node VM.  Saves vertex transforms,
    // normal computation, vertex color interpolation, and all VM instructions
    // that compute base color / emission / other properties we don't need here.
    uint alphaTexIdx = mat.diffuseTexIndex;
    if (alphaTexIdx == 0xFFFFFFFFu) alphaTexIdx = mat.detailTexIndex;
    if (alphaTexIdx != 0xFFFFFFFFu && geo.uvBufferAddress != 0u) {
        Indices aIdx = Indices(geo.indexBufferAddress);
        UVs aUVs = UVs(geo.uvBufferAddress);
        uint ai0 = aIdx.i[primId * 3 + 0];
        uint ai1 = aIdx.i[primId * 3 + 1];
        uint ai2 = aIdx.i[primId * 3 + 2];
        vec2 aUV = vec2(aUVs.uv[ai0*2], 1.0 - aUVs.uv[ai0*2+1]) * bary.x
                 + vec2(aUVs.uv[ai1*2], 1.0 - aUVs.uv[ai1*2+1]) * bary.y
                 + vec2(aUVs.uv[ai2*2], 1.0 - aUVs.uv[ai2*2+1]) * bary.z;
        float texAlpha = texture(textures[nonuniformEXT(alphaTexIdx)], aUV).a;
        float alpha = clamp(mat.multG * texAlpha, 0.0, 1.0);
        float passThrough = 1.0 - alpha * (1.0 - transparentProb);
        return vec3(clamp(passThrough, 0.0, 1.0));
    }

    // Fallback: full material evaluation (no texture available for fast path)
    PBRHit hit = evaluateShadowMaterial(mat, matIdx, geo, primId, bary, objToWorld, rayDir, instanceId);
    float alpha = clamp(hit.alpha, 0.0, 1.0);
    float passThrough = 1.0 - alpha * (1.0 - transparentProb);
    return vec3(clamp(passThrough, 0.0, 1.0));
}

// ============================================================
// Emissive Triangle MIS Sampling
// ============================================================

struct EmissiveSample {
    vec3 position;
    vec3 emission;
    vec3 normal;
    float pdf;
    float area;
};

// Sample an emissive triangle using CDF binary search
EmissiveSample sampleEmissiveTriangle(uint triCount, float rnd, vec2 baryRnd) {
    EmissiveSample s;
    s.pdf = 0.0;
    s.emission = vec3(0.0);
    s.normal = vec3(0, 1, 0);
    s.position = vec3(0.0);
    s.area = 0.0;

    if (triCount == 0u) return s;

    // Binary search CDF to select triangle
    uint lo = 0u, hi = triCount - 1u;
    while (lo < hi) {
        uint mid = (lo + hi) / 2u;
        float cdf = emissiveTris.data[mid * 4u + 1u].w;  // v1.w = cdf
        if (rnd <= cdf)
            hi = mid;
        else
            lo = mid + 1u;
    }
    uint idx = lo;
    uint base = idx * 4u;

    vec4 d0 = emissiveTris.data[base + 0u];  // v0.xyz, area
    vec4 d1 = emissiveTris.data[base + 1u];  // v1.xyz, cdf
    vec4 d2 = emissiveTris.data[base + 2u];  // v2.xyz, totalPower
    vec4 d3 = emissiveTris.data[base + 3u];  // emission.rgb, pad

    vec3 v0 = d0.xyz;
    vec3 v1 = d1.xyz;
    vec3 v2 = d2.xyz;
    s.area = d0.w;
    float totalPower = d2.w;
    s.emission = d3.xyz;

    // CDF probability for this triangle
    float prevCdf = (idx > 0u) ? emissiveTris.data[(idx - 1u) * 4u + 1u].w : 0.0;
    float triProb = d1.w - prevCdf;

    // Uniform barycentric sampling on triangle
    float u = baryRnd.x;
    float v = baryRnd.y;
    if (u + v > 1.0) {
        u = 1.0 - u;
        v = 1.0 - v;
    }
    s.position = v0 * (1.0 - u - v) + v1 * u + v2 * v;

    // Triangle normal (unnormalized cross product direction)
    vec3 edge1 = v1 - v0;
    vec3 edge2 = v2 - v0;
    s.normal = normalize(cross(edge1, edge2));

    // PDF = triProb / area (probability of this point on this triangle)
    s.pdf = (s.area > 0.0) ? triProb / s.area : 0.0;

    return s;
}

// ============================================================
// Main
// ============================================================

void main() {
    ivec2 pixel = ivec2(gl_LaunchIDEXT.xy);
    ivec2 launchSize = ivec2(gl_LaunchSizeEXT.xy);
    uint frameIndex = cam.parameters.x;
    int maxBounces = clamp(int(cam.parameters.z), 1, MAX_BOUNCES_LIMIT);

    // Multi-SPP: configurable samples per pixel (lightPad1 from CPU)
    int spp = clamp(int(cam.lightPad1), 1, 128);

    // Debug view modes 2-5 (Unlit, Normals, Depth, UV) only need primary hit
    uint debugViewEarly = cam.parameters.y;
    if ((debugViewEarly >= 2u && debugViewEarly <= 5u) || debugViewEarly == 7u) {
        maxBounces = 1;
        spp = 1;
    }
    bool rrModeGlobal = (cam.parameters.w == 2u);
    bool backfaceCulling = (cam.lightPad2 & 1u) != 0u;  // bit 0 of lightPad2
    bool hybridRasterMode = (cam.lightPad2 & 4u) != 0u; // bit 2 of lightPad2
    bool nircReady = (cam.lightPad2 & 16u) != 0u;       // bit 4 of lightPad2

    // Accumulators across SPP samples
    vec3 accumDiffuse = vec3(0.0);
    vec3 accumSpecular = vec3(0.0);
    vec3 accumTotalRadiance = vec3(0.0);
    vec3 accumDirectSunDiffuse = vec3(0.0);
    vec3 accumAmbientDiffuse = vec3(0.0);

    // Primary hit info (from first sample only — used for G-buffers)
    vec3 primaryNormal = vec3(0, 0, 1);
    float primaryRoughness = 1.0;
    float primaryViewZ = 1e7;
    vec3 primaryAlbedo = vec3(0.0);
    vec3 primaryWorldPos = vec3(0.0);
    float primaryHitDist = 0.0;
    float secondaryHitDist = 0.0;  // bounce 1 hit distance (for denoiser)
    bool primaryHit = false;
    vec3 primaryLocalPos = vec3(0.0);
    vec2 primaryUV = vec2(0.0);
    vec3 primaryBaseColor = vec3(0.0);
    uint primaryCustomIndex = 0u;
    int  primaryInstanceId = 0;
    float primaryPenumbra = 65504.0;
    float primaryNdotL = 0.0;
    float primaryHairV = 2.0;  // sentinel: 2.0 = not hair, [-1,1] = hair cylinder position
    bool captureSpecularMV = false;
    vec2 specularMV = vec2(0.0);
    vec3 savedRayOrigin = (cam.viewInverse * vec4(0, 0, 0, 1)).xyz;
    vec3 savedRayDir = vec3(0, 0, -1);  // updated by first sample
    float exposure = cam.ptParams0.x;
    float giIntensity = cam.ptParams0.y;

    // Shader complexity: real GPU clock ticks (when available) + operation counter fallback
    uint64_t shaderClockStart = clockARB();
    uint shaderCost = 0u;

    for (int sampleIdx = 0; sampleIdx < spp; sampleIdx++) {

    // Initialize RNG: hash pixel + frame + sample index + blue noise
    rngState = pixel.x * 1973u + pixel.y * 9277u + frameIndex * 26699u + uint(sampleIdx) * 12347u;
    pcg(rngState);

    ivec2 bnCoord = ivec2(pixel.x & 63, pixel.y & 63);
    float blueNoise = texelFetch(blueNoiseTexture, bnCoord, 0).r;
    rngState += uint(blueNoise * 4294967295.0);

    // Sub-pixel jitter (NRD mode only — DLSS RR uses Halton from projInverse)
    // Skip jitter when debug view active (no denoiser to resolve it)
    vec2 pixelCenter = vec2(pixel) + 0.5;
    if (!rrModeGlobal && cam.parameters.y < 2u) {
        pixelCenter += vec2(rand01() - 0.5, rand01() - 0.5);
    }
    vec2 uv = pixelCenter / vec2(launchSize);
    vec2 ndc = vec2(uv.x * 2.0 - 1.0, 1.0 - uv.y * 2.0);

    vec4 origin4 = cam.viewInverse * vec4(0, 0, 0, 1);
    vec4 target4 = cam.projInverse * vec4(ndc.x, ndc.y, 1, 1);
    target4.xyz /= target4.w;
    vec4 dir4 = cam.viewInverse * vec4(normalize(target4.xyz), 0);

    vec3 rayOrigin = origin4.xyz;
    vec3 rayDir = normalize(dir4.xyz);

    // ── Depth of Field ──
    float dofAperture = cam.dofParams.x;
    if (dofAperture > 0.0) {
        float dofFocusDist = cam.dofParams.y;
        float dofBlades = cam.dofParams.z;
        float dofRotation = cam.dofParams.w;
        float dofRatio = cam.dofParams2.x;

        // Sample lens aperture (circular or polygonal)
        vec2 lensRand = rand2();
        vec2 lensUV;
        if (dofBlades < 3.0) {
            // Circular disk: concentric mapping (Shirley)
            float a = 2.0 * lensRand.x - 1.0;
            float b = 2.0 * lensRand.y - 1.0;
            float r, phi;
            if (abs(a) > abs(b)) {
                r = a;
                phi = (PI / 4.0) * (b / max(abs(a), 1e-8));
            } else {
                r = b;
                phi = (PI / 2.0) - (PI / 4.0) * (a / max(abs(b), 1e-8));
            }
            lensUV = vec2(r * cos(phi), r * sin(phi));
        } else {
            // Polygonal bokeh (regular polygon sampling, matching Cycles)
            float corners = dofBlades;
            float u = lensRand.x, v = lensRand.y;
            float corner = floor(u * corners);
            u = u * corners - corner;
            u = sqrt(u);
            v = v * u;
            u = 1.0 - u;
            float angle = PI / corners;
            vec2 p = vec2((u + v) * cos(angle), (u - v) * sin(angle));
            float rot = dofRotation + corner * 2.0 * angle;
            float cr = cos(rot), sr = sin(rot);
            lensUV = vec2(cr * p.x - sr * p.y, sr * p.x + cr * p.y);
        }

        // Anamorphic distortion
        lensUV.x *= (dofRatio > 0.01 ? 1.0 / dofRatio : 1.0);

        // Scale by aperture size
        lensUV *= dofAperture;

        // Compute focal plane intersection
        // target4.xyz is the camera-space direction (before world transform)
        float ft = dofFocusDist / max(abs(target4.z), 1e-6);
        vec3 focusPoint = target4.xyz * ft;  // Camera-space focus point

        // New camera-space ray: from lens offset to focus point
        vec3 camOriginOffset = vec3(lensUV, 0.0);
        vec3 camDirDOF = normalize(focusPoint - camOriginOffset);

        // Transform to world space
        rayOrigin = (cam.viewInverse * vec4(camOriginOffset, 1.0)).xyz;
        rayDir = normalize((cam.viewInverse * vec4(camDirDOF, 0.0)).xyz);
    }

    if (sampleIdx == 0) savedRayDir = rayDir;

    // Per-sample state
    vec3 throughput = vec3(1.0);
    vec3 totalRadiance = vec3(0.0);
    vec3 diffuseRadiance = vec3(0.0);
    vec3 specularRadiance = vec3(0.0);
    vec3 directSunDiffuse = vec3(0.0);
    vec3 ambientDiffuse = vec3(0.0);
    bool isDiffusePath = true;
    // (alphaPassThrough removed — opaque rays handle all cases)
    float primaryPenumbraSample = 65504.0;
    float primaryNdotLSample = 0.0;

    // Specular motion vectors: capture reflected object MV at bounce 1
    bool captureSpecularMV = false;
    vec2 specularMV = vec2(0.0);

    float exposure = cam.ptParams0.x;
    float giIntensity = cam.ptParams0.y;

    int alphaSkips = 0;
    const int MAX_ALPHA_SKIPS = 8;
    int glassBounces = 0;
    const int MAX_GLASS_BOUNCES = 16;
    int thinTransmissionPasses = 0;
    const int MAX_THIN_TRANSMISSION_PASSES = 4;
    bool throughPrimarySpecularInterface = false;

    // ReSTIR GI reservoir for indirect lighting reuse
    // TODO: disabled for stability investigation on complex scenes
    GIReservoir reservoir = emptyReservoir();
    int pixelLinearIdx = pixel.y * launchSize.x + pixel.x;
    float reservoirRng = rand01();
    bool giReservoirEnabled = false;  // disable buffer access

    // SHARC radiance cache
    SharcGridParams sharcGrid;
    sharcGrid.cameraPosition = vec3(cam.viewInverse[3][0], cam.viewInverse[3][1], cam.viewInverse[3][2]);
    sharcGrid.sceneScale = cam.sharcSceneScale;
    SharcState sharcState;
    SharcInit(sharcState);
    bool sharcUpdatePixel = isSharcUpdatePixel(pixel, frameIndex);
    bool sharcEnabled = (cam.sharcCapacity > 0u);
    uint sharcCapacity = cam.sharcCapacity;
    vec3 prevBounceNormal = vec3(0, 1, 0);

    // Surfel GI cache (disabled until surfel quality justifies the cost)
    bool surfelEnabled = false;
    uint surfelCapacity = 1u << 20u;    // 1M entries
    SurfelGridParams surfelGrid;
    surfelGrid.cameraPosition = sharcGrid.cameraPosition;
    surfelGrid.sceneScale = cam.sharcSceneScale * SURFEL_GRID_SCALE_MULT;

    // Pre-compute sun direction and tangent frame (invariant across bounces)
    vec3 sunDir = normalize(cam.sunLight.xyz);
    float sunIntensity = cam.sunLight.w;
    vec3 sunColor = cam.skyLight.rgb;
    vec3 sunTangent = abs(sunDir.y) < 0.999
        ? normalize(cross(sunDir, vec3(0, 1, 0)))
        : normalize(cross(sunDir, vec3(1, 0, 0)));
    vec3 sunBitangent = cross(sunDir, sunTangent);

    // NRC: create context and path state for this sample
    // NRC: detect mode from dispatch resolution
    // Update pass dispatches at trainingDimensions, query pass at frameDimensions
    if (nrcConstants.maxPathVertices > 0u) {
        if (launchSize.x == int(nrcConstants.trainingDimensions.x) &&
            launchSize.y == int(nrcConstants.trainingDimensions.y)) {
            g_nrcMode = NRC_MODE_UPDATE;
            // Update pass: use deeper paths for better training data
            maxBounces = int(nrcConstants.maxPathVertices);
            spp = 1;  // single sample for training
        } else {
            g_nrcMode = NRC_MODE_QUERY;
        }
    }

    NrcBuffers nrcBufs;  // empty struct (buffers accessed via custom macros)
    NrcContext nrcCtx = NrcCreateContext(nrcConstants, nrcBufs, uvec2(pixel));
    NrcSetSampleIndex(nrcCtx, uint(sampleIdx));
    NrcPathState nrcPath = NrcCreatePathState(nrcConstants, rand01());
    bool nrcTerminated = false;

    for (int bounce = 0; bounce < maxBounces; bounce++) {
        shaderCost += 4u;  // each bounce = base cost of BVH traversal + shading

        // ── Surfel GI query (bounce 1+): surface-based irradiance cache ──
        if (surfelEnabled && bounce >= 1) {
            vec3 surfelIrradiance;
            if (surfelGetCachedIrradiance(rayOrigin, prevBounceNormal,
                                          surfelGrid, sharcCapacity, surfelIrradiance)) {
                surfelIrradiance *= giIntensity;
                if (isDiffusePath) {
                    diffuseRadiance += surfelIrradiance * throughput;
                } else {
                    specularRadiance += surfelIrradiance * throughput;
                }
                break;
            }
        }

        // ── SHARC cache query (bounce 1+): fallback if surfel miss ──
        if (sharcEnabled && bounce >= 1) {
            vec3 cachedRadiance;
            if (SharcGetCachedRadiance(sharcGrid, rayOrigin, prevBounceNormal,
                                       sharcCapacity, cachedRadiance)) {
                cachedRadiance *= giIntensity;
                if (isDiffusePath) {
                    diffuseRadiance += cachedRadiance * throughput;
                } else {
                    specularRadiance += cachedRadiance * throughput;
                }
                break;
            }
        }

        // Scene AABB early-out: if ray can't intersect scene bounds, skip
        // expensive TLAS traversal and go directly to sky evaluation.
        // AABB stored in jitterPattern[0..1] as (minX,minY,minZ,_), (maxX,maxY,maxZ,_)
        vec3 sceneMin = intBitsToFloat(cam.jitterPattern[0].xyz);
        vec3 sceneMax = intBitsToFloat(cam.jitterPattern[1].xyz);
        bool hasSceneAABB = (sceneMin.x < sceneMax.x);  // valid if min < max

        bool skipTrace = false;
        if (hasSceneAABB) {
            // Slab-based ray-AABB intersection (6 comparisons)
            vec3 invDir = 1.0 / rayDir;
            vec3 t1 = (sceneMin - rayOrigin) * invDir;
            vec3 t2 = (sceneMax - rayOrigin) * invDir;
            vec3 tNear = min(t1, t2);
            vec3 tFar = max(t1, t2);
            float tEntry = max(max(tNear.x, tNear.y), tNear.z);
            float tExit = min(min(tFar.x, tFar.y), tFar.z);
            skipTrace = (tEntry > tExit || tExit < MIN_HIT_DIST);
        }

        // ---- Hybrid G-buffer: skip primary ray when rasterized hit is available ----
        bool hybridHit = false;
        uint customIndex;
        int instanceId;
        int primitiveId;
        float hitT;
        vec3 bary;
        vec3 localPos;
        vec3 worldPos;
        vec3 wp0, wp1, wp2;
        mat4x3 objToWorld;
        rayQueryEXT rq;

        if (hybridRasterMode && bounce == 0) {
            float hViewZ = imageLoad(hybridDepthImg, pixel).r;
            if (hViewZ > 0.01 && hViewZ < 9990.0) {
                // Convert view-space Z to ray distance and add margin
                vec3 viewRayDir = mat3(cam.view) * rayDir;
                float cosAngle = max(abs(viewRayDir.z), 0.01);
                float depthHint = hViewZ / cosAngle + 0.1;

                rayQueryInitializeEXT(rq, topLevelAS, gl_RayFlagsOpaqueEXT,
                                      0xFF, rayOrigin, MIN_HIT_DIST, rayDir, depthHint);
                while (rayQueryProceedEXT(rq)) {}

                if (rayQueryGetIntersectionTypeEXT(rq, true) != gl_RayQueryCommittedIntersectionNoneEXT) {
                    customIndex = rayQueryGetIntersectionInstanceCustomIndexEXT(rq, true);
                    instanceId = rayQueryGetIntersectionInstanceIdEXT(rq, true);
                    primitiveId = rayQueryGetIntersectionPrimitiveIndexEXT(rq, true);
                    hitT = rayQueryGetIntersectionTEXT(rq, true);
                    vec2 bary2 = rayQueryGetIntersectionBarycentricsEXT(rq, true);
                    bary = vec3(1.0 - bary2.x - bary2.y, bary2.x, bary2.y);
                    hybridHit = true;
                }
            }
        }


        // ---- Standard ray query (used for secondary bounces, or when hybrid miss/fallback) ----
        if (!hybridHit) {
            if (!skipTrace) {
                rayQueryInitializeEXT(rq, topLevelAS, gl_RayFlagsOpaqueEXT,
                                      0xFF, rayOrigin, MIN_HIT_DIST, rayDir, 10000.0);
                while (rayQueryProceedEXT(rq)) {}
            }

            if (skipTrace || rayQueryGetIntersectionTypeEXT(rq, true) == gl_RayQueryCommittedIntersectionNoneEXT) {
                vec3 skyColor = evaluateSky(rayDir);
                if (sharcEnabled && sharcUpdatePixel) {
                    SharcUpdateMiss(sharcGrid, sharcState, skyColor, sharcCapacity);
                }
                NrcUpdateOnMiss(nrcPath);
                if (bounce == 0) {
                    totalRadiance += skyColor * throughput;
                } else {
                    if (isDiffusePath) {
                        diffuseRadiance += skyColor * throughput * giIntensity;
                    } else {
                        specularRadiance += skyColor * throughput * giIntensity;
                    }
                }
                break;
            }

            // Get hit info from ray query
            customIndex = rayQueryGetIntersectionInstanceCustomIndexEXT(rq, true);
            instanceId = rayQueryGetIntersectionInstanceIdEXT(rq, true);
            primitiveId = rayQueryGetIntersectionPrimitiveIndexEXT(rq, true);
            hitT = rayQueryGetIntersectionTEXT(rq, true);
            vec2 bary2 = rayQueryGetIntersectionBarycentricsEXT(rq, true);
            bary = vec3(1.0 - bary2.x - bary2.y, bary2.x, bary2.y);
        }

        // Fetch geometry data (customIndex maps to geometryMetadata array)
        GeometryMetadata geo = geometryMetadata.geometries[customIndex];
        Indices indices = Indices(geo.indexBufferAddress);
        Vertices vertices = Vertices(geo.vertexBufferAddress);
        Normals normals = Normals(geo.normalBufferAddress);
        UVs uvData = UVs(geo.uvBufferAddress);

        uint i0 = indices.i[primitiveId * 3 + 0];
        uint i1 = indices.i[primitiveId * 3 + 1];
        uint i2 = indices.i[primitiveId * 3 + 2];

        {
            // Geometry reconstruction — runs for both hybrid and standard paths.
            // In both cases, rq has valid intersection data.
            vec3 p0 = vec3(vertices.v[i0*3+0], vertices.v[i0*3+1], vertices.v[i0*3+2]);
            vec3 p1 = vec3(vertices.v[i1*3+0], vertices.v[i1*3+1], vertices.v[i1*3+2]);
            vec3 p2 = vec3(vertices.v[i2*3+0], vertices.v[i2*3+1], vertices.v[i2*3+2]);
            localPos = p0 * bary.x + p1 * bary.y + p2 * bary.z;
            objToWorld = rayQueryGetIntersectionObjectToWorldEXT(rq, true);
            worldPos = (objToWorld * vec4(localPos, 1.0));
            wp0 = (objToWorld * vec4(p0, 1.0));
            wp1 = (objToWorld * vec4(p1, 1.0));
            wp2 = (objToWorld * vec4(p2, 1.0));
        }

        // Normals
        vec3 n0 = vec3(normals.n[i0*3+0], normals.n[i0*3+1], normals.n[i0*3+2]);
        vec3 n1 = vec3(normals.n[i1*3+0], normals.n[i1*3+1], normals.n[i1*3+2]);
        vec3 n2 = vec3(normals.n[i2*3+0], normals.n[i2*3+1], normals.n[i2*3+2]);
        vec3 localN = normalize(n0 * bary.x + n1 * bary.y + n2 * bary.z);
        vec3 worldN = normalize(mat3(objToWorld) * localN);

        // Shadow terminator fix: only correct normals that cross below the geometric plane.
        // Positive NdotNg = valid (even at grazing angles). Negative = below surface = fix.
        vec3 geoNormalRaw = normalize(cross(wp1 - wp0, wp2 - wp0)); // true triangle normal
        vec3 geoNormal = geoNormalRaw;
        if (dot(geoNormal, -rayDir) < 0.0) geoNormal = -geoNormal; // flip toward camera
        // Save smooth-interpolated normal BEFORE normal map — used for glass refraction.
        // Smooth shading should affect refraction (the surface IS smooth),
        // but normal maps should NOT (they're detail perturbation, not geometry).
        vec3 smoothN = worldN;

        // DISABLED: edge-on skip (for diagnostic)
        // if (geo.bitangentBufferAddress != 0u) {
        //     float edgeFacing = abs(dot(geoNormalRaw, -rayDir));
        //     if (edgeFacing < 0.2) {
        //         rayOrigin = worldPos + rayDir * 0.001;
        //         bounce--;
        //         continue;
        //     }
        // }

        // Hair: save values from packed normals BEFORE cylindrical override
        float hairV = 0.0;
        vec3 hairSmoothT = vec3(1, 0, 0);
        vec3 hairMacroN = geoNormalRaw;
        vec3 hairShadePos = worldPos;
        uint hairStrandId = INVALID_HAIR_STRAND;
        bool isHairHit = false;

        if (geo.bitangentBufferAddress != 0u) {
            isHairHit = true;
            // Decode packed data from RAW interpolation (NOT normalized!)
            vec3 rawN = vec3(normals.n[i0*3+0], normals.n[i0*3+1], normals.n[i0*3+2]) * bary.x
                      + vec3(normals.n[i1*3+0], normals.n[i1*3+1], normals.n[i1*3+2]) * bary.y
                      + vec3(normals.n[i2*3+0], normals.n[i2*3+1], normals.n[i2*3+2]) * bary.z;
            vec3 localTangent = octDecode(vec2(rawN.y, rawN.z));
            hairSmoothT = normalize(mat3(objToWorld) * localTangent);

            // Find center LINE of the ribbon and compute v as perpendicular distance.
            // 1. Find same-cross-section left/right pair (opposite v, consecutive indices)
            // 2. Their midpoint = a point ON the center line
            // 3. Center line direction = hair tangent
            // 4. v = perpendicular distance from hit to center line / half-width
            float nv0 = normals.n[i0*3];
            float nv1 = normals.n[i1*3];
            float nv2 = normals.n[i2*3];
            vec3 centerPt;
            vec3 widthEdge;
            vec3 otherWidthEdge;
            bool found = false;
            if (!found && nv0 * nv2 < 0.0 && abs(int(i0) - int(i2)) == 1) {
                centerPt = (wp0 + wp2) * 0.5; widthEdge = wp2 - wp0; found = true;
            }
            if (!found && nv0 * nv1 < 0.0 && abs(int(i0) - int(i1)) == 1) {
                centerPt = (wp0 + wp1) * 0.5; widthEdge = wp1 - wp0; found = true;
            }
            if (!found && nv1 * nv2 < 0.0 && abs(int(i1) - int(i2)) == 1) {
                centerPt = (wp1 + wp2) * 0.5; widthEdge = wp2 - wp1; found = true;
            }
            if (!found) {
                centerPt = (wp0 + wp1 + wp2) / 3.0;
                widthEdge = wp2 - wp0;
            }

            // Read the ADJACENT triangle to get BOTH centers → exact center line
            uint adjPrimId = (primitiveId % 2u == 0u) ? uint(primitiveId) + 1u : uint(primitiveId) - 1u;
            uint adj_i0 = indices.i[adjPrimId * 3u + 0u];
            uint adj_i1 = indices.i[adjPrimId * 3u + 1u];
            uint adj_i2 = indices.i[adjPrimId * 3u + 2u];

            vec3 adj_p0 = vec3(vertices.v[adj_i0*3u], vertices.v[adj_i0*3u+1u], vertices.v[adj_i0*3u+2u]);
            vec3 adj_p1 = vec3(vertices.v[adj_i1*3u], vertices.v[adj_i1*3u+1u], vertices.v[adj_i1*3u+2u]);
            vec3 adj_p2 = vec3(vertices.v[adj_i2*3u], vertices.v[adj_i2*3u+1u], vertices.v[adj_i2*3u+2u]);
            vec3 adj_wp0 = (objToWorld * vec4(adj_p0, 1.0));
            vec3 adj_wp1 = (objToWorld * vec4(adj_p1, 1.0));
            vec3 adj_wp2 = (objToWorld * vec4(adj_p2, 1.0));

            // Find adjacent triangle's same-cross-section center
            float adj_nv0 = normals.n[adj_i0*3u];
            float adj_nv1 = normals.n[adj_i1*3u];
            float adj_nv2 = normals.n[adj_i2*3u];
            vec3 otherCenter = (adj_wp0 + adj_wp1 + adj_wp2) / 3.0;  // fallback
            otherWidthEdge = adj_wp2 - adj_wp0;
            if (adj_nv0 * adj_nv2 < 0.0 && abs(int(adj_i0)-int(adj_i2)) == 1)
            {
                otherCenter = (adj_wp0 + adj_wp2) * 0.5;
                otherWidthEdge = adj_wp2 - adj_wp0;
            }
            else if (adj_nv0 * adj_nv1 < 0.0 && abs(int(adj_i0)-int(adj_i1)) == 1)
            {
                otherCenter = (adj_wp0 + adj_wp1) * 0.5;
                otherWidthEdge = adj_wp1 - adj_wp0;
            }
            else if (adj_nv1 * adj_nv2 < 0.0 && abs(int(adj_i1)-int(adj_i2)) == 1)
            {
                otherCenter = (adj_wp1 + adj_wp2) * 0.5;
                otherWidthEdge = adj_wp2 - adj_wp1;
            }

            bool haveHairSections = false;
            vec3 sec0a, sec0b, sec0c, sec0d;
            vec3 sec1a, sec1b, sec1c, sec1d;
            vec3 prevSecA, prevSecB, prevSecC, prevSecD;
            vec3 nextSecA, nextSecB, nextSecC, nextSecD;
            vec3 prevCenter = centerPt;
            vec3 nextCenter = otherCenter;
            bool havePrevCenter = false;
            bool haveNextCenter = false;
            bool havePrevSection = false;
            bool haveNextSection = false;
            uint strandCount, vertsPerStrand, trisPerStrand;
            uint segId = 0u;
            if (getHairRibbonLayout(geo, strandCount, vertsPerStrand, trisPerStrand)) {
                hairStrandId = uint(primitiveId) / trisPerStrand;
                uint localPrimId = uint(primitiveId) % trisPerStrand;
                segId = localPrimId / 4u;
                uint strandBase = hairStrandId * vertsPerStrand;
                uint strandEnd = strandBase + vertsPerStrand;
                uint section0Base = hairStrandId * vertsPerStrand + segId * 4u;
                uint section1Base = section0Base + 4u;
                if (section1Base + 3u < geo.vertexCount) {
                    sec0a = fetchHairVertexWorld(vertices, objToWorld, section0Base + 0u);
                    sec0b = fetchHairVertexWorld(vertices, objToWorld, section0Base + 1u);
                    sec0c = fetchHairVertexWorld(vertices, objToWorld, section0Base + 2u);
                    sec0d = fetchHairVertexWorld(vertices, objToWorld, section0Base + 3u);
                    sec1a = fetchHairVertexWorld(vertices, objToWorld, section1Base + 0u);
                    sec1b = fetchHairVertexWorld(vertices, objToWorld, section1Base + 1u);
                    sec1c = fetchHairVertexWorld(vertices, objToWorld, section1Base + 2u);
                    sec1d = fetchHairVertexWorld(vertices, objToWorld, section1Base + 3u);
                    centerPt = (sec0a + sec0b + sec0c + sec0d) * 0.25;
                    otherCenter = (sec1a + sec1b + sec1c + sec1d) * 0.25;
                    widthEdge = (sec0b - sec0a) + (sec0d - sec0c);
                    otherWidthEdge = (sec1b - sec1a) + (sec1d - sec1c);
                    haveHairSections = true;

                    if (segId > 0u && section0Base >= strandBase + 4u) {
                        uint prevSectionBase = section0Base - 4u;
                        prevSecA = fetchHairVertexWorld(vertices, objToWorld, prevSectionBase + 0u);
                        prevSecB = fetchHairVertexWorld(vertices, objToWorld, prevSectionBase + 1u);
                        prevSecC = fetchHairVertexWorld(vertices, objToWorld, prevSectionBase + 2u);
                        prevSecD = fetchHairVertexWorld(vertices, objToWorld, prevSectionBase + 3u);
                        prevCenter = (prevSecA + prevSecB + prevSecC + prevSecD) * 0.25;
                        havePrevCenter = true;
                        havePrevSection = true;
                    }
                    if (section1Base + 7u < strandEnd) {
                        uint nextSectionBase = section1Base + 4u;
                        nextSecA = fetchHairVertexWorld(vertices, objToWorld, nextSectionBase + 0u);
                        nextSecB = fetchHairVertexWorld(vertices, objToWorld, nextSectionBase + 1u);
                        nextSecC = fetchHairVertexWorld(vertices, objToWorld, nextSectionBase + 2u);
                        nextSecD = fetchHairVertexWorld(vertices, objToWorld, nextSectionBase + 3u);
                        nextCenter = (nextSecA + nextSecB + nextSecC + nextSecD) * 0.25;
                        haveNextCenter = true;
                        haveNextSection = true;
                    }
                }
            }

            vec3 chordAxis = otherCenter - centerPt;
            float chordLen = length(chordAxis);
            vec3 chordT = (chordLen > 1e-8) ? chordAxis / chordLen : hairSmoothT;
            vec3 hairGeomT = chordT;
            if (havePrevCenter && haveNextCenter) {
                vec3 smoothAxis = nextCenter - prevCenter;
                float smoothLen = length(smoothAxis);
                if (smoothLen > 1e-8) hairGeomT = smoothAxis / smoothLen;
            } else if (havePrevCenter) {
                vec3 prevAxis = otherCenter - prevCenter;
                float prevLen = length(prevAxis);
                if (prevLen > 1e-8) hairGeomT = prevAxis / prevLen;
            } else if (haveNextCenter) {
                vec3 nextAxis = nextCenter - centerPt;
                float nextLen = length(nextAxis);
                if (nextLen > 1e-8) hairGeomT = nextAxis / nextLen;
            }
            if (length(hairGeomT) < 1e-6) hairGeomT = hairSmoothT;

            float radius0;
            float radius1;
            if (haveHairSections) {
                vec3 sec0o0 = sec0a - centerPt - hairGeomT * dot(sec0a - centerPt, hairGeomT);
                vec3 sec0o1 = sec0b - centerPt - hairGeomT * dot(sec0b - centerPt, hairGeomT);
                vec3 sec0o2 = sec0c - centerPt - hairGeomT * dot(sec0c - centerPt, hairGeomT);
                vec3 sec0o3 = sec0d - centerPt - hairGeomT * dot(sec0d - centerPt, hairGeomT);
                vec3 sec1o0 = sec1a - otherCenter - hairGeomT * dot(sec1a - otherCenter, hairGeomT);
                vec3 sec1o1 = sec1b - otherCenter - hairGeomT * dot(sec1b - otherCenter, hairGeomT);
                vec3 sec1o2 = sec1c - otherCenter - hairGeomT * dot(sec1c - otherCenter, hairGeomT);
                vec3 sec1o3 = sec1d - otherCenter - hairGeomT * dot(sec1d - otherCenter, hairGeomT);
                radius0 = max((length(sec0o0) + length(sec0o1) + length(sec0o2) + length(sec0o3)) * 0.25, 1e-6);
                radius1 = max((length(sec1o0) + length(sec1o1) + length(sec1o2) + length(sec1o3)) * 0.25, 1e-6);
                if (length(widthEdge) < 1e-6) widthEdge = sec0b - sec0a;
            } else {
                radius0 = max(length(widthEdge) * 0.5, 1e-6);
                radius1 = max(length(otherWidthEdge) * 0.5, 1e-6);
            }
            float widthLen = length(widthEdge);
            vec3 wDir = (widthLen > 1e-6) ? widthEdge / widthLen : vec3(1, 0, 0);

            // Simple segT with smoothstep for C1 continuity
            float segT = clamp(dot(worldPos - centerPt, chordT) / max(chordLen, 1e-8), 0.0, 1.0);
            segT = smoothstep(0.0, 1.0, segT);

            // Linear sweep center (matches at boundaries: segT=1 → otherCenter = next segT=0)
            vec3 sweepCenter = mix(centerPt, otherCenter, segT);
            vec3 toHit = worldPos - sweepCenter;
            vec3 perpToAxis = toHit - hairGeomT * dot(toHit, hairGeomT);

            float coneRadius = mix(radius0, radius1, segT);
            vec3 camLR = cross(hairGeomT, -rayDir);
            float lrLen = length(camLR);
            if (lrLen > 1e-6) camLR /= lrLen; else camLR = wDir;

            // === Ray-cylinder intersection: virtual cylinder normal ===
            // Find where this ray ENTERS the virtual cylinder.
            // The normal at the entry point is the same regardless of which ribbon was hit.
            // This makes the entire silhouette a "window" onto the cylinder for ANY ray.
            vec3 relOrigin = rayOrigin - sweepCenter;
            vec3 D_perp = rayDir - hairGeomT * dot(rayDir, hairGeomT);
            vec3 O_perp = relOrigin - hairGeomT * dot(relOrigin, hairGeomT);

            float rcA = dot(D_perp, D_perp);
            float rcB = 2.0 * dot(O_perp, D_perp);
            float rcC = dot(O_perp, O_perp) - coneRadius * coneRadius;
            float disc = rcB * rcB - 4.0 * rcA * rcC;

            vec3 cylN;
            if (disc >= 0.0 && rcA > 1e-8) {
                float sqrtDisc = sqrt(max(disc, 0.0));
                float t0 = (-rcB - sqrtDisc) / (2.0 * rcA);
                float t1 = (-rcB + sqrtDisc) / (2.0 * rcA);
                float t_cyl = (t0 > 1e-5) ? t0 : ((t1 > 1e-5) ? t1 : -1.0);

                if (t_cyl > 0.0) {
                    hairShadePos = rayOrigin + t_cyl * rayDir;
                    vec3 cylEntry = hairShadePos - sweepCenter;
                    cylEntry -= hairGeomT * dot(cylEntry, hairGeomT);
                    float entryLen = length(cylEntry);
                    if (entryLen > 1e-6) {
                        cylN = cylEntry / entryLen;
                    } else {
                        cylN = (length(perpToAxis) > 1e-6) ? normalize(perpToAxis) : wDir;
                        hairShadePos = sweepCenter + cylN * coneRadius;
                    }
                    hairV = clamp(dot(cylN * coneRadius, camLR) / max(coneRadius, 1e-8), -1.0, 1.0);
                } else {
                    cylN = (length(perpToAxis) > 1e-6) ? normalize(perpToAxis) : wDir;
                    hairShadePos = sweepCenter + cylN * coneRadius;
                    hairV = clamp(dot(cylN * coneRadius, camLR) / max(coneRadius, 1e-8), -1.0, 1.0);
                }
            } else {
                // Degenerate: ray along tangent — use radial fallback
                cylN = (length(perpToAxis) > 1e-6) ? normalize(perpToAxis) : wDir;
                hairShadePos = sweepCenter + cylN * coneRadius;
                hairV = clamp(dot(cylN * coneRadius, camLR) / max(coneRadius, 1e-8), -1.0, 1.0);
            }
            if (bounce == 0) primaryHairV = hairV;

            worldN = cylN;
            geoNormal = cylN;
            geoNormalRaw = cylN;
            smoothN = cylN;
        } else {
            // Standard shadow terminator fix (non-hair geometry only)
            float NdotNg = dot(worldN, geoNormal);
            if (NdotNg < 0.0) {
                worldN = geoNormal;
            }
        }

        // UVs (flip V: Blender V=0 bottom, stb_image/Vulkan V=0 top)
        vec2 uv0_ = vec2(uvData.uv[i0*2+0], 1.0 - uvData.uv[i0*2+1]);
        vec2 uv1_ = vec2(uvData.uv[i1*2+0], 1.0 - uvData.uv[i1*2+1]);
        vec2 uv2_ = vec2(uvData.uv[i2*2+0], 1.0 - uvData.uv[i2*2+1]);
        vec2 hitUV = uv0_ * bary.x + uv1_ * bary.y + uv2_ * bary.z;

        // Vertex Colors (RGBA, linear space)
        vec4 hitVertexColor = vec4(1.0);  // default white
        if (geo.colorBufferAddress != 0u) {
            Colors colorData = Colors(geo.colorBufferAddress);
            vec4 vc0 = vec4(colorData.c[i0*4+0], colorData.c[i0*4+1], colorData.c[i0*4+2], colorData.c[i0*4+3]);
            vec4 vc1 = vec4(colorData.c[i1*4+0], colorData.c[i1*4+1], colorData.c[i1*4+2], colorData.c[i1*4+3]);
            vec4 vc2 = vec4(colorData.c[i2*4+0], colorData.c[i2*4+1], colorData.c[i2*4+2], colorData.c[i2*4+3]);
            hitVertexColor = vc0 * bary.x + vc1 * bary.y + vc2 * bary.z;
        }

        // Fetch material (need matIdx before UV scale)
        uint matIdx = 0u;
        if (geo.primMaterialBufferAddress != 0u) {
            PrimMaterials primMats = PrimMaterials(geo.primMaterialBufferAddress);
            matIdx = primMats.m[primitiveId];
        }

        // Shader Execution Reordering (SER): reorder threads by material ID
        // so threads evaluating the same material run together → less divergence
        // in Node VM execution. Hardware-accelerated on RTX 40+, software on 30.
#ifdef GL_NV_ray_tracing_invocation_reorder
        reorderThreadNV(matIdx, 16);  // 16 bits = up to 65536 materials
#endif

        Material mat = materialBuffer.materials[matIdx];

        // Apply UV scale from Mapping node (stored in multA, magicMult)
        float uvScaleX = mat.multA;
        float uvScaleY = mat.magicMult;
        if (uvScaleX != 1.0 || uvScaleY != 1.0) {
            hitUV *= vec2(uvScaleX, uvScaleY);
        }

        // DEBUG: material index visualization (debugView == 99)
        if (cam.parameters.y == 99u && bounce == 0 && sampleIdx == 0) {
            float r = float(matIdx % 7u) / 6.0;
            float g = float((matIdx / 7u) % 7u) / 6.0;
            float b = float((matIdx / 49u) % 7u) / 6.0;
            imageStore(dlssDepthImg, pixel, vec4(0.5, 0, 0, 0));
            totalRadiance = vec3(r, g, b);
            diffuseRadiance = totalRadiance;
            break;
        }

        // Evaluate PBR material
        PBRHit pbrHit = evaluateBlenderMaterial(
            mat, matIdx, worldPos, worldN,
            wp0, wp1, wp2, uv0_, uv1_, uv2_, hitUV, rayDir,
            hitVertexColor, uint(instanceId), localPos
        );
        if (isHairHit) {
            pbrHit.worldPos = hairShadePos;
            pbrHit.worldNormal = worldN;
        }
        // Hair: cylinder shading uses material baseColor from PBR evaluation

        // ---- Volume-only material: ray march with Beer-Lambert + in-scattering ----
        bool isVolumeOnly = (mat.flags & 4u) != 0u && (mat.flags & 8u) != 0u;
        if (isVolumeOnly) { shaderCost += 20u;  // volume ray marching is very expensive
            float volumeDensity = mat.sunSpecular;
            float volumeAnisotropy = mat.sunSpecularEXP;
            vec3 volumeColor = pbrHit.baseColor;
            bool isHetero = (mat.flags & 16u) != 0u;

            // Pass through ALL volume faces — both entering and exiting.
            // On front face (entering): trace exit, ray march, apply transmittance + inscatter.
            // On back face (exiting): just pass through (march already done on entry).
            bool entering = dot(geoNormal, -rayDir) > 0.0;

            if (!entering) {
                rayOrigin = worldPos + rayDir * 0.002;
                bounce--;
                continue;
            }

            // Find exit distance: skip self-intersection hits (< 0.05)
            vec3 entryPos = worldPos + rayDir * 0.001;
            float marchDist = 0.0;
            vec3 probeOrigin = entryPos;
            for (int attempt = 0; attempt < 2; attempt++) {
                rayQueryEXT exitRQ;
                rayQueryInitializeEXT(exitRQ, topLevelAS, gl_RayFlagsOpaqueEXT,
                                      0xFF, probeOrigin, 0.0, rayDir, 100000.0);
                while (rayQueryProceedEXT(exitRQ)) {}
                if (rayQueryGetIntersectionTypeEXT(exitRQ, true) == gl_RayQueryCommittedIntersectionNoneEXT) {
                    marchDist += 10.0;  // fallback
                    break;
                }
                float t = rayQueryGetIntersectionTEXT(exitRQ, true);
                marchDist += t + 0.01;
                if (t > 0.05) break;  // real exit (not self-intersection)
                probeOrigin += rayDir * (t + 0.01);  // skip this close hit, try next
            }
            marchDist = max(marchDist, 0.1);

            // Noise parameters (from nodeVmPad + nodeVmCode[0..1])
            float noiseScale = uintBitsToFloat(mat.nodeVmPad[0]);
            float noiseDetail = uintBitsToFloat(mat.nodeVmPad[1]);
            float noiseBrightness = uintBitsToFloat(mat.nodeVmPad[2]);
            float noiseRoughness = uintBitsToFloat(mat.nodeVmCode[0].x);
            float noiseLacunarity = uintBitsToFloat(mat.nodeVmCode[0].y);
            float noiseContrast = uintBitsToFloat(mat.nodeVmCode[0].z);
            vec3 mappingOffset = vec3(uintBitsToFloat(mat.nodeVmCode[1].x),
                                      uintBitsToFloat(mat.nodeVmCode[1].y),
                                      uintBitsToFloat(mat.nodeVmCode[1].z));
            // Defaults for unpacked zeros
            if (noiseRoughness <= 0.0) noiseRoughness = 0.5;
            if (noiseLacunarity <= 0.0) noiseLacunarity = 2.0;

            // Ray march
            const int MAX_STEPS = 48;
            float stepSize = marchDist / float(MAX_STEPS);
            stepSize = max(stepSize, 0.01);  // minimum step size
            int numSteps = min(int(marchDist / stepSize), MAX_STEPS);
            float volTransmittance = 1.0;
            vec3 inscatter = vec3(0.0);

            // Sun for in-scattering
            vec3 vSunDir = normalize(cam.sunLight.xyz);
            float vSunInt = cam.sunLight.w;
            vec3 vSunColor = cam.skyLight.rgb;

            for (int step = 0; step < numSteps; step++) {
                float t = (float(step) + 0.5) * stepSize;
                vec3 samplePos = entryPos + rayDir * t;

                // Evaluate volume coefficients (Cycles Principled Volume formula):
                // sigma_s = Color * Density (scattering)
                // sigma_a = max(1-Color, 0) * Density (absorption, when Absorption Color = black)
                // sigma_t = sigma_s + sigma_a = Density (constant! only scatter/absorb ratio changes)
                float localColor = 1.0;  // scatter albedo [0..1]
                if (isHetero && noiseScale > 0.0) {
                    vec3 noisePos = (samplePos + mappingOffset) * noiseScale;
                    float n = fbm3D(noisePos, noiseDetail, noiseRoughness, noiseLacunarity);
                    n = n + noiseBrightness;
                    if (noiseContrast > 0.001) {
                        n = (n - 0.5) * (1.0 + noiseContrast) + 0.5;
                    }
                    localColor = clamp(n, 0.0, 1.0);
                }

                // sigma_t = Density (total extinction is constant — matches Cycles)
                float sigma_t_local = volumeDensity;
                if (sigma_t_local < 0.0001) continue;

                // sigma_s = Color * Density (scattering portion)
                float sigma_s_local = localColor * volumeDensity;

                // In-scattering from ALL light sources (Cycles-style)
                // No shadow rays (volume self-occlusion)
                vec3 L_in = vec3(0.0);

                // 1. Sun (phase-weighted directional light)
                if (vSunInt > 0.0) {
                    float phase = henyeyGreensteinPhase(dot(rayDir, vSunDir), volumeAnisotropy);
                    L_in += vSunColor * vSunInt * phase;
                }

                // 2. Point/spot/area lights — sample 1 random light, scale by count
                uint vLightCount = min(cam.lightCount, 32u);
                if (vLightCount > 0u) {
                    uint li = uint(rand01() * float(vLightCount));
                    li = min(li, vLightCount - 1u);
                    vec4 lPosRange = cam.lights[li * 4u];
                    vec4 lColInt   = cam.lights[li * 4u + 1u];
                    vec3 lPos = lPosRange.xyz;
                    float lRange = lPosRange.w;
                    vec3 lColor = lColInt.rgb;
                    float lIntensity = lColInt.w;
                    vec3 toLight = lPos - samplePos;
                    float dist2 = dot(toLight, toLight);
                    float dist = sqrt(dist2);
                    if (dist < lRange && dist > 0.01) {
                        vec3 lDir = toLight / dist;
                        float atten = 1.0 / dist2;
                        // Windowed falloff (same as surface NEE)
                        float falloff = clamp(1.0 - pow(dist / lRange, 4.0), 0.0, 1.0);
                        falloff = falloff * falloff;
                        float phase = henyeyGreensteinPhase(dot(rayDir, lDir), volumeAnisotropy);
                        L_in += lColor * lIntensity * atten * falloff * phase * float(vLightCount);
                    }
                }

                // 3. Sky environment (isotropic: phase = 1/4π)
                // evaluateSky returns HDRI when available — no separate ambient needed.
                L_in += evaluateSky(rayDir) * 0.25 * INV_PI;

                // Accumulate: T(t) * sigma_s * L_in * dt
                // sigma_s (not sigma_t!) — only scattered light contributes to inscatter
                inscatter += volTransmittance * sigma_s_local * L_in * stepSize;

                // Beer-Lambert with sigma_t (full extinction = scatter + absorption)
                volTransmittance *= exp(-sigma_t_local * stepSize);
                if (volTransmittance < 0.001) break;
            }

            // Apply: inscatter goes to diffuse, transmittance attenuates throughput
            diffuseRadiance += inscatter * throughput;
            throughput *= volTransmittance;

            rayOrigin = entryPos + rayDir * marchDist;
            if (bounce == 0) isDiffusePath = true;
            bounce--;
            continue;
        }

        // Ensure normal faces the ray.
        // At grazing angles, the normal map can perturb N to face away from
        // the camera, causing black bands. Fix: if N·V < 0, project N onto
        // the plane perpendicular to V so it stays in the correct hemisphere.
        vec3 N = pbrHit.worldNormal;
        vec3 gN = geoNormal;  // camera-facing geometric normal
        bool isHairSurface = (geo.bitangentBufferAddress != 0u);
        if (isHairSurface) shaderCost += 5u;  // hair BSDF + cylinder shading
        // Hair: large shadow bias plus same-strand skip prevents ribbon-on-ribbon shadows.
        float shadowBias = isHairSurface ? 0.1 : 0.002;
        float hairSelfShadowSkipDist = isHairSurface ? 0.12 : 0.0;
        bool frontFace = dot(gN, -rayDir) >= 0.0;
        if (!frontFace) {
            gN = -gN;
            N = -N;
        }
        // Clamp perturbed normal: if normal map made it face away from camera,
        // blend back toward geometric normal to avoid black artifacts
        float NdotV_check = dot(N, -rayDir);
        if (NdotV_check < 0.01) {
            // Smoothly blend toward geometric normal as NdotV approaches 0
            float blend = clamp(-NdotV_check * 50.0 + 0.5, 0.0, 1.0);
            N = normalize(mix(N, gN, blend));
        }

        // ---- Backface culling ----
        // Skip for alpha-tested materials (they need back faces visible
        // so you can see through transparent front faces to the back)
        if (backfaceCulling && !frontFace && pbrHit.transmission < 0.5
            && (mat.flags & 1u) == 0u) {
            rayOrigin = worldPos + rayDir * 0.002;
            bounce--;
            continue;
        }

        // ---- Stochastic alpha test ----
        // For materials with per-pixel alpha: randomly pass through based on alpha.
        // Ray advances past the surface to find whatever is behind (back face,
        // other objects, etc.). Each subsequent alpha surface gets tested again.
        if ((mat.flags & 1u) != 0u && pbrHit.alpha < 0.999) {
            if (rand01() > pbrHit.alpha) {
                rayOrigin = worldPos + rayDir * 0.002;
                bounce--;
                continue;
            }
        }

        // ---- Stochastic transparent passthrough (Cycles-style) ----
        // For materials with Transparent BSDF (tp > 0), use Fresnel to determine
        // pass-through vs reflection probability. At normal incidence most light
        // passes through; at grazing angles reflection dominates.
        // This matches Cycles' behavior for architectural glass (Transparent + Glossy).
        float transparentProb = mat.multB;
        // For glass+transparent materials: use Fresnel to split pass-through vs reflection.
        // At normal incidence ~96% passes, ~4% reflects (matches Glass BSDF Fresnel).
        if (transparentProb > 0.0) {
            float cosTheta = abs(dot(N, -rayDir));
            float iorGlass = max(pbrHit.ior, 1.01);
            float f0 = (iorGlass - 1.0) / (iorGlass + 1.0);
            f0 = f0 * f0;
            float fresnelRefl = f0 + (1.0 - f0) * pow(1.0 - cosTheta, 5.0);
            transparentProb = 1.0 - fresnelRefl;  // Fresnel transmission probability
        }
        if (transparentProb > 0.0 && rand01() < transparentProb) {
            // Ray passes through — no refraction, no absorption (like Cycles Transparent BSDF)
            rayOrigin = worldPos + rayDir * 0.002;
            bounce--;  // doesn't count as a bounce
            continue;
        }

        // Artist-authored Cycles pattern:
        // Mix transmissive shader with Transparent using Light Path
        // (typically Is Shadow Ray and/or Is Reflection Ray).
        // Camera rays still see the glass, but secondary specular/reflection rays
        // and shadow rays should pass through cheaply.
        if ((mat.flags & MAT_FLAG_LIGHTPATH_TRANSPARENT) != 0u && bounce > 0 && !isDiffusePath) {
            rayOrigin = worldPos + rayDir * 0.002;
            bounce--;
            continue;
        }

        // ---- Thin transmission fast path ----
        // Treat thin transmissive sheets before any NEE/shadow work.
        // If the ray passes through the sheet, we should not pay direct-lighting
        // costs on the sheet itself first.
        float glassProb = (1.0 - pbrHit.metallic) * pbrHit.transmission;
        bool thinTransmissionMaterial = (mat.flags & MAT_FLAG_THIN_TRANSMISSION) != 0u;
        uint materialVmHeaderFlags = (mat.nodeVmHeader >> 8u) & 0xFFu;
        bool mappedTransmissionMaterial = (materialVmHeaderFlags & VM_HEADER_FLAG_TRANSMISSION) != 0u;
        bool partialTransmissionHit = (glassProb < 0.98) || (pbrHit.alpha < 0.999);
        bool useThinTransmissionPath = thinTransmissionMaterial || (mappedTransmissionMaterial && partialTransmissionHit);
        if (glassProb > 0.01 && useThinTransmissionPath) {
            thinTransmissionPasses++;
            if (thinTransmissionPasses > MAX_THIN_TRANSMISSION_PASSES) break;

            vec3 Vthin = -rayDir;
            float cosTheta = abs(dot(N, Vthin));
            float etaThin = 1.0 / max(pbrHit.ior, 1.01);
            float fresnelThin = fresnelDielectric(cosTheta, etaThin);
            float thinPassProb = glassProb * (1.0 - fresnelThin);
            float thinReflectProb = glassProb * fresnelThin;
            float thinTotalProb = thinPassProb + thinReflectProb;
            float thinRnd = rand01();
            if (thinPassProb > 0.01 && thinRnd < thinPassProb) {
                throughput *= cyclesPrincipledTransmissionTint(pbrHit.baseColor) / max(thinPassProb, 0.01);
                rayOrigin = pbrHit.worldPos + rayDir * 0.002;
                if (bounce == 0) throughPrimarySpecularInterface = true;
                bounce--;  // thin sheet passthrough should not burn the main bounce budget
                continue;
            } else if (thinReflectProb > 0.001 && thinRnd < thinTotalProb) {
                float alphaThin = pbrHit.roughness * pbrHit.roughness;
                vec3 Hthin;
                if (alphaThin > 0.0005) {
                    alphaThin = max(alphaThin, 0.001);
                    Hthin = sampleGGX_VNDF(rand2(), Vthin, N, alphaThin);
                } else {
                    Hthin = N;
                }
                rayDir = reflect(rayDir, Hthin);
                rayOrigin = pbrHit.worldPos + N * 0.001;
                throughput *= vec3(1.0) / max(thinReflectProb, 0.01);
                if (bounce == 0) { isDiffusePath = false; captureSpecularMV = true; throughPrimarySpecularInterface = true; }
                continue;
            }
        }

        // ---- Early glass fast path (all roughness levels) ----
        // Pure solid glass should refract/reflect immediately instead of paying
        // NEE and shadow work. Glass doesn't scatter via diffuse NEE, so the
        // direct-lighting section is wasted cost. Handle GGX microfacet
        // sampling here for rough glass, and delta refraction for smooth glass.
        bool earlyGlassExit =
            glassProb > 0.99 &&
            !useThinTransmissionPath &&
            transparentProb <= 0.0 &&
            pbrHit.alpha >= 0.999 &&
            pbrHit.metallic <= 0.001;
        if (earlyGlassExit) {
            glassBounces++;
            if (glassBounces >= MAX_GLASS_BOUNCES) break;

            vec3 Vglass = -rayDir;
            bool enteringGlass = dot(smoothN, -rayDir) >= 0.0;
            // Use bump-perturbed N for refraction only when bump/normal map is active.
            // Without bump, use smoothN to avoid floating-point noise creating artifacts.
            bool hasBumpMap = (mat.normalTexIndex != 0xFFFFFFFFu);
            // Bump maps (detailNormalBlend < 0) should affect refraction (frosted glass effect).
            // Normal maps (detailNormalBlend >= 0) should NOT — they're surface detail that
            // causes excessive distortion on curved glass.
            bool isBumpNotNormalMap = hasBumpMap && (mat.detailNormalBlend < 0.0);
            vec3 refractN = enteringGlass
                ? (isBumpNotNormalMap ? N : smoothN)
                : (isBumpNotNormalMap ? -N : -smoothN);
            float eta = enteringGlass ? (1.0 / pbrHit.ior) : pbrHit.ior;
            float alphaGlass = pbrHit.roughness * pbrHit.roughness;

            // Bump-to-roughness: only for smooth glass (roughness≈0) with bump map.
            // Glass with its own roughness (from texture/VM) doesn't need bump-derived roughness.
            if (hasBumpMap && alphaGlass < 0.001) {
                float bumpCos = dot(N, smoothN);
                if (bumpCos < 0.9999) {
                    float bumpAlpha = max(1.0 - bumpCos * bumpCos, 0.0);
                    alphaGlass = max(alphaGlass, bumpAlpha);
                }
            }

            vec3 Hglass;
            if (alphaGlass >= 0.0005) {
                alphaGlass = max(alphaGlass, 0.001);
                Hglass = sampleGGX_VNDF(rand2(), Vglass, refractN, alphaGlass);
            } else {
                Hglass = refractN;
            }

            float cosI = abs(dot(Vglass, Hglass));
            float fresnel = fresnelDielectric(cosI, eta);
            vec3 refracted = refract(-Vglass, Hglass, eta);
            bool canRefract = dot(refracted, refracted) > 0.0001;

            if (!canRefract || rand01() < fresnel) {
                rayDir = reflect(rayDir, Hglass);
                rayOrigin = pbrHit.worldPos + refractN * 0.001;
            } else {
                rayDir = refracted;
                rayOrigin = pbrHit.worldPos - refractN * 0.001;
            }

            throughput *= cyclesPrincipledTransmissionTint(pbrHit.baseColor) / max(glassProb, 0.01);
            if (bounce == 0) { isDiffusePath = false; captureSpecularMV = true; throughPrimarySpecularInterface = true; }
            bounce--;
            continue;
        }

        // PSR-lite: once the camera ray crossed a primary specular interface,
        // treat the resolved surface as a replaced-primary hit and keep the
        // remaining work on the cheapest path we can reasonably afford.
        bool primaryThroughSpecularFast = (bounce == 0) && throughPrimarySpecularInterface;

        // ---- Debug: Lighting mode overrides baseColor to white on all samples ----
        if (cam.parameters.y == 1u && bounce == 0) {
            pbrHit.baseColor = vec3(1.0);
        }

        // ---- NIRC: write query input + read previous frame prediction ----
        // nircQueryOutput[0].a > 0 signals that NIRC buffers are valid
        bool nircActive = (nircReady);
        if (nircActive && bounce == 0 && sampleIdx == 0) {
            uint nircPixelIdx = uint(pixel.y) * uint(launchSize.x) + uint(pixel.x);
            uint qBase = nircPixelIdx * 8u;
            nircQueryInput[qBase]     = pbrHit.worldPos.x;
            nircQueryInput[qBase + 1] = pbrHit.worldPos.y;
            nircQueryInput[qBase + 2] = pbrHit.worldPos.z;
            nircQueryInput[qBase + 3] = -rayDir.x;
            nircQueryInput[qBase + 4] = -rayDir.y;
            nircQueryInput[qBase + 5] = -rayDir.z;
            nircQueryInput[qBase + 6] = pbrHit.roughness;
            nircQueryInput[qBase + 7] = 0.0;
        }

        // ---- Bounce 0: capture primary hit info (first sample only) ----
        if (bounce == 0 && sampleIdx == 0) {
            primaryHit = true;
            primaryNormal = N;
            primaryRoughness = pbrHit.roughness;
            primaryAlbedo = pbrHit.baseColor;
            primaryWorldPos = pbrHit.worldPos;
            primaryHitDist = hitT;
            primaryLocalPos = localPos;
            primaryCustomIndex = customIndex;   // BLAS index
            primaryInstanceId = instanceId;     // instance index
            primaryUV = hitUV;
            primaryBaseColor = pbrHit.baseColor;

            // Insert surfel at primary hit position
            if (surfelEnabled && !primaryThroughSpecularFast) {
                uint64_t surfelKey = surfelHashKey(pbrHit.worldPos, N, surfelGrid);
                surfelInsert(surfelKey, surfelCapacity);
            }

            // View-space Z (negative in RH convention)
            vec4 viewPos = cam.view * vec4(pbrHit.worldPos, 1.0);
            primaryViewZ = viewPos.z;
        }

        // ---- Capture secondary hit distance (bounce 1, for denoiser) ----
        if (bounce == 1 && sampleIdx == 0) {
            secondaryHitDist = hitT;
        }

        // ---- Capture specular motion vector (bounce 1 hit of reflected object) ----
        if (bounce == 1 && captureSpecularMV) {
            captureSpecularMV = false;
            // Compute MV of the reflected hit point
            uint rBase = uint(instanceId) * 3u;
            vec4 rRow0 = prevTransforms.data[rBase + 0u];
            vec4 rRow1 = prevTransforms.data[rBase + 1u];
            vec4 rRow2 = prevTransforms.data[rBase + 2u];
            vec4 rLp = vec4(localPos, 1.0);
            vec3 reflPrevWorldPos = vec3(dot(rRow0, rLp), dot(rRow1, rLp), dot(rRow2, rLp));

            vec4 rcClip = cam.proj * cam.view * vec4(pbrHit.worldPos, 1.0);
            vec2 rcNDC = rcClip.xy / rcClip.w;
            vec2 rcUV = vec2(rcNDC.x * 0.5 + 0.5, 0.5 - rcNDC.y * 0.5);
            vec4 rpClip = cam.projPrev * cam.viewPrev * vec4(reflPrevWorldPos, 1.0);
            vec2 rpNDC = rpClip.xy / rpClip.w;
            vec2 rpUV = vec2(rpNDC.x * 0.5 + 0.5, 0.5 - rpNDC.y * 0.5);
            specularMV = rpUV - rcUV;
        }

        // ---- NRC: report surface hit to neural cache ----
        if (NrcIsEnabled() && !nrcTerminated) {
            NrcSurfaceAttributes nrcSurf;
            nrcSurf.encodedPosition = NrcEncodePosition(pbrHit.worldPos, nrcConstants);
            nrcSurf.roughness = pbrHit.roughness;
            nrcSurf.specularF0 = mix(vec3(0.04), pbrHit.baseColor, pbrHit.metallic);
            nrcSurf.diffuseReflectance = pbrHit.baseColor * (1.0 - pbrHit.metallic);
            nrcSurf.shadingNormal = N;
            nrcSurf.viewVector = -rayDir;
            nrcSurf.isDeltaLobe = (pbrHit.roughness < 0.02 && pbrHit.transmission > 0.5);

            vec3 nrcThroughput = throughput;
            vec3 nrcRadiance = totalRadiance;
            uint nrcProgress = NrcUpdateOnHit(
                nrcCtx, nrcPath, nrcSurf, hitT, uint(bounce),
                nrcThroughput, nrcRadiance);

            if (NrcIsUpdateMode()) {
                throughput = nrcThroughput;
                totalRadiance = nrcRadiance;
            }

            if (nrcProgress == NRC_PROGRESS_TERMINATE_IMMEDIATELY) {
                nrcTerminated = true;
                break;
            }
            if (nrcProgress == NRC_PROGRESS_TERMINATE_AFTER_DIRECT_LIGHTING) {
                nrcTerminated = true;
                // Continue to NEE but break after
            }
        }

        // ---- NIRC: write training sample (stochastic subset, 1/16 pixels) ----
        if (nircActive && bounce >= 1 && sampleIdx == 0) {
            uint nircPixelHash = uint(pixel.x) * 1973u + uint(pixel.y) * 9277u + frameIndex * 26699u;
            if ((nircPixelHash & 15u) == 0u) {
                uint nircIdx = (uint(pixel.y) * uint(launchSize.x) + uint(pixel.x) + uint(bounce) * 65536u) % 65536u;
                nircSamples[nircIdx].position = pbrHit.worldPos;
                nircSamples[nircIdx].roughness = pbrHit.roughness;
                nircSamples[nircIdx].direction = -rayDir;
                nircSamples[nircIdx].radiance = totalRadiance * throughput;
            }
        }

        // ---- Accumulate emission ----
        // Emission always goes to diffuseRadiance so NRD preserves it.
        // TODO: BSDF-side MIS weight requires searching the emissive triangle buffer
        // to find the exact light PDF. For now, pass emission unweighted — the NEE side
        // already has correct MIS weights which partially compensate for double-counting.
        vec3 emissionContrib = pbrHit.emission * throughput;
        if (bounce == 0) {
            diffuseRadiance += emissionContrib;
        } else {
            if (isDiffusePath) diffuseRadiance += emissionContrib;
            else specularRadiance += emissionContrib;
        }

        // ---- NEE throughput early-out (skip shadow rays when contribution is negligible) ----
        float maxThroughput = max(throughput.r, max(throughput.g, throughput.b));
        bool hairFastPrimary = isHairSurface;
        bool hairFastSecondary = isHairSurface && (bounce > 0 || primaryThroughSpecularFast);
        // Full path before the dense-groom fast path:
        // bool skipSunNEE = (bounce >= 2 && maxThroughput < 0.01);
        // bool skipLocalNEE = false;  // NEE on all bounces (Cycles behavior)
        bool skipSunNEE = (bounce >= 2 && maxThroughput < 0.01) || hairFastSecondary;
        bool skipLocalNEE = hairFastSecondary || (bounce >= 3);

        // Glass/transmission surfaces don't scatter light — skip NEE entirely.
        // Light reaches through glass via refraction paths, not direct illumination.
        // This matches Cycles behavior where Glass BSDF has no diffuse lobe for NEE.
        // Only skip NEE for pure glass (no metallic). Mixed metallic+glass
        // materials need NEE for the metallic reflection lobe.
        float _glassP = (1.0 - pbrHit.metallic) * pbrHit.transmission;
        bool isGlass = (_glassP > 0.99);
        if (isGlass) { shaderCost += 3u;  // glass refraction + extra bounce
            skipSunNEE = true;
            skipLocalNEE = true;
        }

        // On higher bounces: sample 1 random light instead of all (importance sampling)
        // Scale contribution by lightCount to maintain unbiased estimate
        uint neeStart = 0u;
        uint neeEnd = min(cam.lightCount, 32u);
        float neeScale = 1.0;
        if ((bounce >= 2 || hairFastPrimary) && cam.lightCount > 1u && !skipLocalNEE) {
            // Bounce 2+: sample 1 random light, scale contribution
            uint randIdx = min(uint(rand01() * float(cam.lightCount)), cam.lightCount - 1u);
            neeStart = randIdx;
            neeEnd = randIdx + 1u;
            neeScale = float(cam.lightCount);
        } else if (cam.lightCount > 4u && !skipLocalNEE) {
            // Bounce 0-1: sample 4 random lights per pixel (stochastic, denoiser-friendly)
            uint randIdx = min(uint(rand01() * float(cam.lightCount)), cam.lightCount - 1u);
            neeStart = randIdx;
            neeEnd = min(randIdx + 4u, cam.lightCount);
            neeScale = float(cam.lightCount) / float(min(4u, cam.lightCount - randIdx));
        }

        // Snapshot radiance BEFORE NEE (for SHARC: compute local contribution)
        vec3 preBounceRadiance = diffuseRadiance + specularRadiance;

        // ---- NEE: Direct sun light ----
        // sunDir, sunIntensity, sunColor precomputed above bounce loop
        int sunShadowSkipMax = isHairSurface ? 2 : 4;

        if (!skipSunNEE && sunIntensity > 0.0 && sunDir.y > -0.01) { shaderCost += 2u;  // sun shadow ray
            float NdotL = isHairSurface
                ? (isHairHit ? evalHairCylinderFalloff(N, sunDir) : length(cross(hairSmoothT, sunDir)))
                : dot(N, sunDir);
            if (NdotL > 0.0) {
                // Shadow ray with soft penumbra (sun angular radius)
                // Blue noise + Halton temporal sequence for stable penumbra convergence
                vec3 shadowDir = sunDir;
                {
                    float sunRadius = intBitsToFloat(cam.jitterPattern[2].x);  // from Blender sun_size
                    if (sunRadius <= 0.0) sunRadius = 0.009512;  // Nishita default
                    sunRadius *= 0.5;  // sun_size is diameter, we need radius
                    // Use blue noise for spatial coherence + frame index for temporal variation
                    ivec2 bnCoord = ivec2((pixel.x + frameIndex * 7) & 63, (pixel.y + frameIndex * 11) & 63);
                    vec2 diskSample = vec2(
                        texelFetch(blueNoiseTexture, bnCoord, 0).r,
                        texelFetch(blueNoiseTexture, ivec2(bnCoord.y, bnCoord.x), 0).r
                    );
                    float diskR = sqrt(diskSample.x) * sunRadius;
                    float diskAngle = diskSample.y * 2.0 * PI;
                    // sunTangent/sunBitangent precomputed above bounce loop
                    shadowDir = normalize(sunDir + sunTangent * (cos(diskAngle) * diskR) + sunBitangent * (sin(diskAngle) * diskR));
                }
                vec3 shadowOrigin = pbrHit.worldPos + N * shadowBias;
                bool inShadow = false;
                vec3 shadowFilter = vec3(1.0);
                float shadowHitDist = 65504.0;
                for (int shadowSkip = 0; shadowSkip < sunShadowSkipMax; shadowSkip++) {
                    rayQueryEXT shadowRQ;
                    rayQueryInitializeEXT(shadowRQ, topLevelAS,
                        gl_RayFlagsOpaqueEXT,
                        0xFF, shadowOrigin, 0.0, shadowDir, 10000.0);
                    while (rayQueryProceedEXT(shadowRQ)) {}

                    if (rayQueryGetIntersectionTypeEXT(shadowRQ, true)
                        == gl_RayQueryCommittedIntersectionNoneEXT) {
                        break; // No hit — not in shadow
                    }

                    // Check if shadow hit is alpha-tested
                    uint sCustIdx = rayQueryGetIntersectionInstanceCustomIndexEXT(shadowRQ, true);
                    int sPrimId = rayQueryGetIntersectionPrimitiveIndexEXT(shadowRQ, true);
                    float sHitT = rayQueryGetIntersectionTEXT(shadowRQ, true);

                    GeometryMetadata sGeo = geometryMetadata.geometries[sCustIdx];
                    uint sStrandId = getHairStrandId(sGeo, uint(max(sPrimId, 0)));
                    bool skipSameStrandShadow = isHairSurface && sGeo.bitangentBufferAddress != 0u
                        && sCustIdx == customIndex
                        && hairStrandId != INVALID_HAIR_STRAND
                        && sStrandId == hairStrandId;
                    if (skipSameStrandShadow
                        || (isHairSurface && sGeo.bitangentBufferAddress != 0u
                            && sCustIdx == customIndex && sHitT < hairSelfShadowSkipDist)) {
                        shadowOrigin += shadowDir * (sHitT + 0.01);
                        continue;
                    }
                    uint sMatIdx = 0u;
                    if (sGeo.primMaterialBufferAddress != 0u) {
                        PrimMaterials sPrimMats = PrimMaterials(sGeo.primMaterialBufferAddress);
                        sMatIdx = sPrimMats.m[sPrimId];
                    }
                    Material sMat = materialBuffer.materials[sMatIdx];

                    // Glass/volume: let shadow ray pass through (real-time approximation —
                    // without caustic tracing, blocking at glass creates incorrect darkness)
                    if ((sMat.flags & 6u) != 0u) {
                        shadowOrigin += shadowDir * (sHitT + 0.004);
                        continue;
                    }

                    bool sNeedsShadowTransparency =
                        (sMat.flags & (1u | MAT_FLAG_LIGHTPATH_TRANSPARENT)) != 0u || sMat.multB > 0.0;
                    if (!sNeedsShadowTransparency) {
                        inShadow = true;
                        shadowHitDist = sHitT;
                        break;
                    }

                    vec2 sBary2 = rayQueryGetIntersectionBarycentricsEXT(shadowRQ, true);
                    vec3 sBary = vec3(1.0 - sBary2.x - sBary2.y, sBary2.x, sBary2.y);
                    mat4x3 sOTW = rayQueryGetIntersectionObjectToWorldEXT(shadowRQ, true);
                    uint sInstanceId = uint(rayQueryGetIntersectionInstanceIdEXT(shadowRQ, true));
                    vec3 sTrans = evaluateShadowMaterialTransmittance(
                        sMat, sMatIdx, sGeo, sPrimId, sBary, sOTW, shadowDir, sInstanceId
                    );

                    if (max(max(sTrans.r, sTrans.g), sTrans.b) <= 0.001) {
                        inShadow = true;
                        shadowHitDist = sHitT;
                        break;
                    }

                    shadowFilter *= sTrans;
                    if (max(max(shadowFilter.r, shadowFilter.g), shadowFilter.b) <= 0.001) {
                        inShadow = true;
                        shadowHitDist = sHitT;
                        break;
                    }

                    // Skip through — restart from behind this hit with accumulated tint.
                    shadowOrigin += shadowDir * (sHitT + 0.002);
                }

                // Compute direct light contribution (ALWAYS, regardless of shadow)
                vec3 V = -rayDir;
                vec3 sunRadiance = sunColor * sunIntensity;
                vec3 diffContrib, specContrib;
                if (isHairSurface) {
                    if (isHairHit) {
                        evaluateHairCylinderBSDF(
                            N, V, sunDir, hairSmoothT,
                            pbrHit.baseColor, pbrHit.roughness, pbrHit.hairRadialRoughness,
                            pbrHit.specularLevel, pbrHit.ior, pbrHit.hairShift, hairV,
                            diffContrib, specContrib);
                    } else {
                        // Hair: R+TT+TRT via Beer-Lambert (no separate diffuse)
                        diffContrib = hair_eval(V, sunDir, hairSmoothT,
                                               pbrHit.baseColor, max(pbrHit.roughness, 0.05),
                                               max(pbrHit.hairRadialRoughness, 0.05),
                                               pbrHit.hairShift, max(pbrHit.ior, 1.01), hairV);
                        specContrib = vec3(0.0);
                    }
                } else {
                    evaluateCookTorrance(
                        N, V, sunDir, pbrHit.baseColor, pbrHit.roughness,
                        pbrHit.metallic, pbrHit.specularLevel, pbrHit.ior, pbrHit.transmission,
                        diffContrib, specContrib
                    );
                }

                if (bounce == 0) {
                    // Always apply shadow directly (works for both RR and NRD modes)
                    vec3 shadow = inShadow ? vec3(0.0) : shadowFilter;
                    diffuseRadiance += clampRadiance(diffContrib * sunRadiance * throughput * shadow);
                    specularRadiance += clampRadiance(specContrib * sunRadiance * throughput * shadow);

                    // Store penumbra for SIGMA (NRD fallback)
                    primaryNdotLSample = NdotL;
                    if (inShadow) {
                        float sigmaTanAngle = 0.04;
                        primaryPenumbraSample = min(shadowHitDist * sigmaTanAngle * 0.5, 32768.0);
                    } else {
                        primaryPenumbraSample = 65504.0;
                    }
                } else {
                    // Indirect bounces: apply shadow directly (SIGMA only handles primary)
                    vec3 shadow = inShadow ? vec3(0.0) : shadowFilter;
                    vec3 directLight = clampRadiance((diffContrib + specContrib) * sunRadiance * shadow);
                    if (isDiffusePath) {
                        diffuseRadiance += directLight * throughput * giIntensity;
                    } else {
                        specularRadiance += directLight * throughput * giIntensity;
                    }
                }
            }
        }

        // ---- ReSTIR DI: Reservoir-based light sampling (bounce 0 only) ----
        // Replaces brute-force all-lights loop with weighted reservoir sampling.
        // Each pixel picks 1 light from M candidates, then temporally reuses.
        // Result: same quality as sampling ALL lights, but only 1 shadow ray.
        bool restirDone = false;
        // ReSTIR DI: reservoir-based light sampling (opt-in via UI toggle)
        // Better for scenes with many lights (16+), may cause splotches with few lights
        bool restirEnabled = (cam.lightPad2 & 2u) != 0u;  // bit 1 of lightPad2
        if (restirEnabled && !skipLocalNEE && bounce == 0 && cam.lightCount > 0u && !isHairSurface && !primaryThroughSpecularFast) {
            DIReservoir reservoir = emptyDIReservoir();
            vec3 V = -rayDir;
            uint localRng = rngState;

            // Candidate generation: sample M=min(lightCount, 8) random lights
            uint M = min(cam.lightCount, 8u);
            float sourcePDF = 1.0 / float(cam.lightCount);

            for (uint m = 0u; m < M; m++) {
                // Random light index
                localRng ^= localRng << 13u; localRng ^= localRng >> 17u; localRng ^= localRng << 5u;
                uint li = uint(float(localRng) / 4294967295.0 * float(cam.lightCount));
                li = min(li, cam.lightCount - 1u);

                vec4 lPosRange = cam.lights[li * 4u];
                vec4 lColInt   = cam.lights[li * 4u + 1u];
                vec4 lDirSizeX = cam.lights[li * 4u + 2u];
                vec4 lTanSizeY = cam.lights[li * 4u + 3u];

                vec3 lightPos = lPosRange.xyz;
                vec3 lightColor = lColInt.rgb;
                float lightInt = lColInt.w;
                float sizeY = lTanSizeY.w;
                bool isSpecial = (lPosRange.w < 0.0);
                bool isSpot = isSpecial && sizeY < 0.0;
                bool isArea = isSpecial && !isSpot;

                // Compute light direction and attenuation
                vec3 toLight = lightPos - pbrHit.worldPos;
                float dist = length(toLight);
                if (dist < 0.001) continue;
                vec3 L = toLight / dist;
                float NdotL = dot(N, L);
                if (NdotL <= 0.0) continue;

                // Spot light cone attenuation
                float spotAtten = 1.0;
                if (isSpot) {
                    vec3 spotDir = lDirSizeX.xyz;
                    float cosHalfAngle = lDirSizeX.w;
                    float spotSmooth = abs(lTanSizeY.w);
                    float cosAngle = dot(-L, spotDir);
                    float t = clamp((cosAngle - cosHalfAngle) * spotSmooth, 0.0, 1.0);
                    spotAtten = t * t * (3.0 - 2.0 * t);
                    if (spotAtten <= 0.0) continue;
                }

                float falloff = 1.0 / (dist * dist + 0.001);
                float attenuation = falloff;
                vec3 samplePos = lightPos;

                if (isArea) {
                    vec3 lightNormal = lDirSizeX.xyz;
                    float lightFacing = dot(-L, lightNormal);
                    if (lightFacing <= 0.0) continue;
                    float areaSize = lDirSizeX.w * lTanSizeY.w;
                    attenuation *= lightFacing * areaSize;
                }

                vec3 lightRadiance = lightColor * lightInt * attenuation * spotAtten;
                float pHat = diTargetPDF(N, V, L, NdotL, pbrHit.baseColor,
                                         pbrHit.roughness, pbrHit.metallic, lightRadiance);

                diReservoirUpdate(reservoir, li, samplePos, pHat, sourcePDF, localRng);
            }

            // Temporal reuse: merge with previous frame's reservoir
            uint pixelLinearIdx = uint(pixel.y) * uint(launchSize.x) + uint(pixel.x);
            uint prevBase = pixelLinearIdx * 3u;
            DIReservoir prevReservoir = diUnpack(
                giReservoirPrev.data[prevBase + 0u],
                giReservoirPrev.data[prevBase + 1u]);
            bool prevFresh = diReservoirIsFresh(giReservoirPrev.data[prevBase + 2u], frameIndex);

            if (prevFresh && prevReservoir.M > 0.0 && prevReservoir.lightIndex != 0xFFFFFFFFu
                && prevReservoir.age < 20.0) {
                // Re-evaluate target PDF of previous sample at current pixel
                uint prevLi = prevReservoir.lightIndex;
                if (prevLi < cam.lightCount) {
                    vec4 pPosRange = cam.lights[prevLi * 4u];
                    vec4 pColInt   = cam.lights[prevLi * 4u + 1u];
                    vec4 pDirSizeX = cam.lights[prevLi * 4u + 2u];
                    vec4 pTanSizeY = cam.lights[prevLi * 4u + 3u];
                    vec3 pToLight = pPosRange.xyz - pbrHit.worldPos;
                    float pDist = length(pToLight);
                    vec3 pL = pToLight / max(pDist, 0.001);
                    float pNdotL = dot(N, pL);
                    float pFalloff = 1.0 / (pDist * pDist + 0.001);
                    float pAtten = pFalloff;
                    float pSpotAtten = 1.0;
                    bool pIsSpecial = (pPosRange.w < 0.0);
                    bool pIsSpot = pIsSpecial && pTanSizeY.w < 0.0;
                    bool pIsArea = pIsSpecial && !pIsSpot;
                    if (pIsSpot) {
                        float pCosHalf = pDirSizeX.w;
                        float pSm = abs(pTanSizeY.w);
                        float pCosA = dot(-pL, pDirSizeX.xyz);
                        float pSt = clamp((pCosA - pCosHalf) * pSm, 0.0, 1.0);
                        pSpotAtten = pSt * pSt * (3.0 - 2.0 * pSt);
                    }
                    if (pIsArea) {
                        float pFaceDot = max(dot(-pL, pDirSizeX.xyz), 0.0);
                        pAtten *= pFaceDot * pDirSizeX.w * pTanSizeY.w;
                    }
                    vec3 pRadiance = pColInt.rgb * pColInt.w * pAtten * pSpotAtten;
                    float prevTargetPDF = diTargetPDF(N, V, pL, max(pNdotL, 0.0),
                        pbrHit.baseColor, pbrHit.roughness, pbrHit.metallic, pRadiance);

                    // Clamp M to prevent bias buildup — scale weightSum proportionally
                    // so the weight/M ratio stays consistent (prevents W inflation)
                    DIReservoir clampedPrev = prevReservoir;
                    float prevMCap = min(clampedPrev.M, 20.0);
                    if (prevMCap < clampedPrev.M) {
                        clampedPrev.weightSum *= prevMCap / clampedPrev.M;
                    }
                    clampedPrev.M = prevMCap;
                    diReservoirMerge(reservoir, clampedPrev, prevTargetPDF, localRng);
                }
            }

            // Spatial reuse: merge with K random neighbor reservoirs
            // This shares shadow visibility info across pixels, reducing binary noise
            for (int sn = 0; sn < 3; sn++) {
                // Random neighbor within 10px radius
                localRng ^= localRng << 13u; localRng ^= localRng >> 17u; localRng ^= localRng << 5u;
                float angle = float(localRng) / 4294967295.0 * 6.28318;
                localRng ^= localRng << 13u; localRng ^= localRng >> 17u; localRng ^= localRng << 5u;
                float radius = sqrt(float(localRng) / 4294967295.0) * 10.0;
                ivec2 neighbor = pixel + ivec2(cos(angle) * radius, sin(angle) * radius);
                neighbor = clamp(neighbor, ivec2(0), ivec2(launchSize) - 1);

                uint nIdx = uint(neighbor.y) * uint(launchSize.x) + uint(neighbor.x);
                uint nBase = nIdx * 3u;
                if (!diReservoirIsFresh(giReservoirPrev.data[nBase + 2u], frameIndex)) continue;
                DIReservoir nReservoir = diUnpack(
                    giReservoirPrev.data[nBase + 0u],
                    giReservoirPrev.data[nBase + 1u]);

                if (nReservoir.M <= 0.0 || nReservoir.lightIndex >= cam.lightCount) continue;

                // Re-evaluate neighbor's light at THIS pixel's surface
                uint nLi = nReservoir.lightIndex;
                vec4 nPosRange = cam.lights[nLi * 4u];
                vec4 nColInt = cam.lights[nLi * 4u + 1u];
                vec4 nDirSizeX = cam.lights[nLi * 4u + 2u];
                vec4 nTanSizeY = cam.lights[nLi * 4u + 3u];
                vec3 nToLight = nPosRange.xyz - pbrHit.worldPos;
                float nDist = length(nToLight);
                vec3 nL = nToLight / max(nDist, 0.001);
                float nNdotL = dot(N, nL);
                float nFalloff = 1.0 / (nDist * nDist + 0.001);
                float nAtten = nFalloff;
                float nSpotAtten = 1.0;
                bool nIsSpecial = (nPosRange.w < 0.0);
                bool nIsSpot = nIsSpecial && nTanSizeY.w < 0.0;
                bool nIsArea = nIsSpecial && !nIsSpot;
                if (nIsSpot) {
                    float nCosHalf = nDirSizeX.w;
                    float nSm = abs(nTanSizeY.w);
                    float nCosA = dot(-nL, nDirSizeX.xyz);
                    float nSt = clamp((nCosA - nCosHalf) * nSm, 0.0, 1.0);
                    nSpotAtten = nSt * nSt * (3.0 - 2.0 * nSt);
                }
                if (nIsArea) {
                    float nFaceDot = max(dot(-nL, nDirSizeX.xyz), 0.0);
                    nAtten *= nFaceDot * nDirSizeX.w * nTanSizeY.w;
                }
                vec3 nRadiance = nColInt.rgb * nColInt.w * nAtten * nSpotAtten;
                float nTargetPDF = diTargetPDF(N, V, nL, max(nNdotL, 0.0),
                    pbrHit.baseColor, pbrHit.roughness, pbrHit.metallic, nRadiance);

                DIReservoir clampedN = nReservoir;
                float nMCap = min(clampedN.M, 10.0);
                if (nMCap < clampedN.M) {
                    clampedN.weightSum *= nMCap / clampedN.M;
                }
                clampedN.M = nMCap;
                diReservoirMerge(reservoir, clampedN, nTargetPDF, localRng);
            }

            // Final shading: trace ONE shadow ray to the selected light
            if (reservoir.lightIndex < cam.lightCount && reservoir.targetPDF > 0.0) {
                uint finalLi = reservoir.lightIndex;
                vec4 fPosRange = cam.lights[finalLi * 4u];
                vec4 fColInt   = cam.lights[finalLi * 4u + 1u];
                vec4 fDirSizeX = cam.lights[finalLi * 4u + 2u];
                vec4 fTanSizeY = cam.lights[finalLi * 4u + 3u];

                vec3 fToLight = fPosRange.xyz - pbrHit.worldPos;
                float fDist = length(fToLight);
                vec3 fL = fToLight / max(fDist, 0.001);

                // Shadow ray
                vec3 fShadowOrigin = pbrHit.worldPos + N * shadowBias;
                bool fInShadow = false;
                vec3 fShadowFilter = vec3(1.0);
                for (int fShadowSkip = 0; fShadowSkip < 4; fShadowSkip++) {
                    rayQueryEXT fShadowRQ;
                    rayQueryInitializeEXT(fShadowRQ, topLevelAS, gl_RayFlagsOpaqueEXT,
                        0xFF, fShadowOrigin, 0.0, fL, fDist - 0.004);
                    while (rayQueryProceedEXT(fShadowRQ)) {}
                    if (rayQueryGetIntersectionTypeEXT(fShadowRQ, true)
                        == gl_RayQueryCommittedIntersectionNoneEXT) {
                        break;
                    }
                    uint fCustIdx = rayQueryGetIntersectionInstanceCustomIndexEXT(fShadowRQ, true);
                    int fPrimId = rayQueryGetIntersectionPrimitiveIndexEXT(fShadowRQ, true);
                    float fHitT = rayQueryGetIntersectionTEXT(fShadowRQ, true);
                    GeometryMetadata fGeo = geometryMetadata.geometries[fCustIdx];
                    uint fStrandId = getHairStrandId(fGeo, uint(max(fPrimId, 0)));
                    bool skipSameStrandShadow = isHairSurface && fGeo.bitangentBufferAddress != 0u
                        && fCustIdx == customIndex
                        && hairStrandId != INVALID_HAIR_STRAND
                        && fStrandId == hairStrandId;
                    if (skipSameStrandShadow
                        || (isHairSurface && fGeo.bitangentBufferAddress != 0u
                            && fCustIdx == customIndex && fHitT < hairSelfShadowSkipDist)) {
                        fShadowOrigin += fL * (fHitT + 0.01);
                        continue;
                    }
                    uint fMatIdx = 0u;
                    if (fGeo.primMaterialBufferAddress != 0u) {
                        PrimMaterials fPM = PrimMaterials(fGeo.primMaterialBufferAddress);
                        fMatIdx = fPM.m[fPrimId];
                    }
                    Material fMat = materialBuffer.materials[fMatIdx];

                    if ((fMat.flags & 6u) != 0u) {
                        fShadowOrigin += fL * (fHitT + 0.004);
                        continue;
                    }

                    bool fNeedsShadowTransparency =
                        (fMat.flags & (1u | MAT_FLAG_LIGHTPATH_TRANSPARENT)) != 0u || fMat.multB > 0.0;
                    if (!fNeedsShadowTransparency) {
                        fInShadow = true;
                        break;
                    }

                    vec2 fBary2 = rayQueryGetIntersectionBarycentricsEXT(fShadowRQ, true);
                    vec3 fBary = vec3(1.0 - fBary2.x - fBary2.y, fBary2.x, fBary2.y);
                    mat4x3 fOTW = rayQueryGetIntersectionObjectToWorldEXT(fShadowRQ, true);
                    uint fInstanceId = uint(rayQueryGetIntersectionInstanceIdEXT(fShadowRQ, true));
                    vec3 fTrans = evaluateShadowMaterialTransmittance(
                        fMat, fMatIdx, fGeo, fPrimId, fBary, fOTW, fL, fInstanceId
                    );
                    if (max(max(fTrans.r, fTrans.g), fTrans.b) <= 0.001) {
                        fInShadow = true;
                        break;
                    }
                    fShadowFilter *= fTrans;
                    if (max(max(fShadowFilter.r, fShadowFilter.g), fShadowFilter.b) <= 0.001) {
                        fInShadow = true;
                        break;
                    }
                    fShadowOrigin += fL * (fHitT + 0.002);
                }

                if (!fInShadow) {
                    float W = diReservoirWeight(reservoir);
                    float fNdotL = max(dot(N, fL), 0.0);
                    float fFalloff = 1.0 / (fDist * fDist + 0.001);

                    // Recompute attenuation for the final light
                    float fAtten = fFalloff;
                    bool fIsSpecial = (fPosRange.w < 0.0);
                    bool fIsSpot = fIsSpecial && fTanSizeY.w < 0.0;
                    bool fIsArea = fIsSpecial && !fIsSpot;
                    float fSpotAtten = 1.0;

                    if (fIsSpot) {
                        float cosHalf = fDirSizeX.w;
                        float sSm = abs(fTanSizeY.w);
                        float cosA = dot(-fL, fDirSizeX.xyz);
                        float st = clamp((cosA - cosHalf) * sSm, 0.0, 1.0);
                        fSpotAtten = st * st * (3.0 - 2.0 * st);
                    }
                    if (fIsArea) {
                        float faceDot = max(dot(-fL, fDirSizeX.xyz), 0.0);
                        fAtten *= faceDot * fDirSizeX.w * fTanSizeY.w;
                    }

                    vec3 fRadiance = fColInt.rgb * fColInt.w * fAtten * fSpotAtten;
                    vec3 fDiffC, fSpecC;
                    if (isHairSurface) {
                        if (isHairHit) {
                            evaluateHairCylinderBSDF(
                                N, -rayDir, fL, hairSmoothT,
                                pbrHit.baseColor, pbrHit.roughness, pbrHit.hairRadialRoughness,
                                pbrHit.specularLevel, pbrHit.ior, pbrHit.hairShift, hairV,
                                fDiffC, fSpecC);
                        } else {
                            fDiffC = hair_eval(V, fL, hairSmoothT, pbrHit.baseColor,
                                              max(pbrHit.roughness, 0.05),
                                              max(pbrHit.hairRadialRoughness, 0.05),
                                              pbrHit.hairShift, max(pbrHit.ior, 1.01), hairV);
                            fSpecC = vec3(0.0);
                        }
                    } else {
                            evaluateCookTorrance(N, V, fL, pbrHit.baseColor, pbrHit.roughness,
                            pbrHit.metallic, pbrHit.specularLevel, pbrHit.ior, pbrHit.transmission, fDiffC, fSpecC);
                    }

                    diffuseRadiance += clampRadiance(fDiffC * fRadiance * W * throughput * fShadowFilter);
                    specularRadiance += clampRadiance(fSpecC * fRadiance * W * throughput * fShadowFilter);
                }
            }

            // Write reservoir for next frame
            reservoir.age += 1.0;
            uint currBase = pixelLinearIdx * 3u;
            giReservoirCurr.data[currBase + 0u] = diPackV0(reservoir);
            giReservoirCurr.data[currBase + 1u] = diPackV1(reservoir);
            giReservoirCurr.data[currBase + 2u] = vec4(uintBitsToFloat(frameIndex), 0, 0, 0);
            rngState = localRng;
            restirDone = true;
        }

        // ---- NEE: Point/spot/area lights (fallback for bounce 1+ or when ReSTIR skipped) ----
        if (!skipLocalNEE && !restirDone)
        for (uint li = neeStart; li < neeEnd; li++) {
            vec4 lightPosRange = cam.lights[li * 4u];
            vec4 lightColInt   = cam.lights[li * 4u + 1u];
            vec4 lightDirSizeX = cam.lights[li * 4u + 2u];
            vec4 lightTanSizeY = cam.lights[li * 4u + 3u];

            vec3 lightPos   = lightPosRange.xyz;
            float rawRange  = lightPosRange.w;
            vec3 lightColor = lightColInt.rgb;
            float lightInt  = lightColInt.w;

            // Negative range = area or spot light
            bool isSpecialLight = (rawRange < 0.0);
            float sizeY = lightTanSizeY.w;
            // Distinguish: spot light has negative sizeY (negated spot_smooth),
            // area light has positive sizeY (physical dimension in meters)
            bool isSpotLight = isSpecialLight && sizeY < 0.0;
            bool isAreaLight = isSpecialLight && !isSpotLight;
            float lightRange;
            if (isAreaLight) {
                // Range must cover the light's own diagonal plus falloff distance
                float sizeX = lightDirSizeX.w;
                float sizeY = lightTanSizeY.w;
                float diagonal = sqrt(sizeX * sizeX + sizeY * sizeY) * 0.5;
                float falloffRange = max(sqrt(lightInt * sizeX * sizeY / 0.01), 1.0);
                lightRange = diagonal + falloffRange;
            } else if (isSpotLight) {
                lightRange = -rawRange;
            } else {
                lightRange = rawRange;
            }
            lightRange = min(lightRange, 100.0);

            vec3 toLight = lightPos - pbrHit.worldPos;
            float dist = length(toLight);
            if (dist > lightRange || dist < 0.001) continue;
            vec3 L = toLight / dist;
            float NdotL_pt = dot(N, L);
            // For area lights: don't cull by center NdotL — parts of the light
            // can illuminate the surface even when the center is near/below horizon.
            // The per-sample NdotL is checked later in the BRDF evaluation.
            if (!isAreaLight && NdotL_pt <= 0.0) continue;

            // Spot light: cone attenuation (Cycles formula)
            if (isSpotLight) {
                vec3 spotDir = lightDirSizeX.xyz;
                float cosHalfAngle = lightDirSizeX.w;
                float spotSmooth = abs(lightTanSizeY.w);  // negated in export as spot flag
                float cosAngle = dot(-L, spotDir);
                // smoothstep((cosAngle - cosHalfAngle) * spotSmooth)
                float t = clamp((cosAngle - cosHalfAngle) * spotSmooth, 0.0, 1.0);
                float spotAtten = t * t * (3.0 - 2.0 * t);  // Hermite smoothstep
                if (spotAtten <= 0.0) continue;
                lightInt *= spotAtten;
            }

            // Area light: uniform area sampling with correct geometric term.
            // Each sample tests one random point on the rectangle.
            // The rectangular illumination pattern converges with temporal accumulation.
            vec3 jitteredTarget;
            if (isAreaLight) {
                vec3 lightNormal = lightDirSizeX.xyz;
                vec3 lightTangent = lightTanSizeY.xyz;
                float sizeX = lightDirSizeX.w;
                float sizeY = lightTanSizeY.w;

                // Don't hard-cull by center facing — check individual sample instead
                vec3 lightBitangent = cross(lightNormal, lightTangent);
                vec2 areaRnd = rand2() * 2.0 - 1.0;
                jitteredTarget = lightPos
                    + lightTangent * (areaRnd.x * sizeX * 0.5)
                    + lightBitangent * (areaRnd.y * sizeY * 0.5);
            } else {
                // Point/spot light: small jitter for soft shadows
                float softRadius = clamp(dist * 0.015, 0.01, 0.3);
                vec2 diskSample = rand2();
                float diskR = sqrt(diskSample.x) * softRadius;
                float diskAngle = diskSample.y * 2.0 * PI;
                vec3 lTangent = abs(L.y) < 0.999 ? normalize(cross(L, vec3(0,1,0))) : normalize(cross(L, vec3(1,0,0)));
                vec3 lBitangent = cross(L, lTangent);
                jitteredTarget = lightPos + lTangent * (cos(diskAngle) * diskR) + lBitangent * (sin(diskAngle) * diskR);
            }

            vec3 toSample = jitteredTarget - pbrHit.worldPos;
            float sampleDist = length(toSample);
            vec3 shadowDir = toSample / sampleDist;
            float shadowDist = sampleDist;

            // Attenuation
            float effectiveDist = isAreaLight ? sampleDist : dist;
            float falloff = 1.0 / (effectiveDist * effectiveDist + 0.001);
            float attenuation = falloff;

            if (isAreaLight) {
                vec3 lightNormal = lightDirSizeX.xyz;
                // Cosine at light surface — per sampled point, not center
                float cosAtLight = max(dot(-shadowDir, lightNormal), 0.0);
                if (cosAtLight <= 0.0) continue;  // sample is behind light
                float areaSize = lightDirSizeX.w * lightTanSizeY.w;
                attenuation *= cosAtLight * areaSize;
            }

            // Shadow ray to jittered target (skip glass surfaces)
            vec3 ptShadowOrigin = pbrHit.worldPos + N * shadowBias;
            bool inShadow = false;
            vec3 shadowFilter = vec3(1.0);
            for (int ptShadowSkip = 0; ptShadowSkip < 4; ptShadowSkip++) {
                rayQueryEXT shadowRQ;
                rayQueryInitializeEXT(shadowRQ, topLevelAS,
                    gl_RayFlagsOpaqueEXT,
                    0xFF, ptShadowOrigin, 0.0, shadowDir, shadowDist - 0.004);
                while (rayQueryProceedEXT(shadowRQ)) {}
                if (rayQueryGetIntersectionTypeEXT(shadowRQ, true)
                    == gl_RayQueryCommittedIntersectionNoneEXT) {
                    break; // No hit — not in shadow
                }
                // Check if hit is glass (transmission flag)
                uint ptsCustIdx = rayQueryGetIntersectionInstanceCustomIndexEXT(shadowRQ, true);
                int ptsPrimId = rayQueryGetIntersectionPrimitiveIndexEXT(shadowRQ, true);
                float ptsHitT = rayQueryGetIntersectionTEXT(shadowRQ, true);
                GeometryMetadata ptsGeo = geometryMetadata.geometries[ptsCustIdx];
                uint ptsStrandId = getHairStrandId(ptsGeo, uint(max(ptsPrimId, 0)));
                bool skipSameStrandShadow = isHairSurface && ptsGeo.bitangentBufferAddress != 0u
                    && ptsCustIdx == customIndex
                    && hairStrandId != INVALID_HAIR_STRAND
                    && ptsStrandId == hairStrandId;
                if (skipSameStrandShadow
                    || (isHairSurface && ptsGeo.bitangentBufferAddress != 0u
                        && ptsCustIdx == customIndex && ptsHitT < hairSelfShadowSkipDist)) {
                    ptShadowOrigin += shadowDir * (ptsHitT + 0.01);
                    continue;
                }
                uint ptsMatIdx = 0u;
                if (ptsGeo.primMaterialBufferAddress != 0u) {
                    PrimMaterials ptsPM = PrimMaterials(ptsGeo.primMaterialBufferAddress);
                    ptsMatIdx = ptsPM.m[ptsPrimId];
                }
                Material ptsMat = materialBuffer.materials[ptsMatIdx];

                if ((ptsMat.flags & 6u) != 0u) {
                    ptShadowOrigin = ptShadowOrigin + shadowDir * (ptsHitT + 0.004);
                    continue;
                }

                bool ptsNeedsShadowTransparency =
                    (ptsMat.flags & (1u | MAT_FLAG_LIGHTPATH_TRANSPARENT)) != 0u || ptsMat.multB > 0.0;
                if (!ptsNeedsShadowTransparency) {
                    inShadow = true;
                    break;
                }

                vec2 ptsBary2 = rayQueryGetIntersectionBarycentricsEXT(shadowRQ, true);
                vec3 ptsBary = vec3(1.0 - ptsBary2.x - ptsBary2.y, ptsBary2.x, ptsBary2.y);
                mat4x3 ptsOTW = rayQueryGetIntersectionObjectToWorldEXT(shadowRQ, true);
                uint ptsInstanceId = uint(rayQueryGetIntersectionInstanceIdEXT(shadowRQ, true));
                vec3 ptsTrans = evaluateShadowMaterialTransmittance(
                    ptsMat, ptsMatIdx, ptsGeo, ptsPrimId, ptsBary, ptsOTW, shadowDir, ptsInstanceId
                );
                if (max(max(ptsTrans.r, ptsTrans.g), ptsTrans.b) <= 0.001) {
                    inShadow = true;
                    break;
                }
                shadowFilter *= ptsTrans;
                if (max(max(shadowFilter.r, shadowFilter.g), shadowFilter.b) <= 0.001) {
                    inShadow = true;
                    break;
                }
                ptShadowOrigin = ptShadowOrigin + shadowDir * (ptsHitT + 0.004);
            }

            // BRDF evaluation: area lights use direction to sampled point,
            // point lights use direction to center (jitter is only for shadows)
            vec3 V = -rayDir;
            vec3 brdfL = isAreaLight ? shadowDir : L;
            vec3 diffC, specC;
            if (isHairSurface) {
                if (isHairHit) {
                    evaluateHairCylinderBSDF(
                        N, V, brdfL, hairSmoothT,
                        pbrHit.baseColor, pbrHit.roughness, pbrHit.hairRadialRoughness,
                        pbrHit.specularLevel, pbrHit.ior, pbrHit.hairShift, hairV,
                        diffC, specC);
                } else {
                    diffC = hair_eval(V, brdfL, hairSmoothT, pbrHit.baseColor,
                                      max(pbrHit.roughness, 0.05),
                                      max(pbrHit.hairRadialRoughness, 0.05),
                                      pbrHit.hairShift, max(pbrHit.ior, 1.01), hairV);
                    specC = vec3(0.0);
                }
            } else {
                evaluateCookTorrance(N, V, brdfL, pbrHit.baseColor, pbrHit.roughness,
                                     pbrHit.metallic, pbrHit.specularLevel, pbrHit.ior, pbrHit.transmission,
                                     diffC, specC);
            }

            vec3 lightRadiance = lightColor * lightInt * attenuation;
            vec3 shadow = inShadow ? vec3(0.0) : shadowFilter;

            if (bounce == 0) {
                // Point lights: apply shadow directly (SIGMA only handles sun)
                diffuseRadiance += clampRadiance(diffC * lightRadiance * shadow * throughput * neeScale);
                specularRadiance += clampRadiance(specC * lightRadiance * shadow * throughput * neeScale);
            } else {
                vec3 directLight = clampRadiance((diffC + specC) * lightRadiance * shadow * neeScale);
                if (isDiffusePath) {
                    diffuseRadiance += directLight * throughput * giIntensity;
                } else {
                    specularRadiance += directLight * throughput * giIntensity;
                }
            }
        }

        // ---- NEE: Emissive triangle lights (MIS, bounce 0-1 only) ----
        uint emissiveTriCount = cam.lightPad0;
        if (!skipLocalNEE && emissiveTriCount > 0u) {
            EmissiveSample eSample = sampleEmissiveTriangle(emissiveTriCount, rand01(), rand2());
            if (eSample.pdf > 0.0) {
                vec3 toEmissive = eSample.position - pbrHit.worldPos;
                float eDist = length(toEmissive);
                vec3 eDir = toEmissive / eDist;
                float eNdotL = dot(N, eDir);
                // Check emissive surface faces us
                float eCosTheta = dot(-eDir, eSample.normal);

                if (eNdotL > 0.0 && eCosTheta > 0.0 && eDist > 0.01) {
                    // Shadow ray to emissive surface (skip glass)
                    vec3 eShadowOrigin = pbrHit.worldPos + N * shadowBias;
                    bool eInShadow = false;
                    vec3 eShadowFilter = vec3(1.0);
                    for (int eShadowSkip = 0; eShadowSkip < 4; eShadowSkip++) {
                        rayQueryEXT eShadowRQ;
                        rayQueryInitializeEXT(eShadowRQ, topLevelAS,
                            gl_RayFlagsOpaqueEXT,
                            0xFF, eShadowOrigin, 0.0, eDir, eDist - 0.01);
                        while (rayQueryProceedEXT(eShadowRQ)) {}
                        if (rayQueryGetIntersectionTypeEXT(eShadowRQ, true)
                            == gl_RayQueryCommittedIntersectionNoneEXT) {
                            break;
                        }
                        uint eCustIdx = rayQueryGetIntersectionInstanceCustomIndexEXT(eShadowRQ, true);
                        int ePrimId = rayQueryGetIntersectionPrimitiveIndexEXT(eShadowRQ, true);
                        float eHitT = rayQueryGetIntersectionTEXT(eShadowRQ, true);
                        GeometryMetadata eGeo = geometryMetadata.geometries[eCustIdx];
                        uint eStrandId = getHairStrandId(eGeo, uint(max(ePrimId, 0)));
                        bool skipSameStrandShadow = isHairSurface && eGeo.bitangentBufferAddress != 0u
                            && eCustIdx == customIndex
                            && hairStrandId != INVALID_HAIR_STRAND
                            && eStrandId == hairStrandId;
                        if (skipSameStrandShadow
                            || (isHairSurface && eGeo.bitangentBufferAddress != 0u
                                && eCustIdx == customIndex && eHitT < hairSelfShadowSkipDist)) {
                            eShadowOrigin += eDir * (eHitT + 0.01);
                            continue;
                        }
                        uint eMatIdx = 0u;
                        if (eGeo.primMaterialBufferAddress != 0u) {
                            PrimMaterials ePM = PrimMaterials(eGeo.primMaterialBufferAddress);
                            eMatIdx = ePM.m[ePrimId];
                        }
                        Material eMat = materialBuffer.materials[eMatIdx];

                        if ((eMat.flags & 6u) != 0u) {
                            eShadowOrigin = eShadowOrigin + eDir * (eHitT + 0.004);
                            continue;
                        }

                        bool eNeedsShadowTransparency =
                            (eMat.flags & (1u | MAT_FLAG_LIGHTPATH_TRANSPARENT)) != 0u || eMat.multB > 0.0;
                        if (!eNeedsShadowTransparency) {
                            eInShadow = true;
                            break;
                        }
                        vec2 eBary2 = rayQueryGetIntersectionBarycentricsEXT(eShadowRQ, true);
                        vec3 eBary = vec3(1.0 - eBary2.x - eBary2.y, eBary2.x, eBary2.y);
                        mat4x3 eOTW = rayQueryGetIntersectionObjectToWorldEXT(eShadowRQ, true);
                        uint eInstanceId = uint(rayQueryGetIntersectionInstanceIdEXT(eShadowRQ, true));
                        vec3 eTrans = evaluateShadowMaterialTransmittance(
                            eMat, eMatIdx, eGeo, ePrimId, eBary, eOTW, eDir, eInstanceId
                        );
                        if (max(max(eTrans.r, eTrans.g), eTrans.b) <= 0.001) {
                            eInShadow = true;
                            break;
                        }
                        eShadowFilter *= eTrans;
                        if (max(max(eShadowFilter.r, eShadowFilter.g), eShadowFilter.b) <= 0.001) {
                            eInShadow = true;
                            break;
                        }
                        eShadowOrigin = eShadowOrigin + eDir * (eHitT + 0.004);
                    }

                    if (!eInShadow) {
                        // Evaluate BRDF
                        vec3 V = -rayDir;
                        vec3 eDiffC, eSpecC;
                        if (isHairSurface) {
                            if (isHairHit) {
                                evaluateHairCylinderBSDF(
                                    N, V, eDir, hairSmoothT,
                                    pbrHit.baseColor, pbrHit.roughness, pbrHit.hairRadialRoughness,
                                    pbrHit.specularLevel, pbrHit.ior, pbrHit.hairShift, hairV,
                                    eDiffC, eSpecC);
                            } else {
                                eDiffC = hair_eval(V, eDir, hairSmoothT, pbrHit.baseColor,
                                                  max(pbrHit.roughness, 0.05),
                                                  max(pbrHit.hairRadialRoughness, 0.05),
                                                  pbrHit.hairShift, max(pbrHit.ior, 1.01), hairV);
                                eSpecC = vec3(0.0);
                            }
                        } else {
                            evaluateCookTorrance(N, V, eDir, pbrHit.baseColor, pbrHit.roughness,
                                                 pbrHit.metallic, pbrHit.specularLevel, pbrHit.ior, pbrHit.transmission,
                                                 eDiffC, eSpecC);
                        }

                        // Geometric term: emission / (dist^2) * cosTheta_emitter
                        vec3 eRadiance = eSample.emission * eCosTheta / (eDist * eDist);

                        // MIS weight: power heuristic (light_pdf^2 / (light_pdf^2 + bsdf_pdf^2))
                        // BSDF pdf for diffuse: cosTheta / PI
                        float bsdfPdf = eNdotL / PI;
                        float lightPdf = eSample.pdf * eDist * eDist / eCosTheta;
                        float misWeight = (lightPdf * lightPdf) / (lightPdf * lightPdf + bsdfPdf * bsdfPdf + 1e-8);

                        vec3 eDiffContrib = clampRadiance(eDiffC * eRadiance * misWeight / max(eSample.pdf, 1e-6) * eShadowFilter);
                        vec3 eSpecContrib = clampRadiance(eSpecC * eRadiance * misWeight / max(eSample.pdf, 1e-6) * eShadowFilter);

                        if (bounce == 0) {
                            diffuseRadiance += clampRadiance(eDiffContrib * throughput);
                            specularRadiance += clampRadiance(eSpecContrib * throughput);
                        } else {
                            vec3 directLight = clampRadiance(eDiffContrib + eSpecContrib);
                            if (isDiffusePath) {
                                diffuseRadiance += directLight * throughput * giIntensity;
                            } else {
                                specularRadiance += directLight * throughput * giIntensity;
                            }
                        }
                    }
                }
            }
        }

        // Ambient fill removed — sky GI from bounced rays provides natural
        // environment lighting. evaluateSky() acts as the environment map.

        // ---- ReSTIR GI: capture indirect hit as reservoir sample ----
        if (giReservoirEnabled && bounce == 1 && primaryHit) {
            GIReservoir newSample;
            newSample.position = pbrHit.worldPos;
            newSample.normal = N;
            newSample.radiance = (diffuseRadiance + specularRadiance) * giIntensity;
            newSample.hitDist = hitT;
            newSample.age = 0.0;
            newSample.weightSum = 0.0;
            newSample.M = 0.0;
            float pHat = giTargetPDF(primaryNormal, primaryWorldPos, newSample);
            if (pHat > 0.0) {
                reservoirUpdate(reservoir, newSample, pHat, reservoirRng);
            }
        }

        // ── SHARC update + Path Guiding recording ──
        if (sharcEnabled && sharcUpdatePixel && !primaryThroughSpecularFast) {
            vec3 directLighting = (diffuseRadiance + specularRadiance) - preBounceRadiance;
            if (any(isnan(directLighting)) || any(isinf(directLighting)))
                directLighting = vec3(0.0);
            directLighting = max(directLighting, vec3(0.0));

            // Record radiance direction into guide bins
            float lum = dot(directLighting, vec3(0.2126, 0.7152, 0.0722));
            if (lum > 0.001) {
                uint64_t guideKey = sharcHashKey(pbrHit.worldPos, N, sharcGrid);
                uint guideSlot = sharcInsert(guideKey, sharcCapacity);
                if (guideSlot != 0xFFFFFFFFu) {
                    // Record which direction the light came FROM (negative ray dir)
                    guideAccumulate(guideSlot, -rayDir, lum, sharcCapacity);
                }
            }

            bool continueTracing = SharcUpdateHit(sharcGrid, sharcState,
                pbrHit.worldPos, N, directLighting, rand01(), sharcCapacity);
            if (!continueTracing) break;

            SharcSetThroughput(sharcState, throughput);
        }

        // ---- Surfel update: trace 4 hemisphere rays for indirect irradiance ----
        if (surfelEnabled && bounce == 0 && !primaryThroughSpecularFast && surfelIsUpdatePixel(pixel, frameIndex)) {
            uint64_t sKey = surfelHashKey(pbrHit.worldPos, N, surfelGrid);
            uint sSlot = surfelFind(sKey, surfelCapacity);
            if (sSlot != 0xFFFFFFFFu) {
                vec3 surfelRadiance = vec3(0.0);
                vec3 surfelOrigin = pbrHit.worldPos + N * 0.002;

                for (int sr = 0; sr < 4; sr++) {
                    vec3 sDir = sampleCosineHemisphere(rand2(), N);

                    rayQueryEXT srq;
                    rayQueryInitializeEXT(srq, topLevelAS, gl_RayFlagsOpaqueEXT,
                                          0xFF, surfelOrigin, MIN_HIT_DIST, sDir, 10000.0);
                    while (rayQueryProceedEXT(srq)) {}

                    if (rayQueryGetIntersectionTypeEXT(srq, true) == gl_RayQueryCommittedIntersectionNoneEXT) {
                        // Sky contribution
                        surfelRadiance += evaluateSky(sDir);
                    } else {
                        // Hit surface — compute direct lighting at hit point
                        uint sCI = rayQueryGetIntersectionInstanceCustomIndexEXT(srq, true);
                        int sPrimId = rayQueryGetIntersectionPrimitiveIndexEXT(srq, true);
                        GeometryMetadata sGeo = geometryMetadata.geometries[sCI];

                        // Material albedo (from legacy struct, no VM)
                        uint sMatIdx = 0u;
                        if (sGeo.primMaterialBufferAddress != 0u) {
                            PrimMaterials sPM = PrimMaterials(sGeo.primMaterialBufferAddress);
                            sMatIdx = sPM.m[sPrimId];
                        }
                        Material sMat = materialBuffer.materials[sMatIdx];
                        vec3 albedo = vec3(sMat.ksAmbient, sMat.ksDiffuse, sMat.ksSpecular);

                        // Geometric normal at hit
                        Indices sIdx = Indices(sGeo.indexBufferAddress);
                        Vertices sVerts = Vertices(sGeo.vertexBufferAddress);
                        uint si0 = sIdx.i[sPrimId * 3 + 0];
                        uint si1 = sIdx.i[sPrimId * 3 + 1];
                        uint si2 = sIdx.i[sPrimId * 3 + 2];
                        vec3 sv0 = vec3(sVerts.v[si0*3], sVerts.v[si0*3+1], sVerts.v[si0*3+2]);
                        vec3 sv1 = vec3(sVerts.v[si1*3], sVerts.v[si1*3+1], sVerts.v[si1*3+2]);
                        vec3 sv2 = vec3(sVerts.v[si2*3], sVerts.v[si2*3+1], sVerts.v[si2*3+2]);
                        mat4x3 sOTW = rayQueryGetIntersectionObjectToWorldEXT(srq, true);
                        vec3 sN = normalize(cross(
                            (sOTW * vec4(sv1, 1.0)) - (sOTW * vec4(sv0, 1.0)),
                            (sOTW * vec4(sv2, 1.0)) - (sOTW * vec4(sv0, 1.0))));

                        // Sun direct (unshadowed for speed)
                        vec3 sunDir = normalize(cam.sunLight.xyz);
                        float sNdotL = max(dot(sN, sunDir), 0.0);
                        surfelRadiance += albedo * sNdotL * cam.sunLight.w * cam.skyLight.rgb * INV_PI;

                        // Ambient hemisphere: use sky environment (includes HDRI when active)
                        surfelRadiance += albedo * evaluateSky(sN) * 0.25 * INV_PI;

                        // Emission
                        surfelRadiance += vec3(sMat.emissiveR, sMat.emissiveG, sMat.emissiveB) * sMat.fresnelMaxLevel;
                    }
                }
                surfelAccumulate(sSlot, surfelRadiance * 0.25, surfelCapacity);
            }
        }

        // ---- NRC: terminate after direct lighting if requested ----
        if (nrcTerminated) break;

        // ---- Early termination: throughput too low to contribute visibly ----
        float tpMax = max(throughput.r, max(throughput.g, throughput.b));
        if (tpMax < 0.01) break;

        // ---- Russian roulette (NRD guidance: min survival prob 0.05 → max 20x boost) ----
        if (!NrcCanUseRussianRoulette(nrcPath) && NrcIsEnabled()) {
            // NRC unbiased training path — skip RR
        } else
        if (bounce >= 1) {
            float p = clamp(sqrt(tpMax), 0.05, 1.0);
            if (rand01() > p) break;
            throughput /= p;
            throughput = min(throughput, vec3(MAX_RADIANCE));
        }

        // ---- Transmission / Glass (GGX Microfacet, like Cycles) ----
        // Cycles: metallic controls conductor vs dielectric split.
        // Transmission only affects the dielectric portion:
        //   P(metallic reflection) = metallic
        //   P(glass refraction)    = (1 - metallic) * transmission
        //   P(diffuse)             = (1 - metallic) * (1 - transmission)
        // Stochastic lobe selection: if rand < metallic → skip glass, do metallic BRDF.
        vec3 V = -rayDir;
        if (glassProb > 0.01 && !useThinTransmissionPath && rand01() < glassProb) {
            glassBounces++;
            if (glassBounces >= MAX_GLASS_BOUNCES) break;

            bool enteringGlass = dot(smoothN, -rayDir) >= 0.0;
            bool hasBumpMapG = (mat.normalTexIndex != 0xFFFFFFFFu);
            bool isBumpNotNormalMapG = hasBumpMapG && (mat.detailNormalBlend < 0.0);
            vec3 refractN = enteringGlass
                ? (isBumpNotNormalMapG ? N : smoothN)
                : (isBumpNotNormalMapG ? -N : -smoothN);
            float eta = enteringGlass ? (1.0 / pbrHit.ior) : pbrHit.ior;
            float alpha = pbrHit.roughness * pbrHit.roughness;

            // Bump-to-roughness for low-SPP convergence — only for smooth glass with bump
            if (hasBumpMapG && alpha < 0.001) {
                float bumpCosG = dot(N, smoothN);
                if (bumpCosG < 0.9999) {
                    alpha = max(alpha, max(1.0 - bumpCosG * bumpCosG, 0.0));
                }
            }

            // Sample microfacet normal (GGX) for rough glass
            vec3 H;
            bool singularGlass = (alpha < 0.0005);
            if (!singularGlass && alpha > 0.0) {
                alpha = max(alpha, 0.001);
                vec2 xi = rand2();
                float phi = 2.0 * PI * xi.x;
                float cosTheta = sqrt((1.0 - xi.y) / (1.0 + (alpha * alpha - 1.0) * xi.y));
                float sinTheta = sqrt(1.0 - cosTheta * cosTheta);
                vec3 up = abs(refractN.y) < 0.999 ? vec3(0,1,0) : vec3(1,0,0);
                vec3 tanX = normalize(cross(up, refractN));
                vec3 tanY = cross(refractN, tanX);
                H = normalize(sinTheta * cos(phi) * tanX + sinTheta * sin(phi) * tanY + cosTheta * refractN);
            } else {
                H = refractN;
            }

            // Dielectric Fresnel (exact, not Schlick approximation — matches Cycles)
            float cosI = abs(dot(V, H));
            float fresnel = fresnelDielectric(cosI, eta);

            // Decide reflect vs refract based on Fresnel
            vec3 refracted = refract(-V, H, eta);
            bool canRefract = dot(refracted, refracted) > 0.0001;

            if (!canRefract || rand01() < fresnel) {
                // Reflection: stay on incident side
                rayDir = reflect(rayDir, H);
                rayOrigin = pbrHit.worldPos + refractN * 0.001;
            } else {
                // Refraction: cross to other side of surface
                rayDir = refracted;
                rayOrigin = pbrHit.worldPos - refractN * 0.001;
            }
            throughput *= cyclesPrincipledTransmissionTint(pbrHit.baseColor) / max(glassProb, 0.01);  // Cycles Principled transmission tint
            if (bounce == 0) { isDiffusePath = false; captureSpecularMV = true; }
            bounce--;  // glass doesn't count against main bounce budget
            continue;
        }

        // ---- Sample BRDF lobe ----
        float NdotV = max(dot(N, V), 0.001);

        // F0 from IOR for lobe selection
        float f0_dielectric = (pbrHit.ior - 1.0) / (pbrHit.ior + 1.0);
        f0_dielectric = f0_dielectric * f0_dielectric;
        vec3 F0 = mix(vec3(f0_dielectric * pbrHit.specularLevel * 2.0), pbrHit.baseColor, pbrHit.metallic);
        vec3 F = fresnelSchlick(NdotV, F0);
        float specWeight = (F.r + F.g + F.b) / 3.0;
        // For metals, specWeight is high; for dielectrics at normal incidence, ~4%

        // ── Hair BSDF: Karis simplified Marschner (R + TT + TRT) ──
        if (isHairSurface) {
            if (bounce > 1) {
                // Allow 1 secondary hair bounce for inter-strand scattering (fills shadows).
                // Cycles traces multiple hair bounces; stopping at bounce 0 creates
                // harsh contrast between lit and shadowed areas.
                break;
            }

            vec3 hairT = hairSmoothT;
            vec3 hairColor = pbrHit.baseColor;
            vec3 bounceN = worldN;
            float hairRoughness = max(pbrHit.roughness, 0.05);
            float hairIor = max(pbrHit.ior, 1.01);
            float hairSpecularWeight = max(pbrHit.specularLevel * 2.0, 0.0);
            float hairF0 = (hairIor - 1.0) / (hairIor + 1.0);
            hairF0 *= hairF0;

            // Hair needs an explicit glossy branch for scene reflections.
            // Otherwise low roughness only sharpens a lobe that is still sampled diffusely.
            float specProb = clamp(hairSpecularWeight * (0.35 + 0.45 * (1.0 - hairRoughness)) + hairF0 * 2.0,
                                   0.12, 0.9);
            if (hairSpecularWeight <= 1e-5)
                specProb = 0.0;

            bool chooseHairSpec = specProb > 0.0 && rand01() < specProb;
            vec3 newDir;

            if (chooseHairSpec) {
                float alpha = max(hairRoughness * hairRoughness, 0.001);
                vec3 H = sampleGGX_VNDF(rand2(), V, bounceN, alpha);
                newDir = reflect(-V, H);

                float NdotL = max(dot(bounceN, newDir), 0.0);
                float NdotH = max(dot(bounceN, H), 0.0);
                float NdotVHair = max(dot(bounceN, V), 0.001);
                float VdotH = max(dot(V, H), 1e-6);
                if (NdotL <= 0.0 || VdotH <= 1e-6)
                    break;

                float specPdf = (GGX_D(NdotH, alpha) * SmithG1(NdotVHair, alpha) * VdotH)
                              / max(4.0 * NdotVHair * VdotH, 1e-6);
                vec3 hairSpec = hair_eval(V, newDir, hairT,
                                          hairColor, hairRoughness, max(pbrHit.hairRadialRoughness, 0.05),
                                          pbrHit.hairShift, hairIor, hairV);
                float branchPdf = specProb * max(specPdf, 1e-6);
                throughput *= hairSpec / branchPdf;
                if (bounce == 0) { isDiffusePath = false; captureSpecularMV = true; }
            } else {
                newDir = sampleCosineHemisphere(rand2(), bounceN);

                // Use hair_eval for diffuse bounce (Beer-Lambert absorption)
                vec3 hairDiffuse = hair_eval(V, newDir, hairT,
                                             hairColor, hairRoughness, max(pbrHit.hairRadialRoughness, 0.05),
                                             pbrHit.hairShift, hairIor, hairV);
                float cosPdf = max(dot(newDir, bounceN), 0.0) * INV_PI;
                float branchPdf = max((1.0 - specProb) * cosPdf, 1e-6);
                if (branchPdf <= 1e-6)
                    break;

                throughput *= hairDiffuse / branchPdf;
                if (bounce == 0) isDiffusePath = true;
            }

            throughput = min(throughput, vec3(MAX_RADIANCE));
            rayDir = newDir;

            rayOrigin = pbrHit.worldPos + bounceN * 0.02;
            prevBounceNormal = bounceN;
            continue;
        }

        float diffuseWeight = (1.0 - pbrHit.metallic) * (1.0 - pbrHit.transmission);
        float dielectricSpecWeight = (1.0 - pbrHit.metallic) * (1.0 - pbrHit.transmission);
        float metalSpecWeight = pbrHit.metallic;

        // Compensate for glass lobe selection probability.
        // Glass path divides by glassProb; non-glass path must divide by (1-glassProb)
        // so that E[throughput] = metallic*F*G2/G1 + diffuse*baseColor (correct weights).
        // Cap at 2x to avoid excessive throughput that kills FPS on high-transmission materials.
        float nonGlassCompensation = (glassProb > 0.01) ? 1.0 / max(1.0 - glassProb, 0.5) : 1.0;

        // When diffuse lobe has no energy (metallic or full transmission),
        // force specular to avoid wasting rays on zero-throughput paths.
        bool chooseDiffuse = (diffuseWeight > 0.001) ? (rand01() > specWeight) : false;

        if (chooseDiffuse && pbrHit.metallic < 1.0) {
            // Diffuse lobe — with path guiding when available
            vec3 newDir;

            // Try path guiding: sample toward where light was found in previous frames
            bool useGuide = false;
            if (sharcEnabled && bounce >= 1) {
                uint64_t guideKey = sharcHashKey(pbrHit.worldPos, N, sharcGrid);
                uint guideSlot = sharcFind(guideKey, sharcCapacity);
                if (guideSlot != 0xFFFFFFFFu) {
                    float guidePdf;
                    vec3 guideDir = guideSampleDirection(guideSlot, N, rand01(), rand01(),
                                                         sharcCapacity, guidePdf);
                    if (guidePdf > 0.0 && dot(guideDir, N) > 0.0) {
                        newDir = guideDir;
                        // MIS: weight the guided sample against cosine hemisphere
                        float cosinePdf = max(dot(newDir, N), 0.0) * INV_PI;
                        float misWeight = guideMISWeight(cosinePdf, guidePdf, 0.5);
                        throughput *= pbrHit.baseColor * diffuseWeight * misWeight * nonGlassCompensation;
                        useGuide = true;
                    }
                }
            }

            if (!useGuide) {
                // Standard cosine hemisphere sampling
                newDir = sampleCosineHemisphere(rand2(), N);
                throughput *= pbrHit.baseColor * diffuseWeight * nonGlassCompensation;
            }

            rayDir = newDir;
            if (bounce == 0) isDiffusePath = true;
        } else {
            // Specular lobe
            float alpha = pbrHit.roughness * pbrHit.roughness;
            vec3 H = sampleGGX_VNDF(rand2(), V, N, alpha);
            vec3 newDir = reflect(-V, H);

            if (dot(newDir, N) <= 0.0) break; // Below surface

            float NdotL = max(dot(N, newDir), 0.0);
            float NdotH = max(dot(N, H), 0.0);
            float VdotH = max(dot(V, H), 0.0);

            // VNDF sampling weight = F * lobeWeight * G2/G1
            // Divided by nonGlassCompensation to account for stochastic glass selection.
            vec3 dielectricF0 = vec3(f0_dielectric * pbrHit.specularLevel * 2.0);
            vec3 dielectricFw = fresnelSchlick(VdotH, dielectricF0) * dielectricSpecWeight;
            vec3 metalFw = fresnelSchlick(VdotH, pbrHit.baseColor) * metalSpecWeight;
            float G2 = SmithG2(NdotL, NdotV, alpha);
            float G1 = SmithG1(NdotV, alpha);
            throughput *= (dielectricFw + metalFw) * (G2 / max(G1, 0.001)) * nonGlassCompensation;

            rayDir = newDir;
            if (bounce == 0) { isDiffusePath = false; captureSpecularMV = true; }
        }

        // Clamp throughput every bounce to prevent fireflies from specular paths
        throughput = min(throughput, vec3(MAX_RADIANCE));

        // Update ray origin (offset along geometric normal to avoid self-intersection)
        // Hair DOTS: larger offset to skip past sibling ribbon of same strand
        float rayOffset = (geo.bitangentBufferAddress != 0u) ? 0.02 : 0.002;
        rayOrigin = pbrHit.worldPos + N * rayOffset;
        prevBounceNormal = N;  // store for SHARC query on next bounce

        // NRC: report BRDF PDF for termination heuristic
        float nrcBrdfPdf = max(dot(rayDir, N), 0.0) * INV_PI;  // cosine-weighted approximation
        NrcSetBrdfPdf(nrcPath, nrcBrdfPdf);
    }

    // ---- ReSTIR GI: temporal reuse from previous frame ----
    if (giReservoirEnabled && primaryHit && frameIndex > 0u) {
        // Read motion vector for temporal reprojection
        vec4 currClipR = cam.proj * cam.view * vec4(primaryWorldPos, 1.0);
        vec2 currNDCR = currClipR.xy / currClipR.w;
        vec2 currUVR = vec2(currNDCR.x * 0.5 + 0.5, 0.5 - currNDCR.y * 0.5);

        uint rBase = uint(primaryInstanceId) * 3u;
        vec4 rRow0 = prevTransforms.data[rBase + 0u];
        vec4 rRow1 = prevTransforms.data[rBase + 1u];
        vec4 rRow2 = prevTransforms.data[rBase + 2u];
        vec3 rPrevWorldPos = vec3(dot(rRow0, vec4(primaryLocalPos, 1.0)),
                                  dot(rRow1, vec4(primaryLocalPos, 1.0)),
                                  dot(rRow2, vec4(primaryLocalPos, 1.0)));
        vec4 prevClipR = cam.projPrev * cam.viewPrev * vec4(rPrevWorldPos, 1.0);
        vec2 prevNDCR = prevClipR.xy / prevClipR.w;
        vec2 prevUVR = vec2(prevNDCR.x * 0.5 + 0.5, 0.5 - prevNDCR.y * 0.5);
        vec2 mvR = prevUVR - currUVR;

        reservoirTemporalReuse(reservoir, primaryNormal, primaryWorldPos,
                               mvR, launchSize, pixel, reservoirRng);

        // Apply reused GI sample: add temporally-stable indirect contribution
        if (reservoir.weightSum > 0.0 && reservoir.M > 0.0) {
            float finalPHat = giTargetPDF(primaryNormal, primaryWorldPos, reservoir);
            if (finalPHat > 0.0) {
                // W = weightSum / (M * p_hat) — standard RIS weight
                float W = reservoir.weightSum / (reservoir.M * finalPHat);
                vec3 reusedGI = reservoir.radiance * finalPHat * W;
                // Blend: use reservoir GI to supplement path-traced indirect
                // Weight by temporal stability (higher M = more stable = more trust)
                float blendWeight = clamp(reservoir.M / 10.0, 0.0, 0.5);
                diffuseRadiance = mix(diffuseRadiance, diffuseRadiance + reusedGI * 0.3, blendWeight);
            }
        }
    }

    // Write current reservoir for next frame
    if (giReservoirEnabled) {
        writeReservoir(pixelLinearIdx, reservoir);
    }

    // ---- NRC: finalize path info ----
    NrcWriteFinalPathInfo(nrcCtx, nrcPath, throughput, totalRadiance);

    // NRC update pass: only writes training data, skip image output
    if (NrcIsUpdateMode()) {
        return;
    }

    // ---- NIRC Two-Level MC: blend neural prediction with path traced result ----
    bool nircActivePost = (nircReady);
    if (nircActivePost && primaryHit && sampleIdx == 0 && frameIndex > 5u) {
        uint nircPixelIdx = uint(pixel.y) * uint(launchSize.x) + uint(pixel.x);
        vec4 nircPred = nircQueryOutput[nircPixelIdx];
        // nircPred.rgb = predicted incident radiance, .a = confidence
        if (nircPred.a > 0.0) {
            // Two-Level MC: F_total = F_cache + F_residual
            // F_cache = neural prediction (cheap, potentially biased)
            // F_residual = (path_traced - prediction) → converges to 0
            // Weighted blend based on confidence (increases as network trains)
            float nircWeight = clamp(float(frameIndex) / 300.0, 0.0, 0.3);  // ramp up over ~10s
            vec3 nircRadiance = max(nircPred.rgb, vec3(0.0));
            // Blend: use prediction for indirect, keep path traced for direct
            diffuseRadiance = mix(diffuseRadiance, diffuseRadiance + nircRadiance * 0.2, nircWeight);
        }
    }

    // ---- Accumulate this sample ----
    totalRadiance += diffuseRadiance + specularRadiance;
    accumDiffuse += diffuseRadiance;
    accumSpecular += specularRadiance;
    accumTotalRadiance += totalRadiance;
    accumDirectSunDiffuse += directSunDiffuse;
    accumAmbientDiffuse += ambientDiffuse;
    if (sampleIdx == 0) {
        primaryPenumbra = primaryPenumbraSample;
        primaryNdotL = primaryNdotLSample;
    }

    } // end SPP loop

    // Average across samples
    float invSPP = 1.0 / float(spp);
    vec3 diffuseRadiance = accumDiffuse * invSPP;
    vec3 specularRadiance = accumSpecular * invSPP;
    vec3 directSunDiffuse = accumDirectSunDiffuse * invSPP;
    vec3 ambientDiffuse = accumAmbientDiffuse * invSPP;
    vec3 color = accumTotalRadiance * invSPP;

    // ---- Debug view override (after SPP averaging) ----
    uint debugView = cam.parameters.y;
    if (debugView >= 2u && debugView <= 7u) {
        if (debugView == 2u) {
            // Unlit: albedo only
            color = primaryHit ? primaryBaseColor : vec3(0.0);
        } else if (debugView == 3u) {
            // Normals: world-space N as RGB
            color = primaryHit ? primaryNormal * 0.5 + 0.5 : vec3(0.5);
        } else if (debugView == 4u) {
            // Depth: linear distance normalized over 100m
            color = primaryHit ? vec3(clamp(primaryHitDist / 100.0, 0.0, 1.0)) : vec3(1.0);
        } else if (debugView == 5u) {
            // UV coordinates as RG
            color = primaryHit ? vec3(fract(primaryUV), 0.0) : vec3(0.0);
        } else if (debugView == 6u) {
            // Shader complexity heatmap using real GPU clock ticks
            uint64_t shaderClockEnd = clockARB();
            uint64_t elapsed = shaderClockEnd - shaderClockStart;
            // Normalize: ~500K ticks = simple pixel, ~5M ticks = expensive pixel
            // (RTX 3080 core clock ~1.7GHz → 1M ticks ≈ 0.6ms)
            float complexity = clamp(float(elapsed) / 5000000.0, 0.0, 1.0);
            // Smooth green → yellow → red gradient
            float r = smoothstep(0.0, 0.5, complexity);
            float g = 1.0 - smoothstep(0.5, 1.0, complexity);
            float b = 0.0;
            color = vec3(r, g, b);
        } else if (debugView == 7u) {
            // UV Checkerboard: 8×8 tiles alternating dark/light
            if (primaryHit) {
                vec2 uv = fract(primaryUV * 8.0);
                bool check = (uv.x < 0.5) ^^ (uv.y < 0.5);
                color = check ? vec3(0.85) : vec3(0.25);
            } else {
                color = vec3(0.1);
            }
        }
    }

    // ---- Write outputs ----

    // NRD G-buffers
    if (primaryHit) {
        imageStore(normalRoughnessImg, pixel, NRD_PackNormalRoughness(primaryNormal, primaryRoughness));
        imageStore(viewDepthImg, pixel, vec4(primaryViewZ, 0, 0, 0));

        // Per-object motion vectors: use previous-frame instance transform
        // to compute where this surface point was last frame
        uint base = uint(primaryInstanceId) * 3u;
        vec4 prevRow0 = prevTransforms.data[base + 0u];
        vec4 prevRow1 = prevTransforms.data[base + 1u];
        vec4 prevRow2 = prevTransforms.data[base + 2u];
        vec4 lp = vec4(primaryLocalPos, 1.0);
        vec3 prevWorldPos = vec3(dot(prevRow0, lp), dot(prevRow1, lp), dot(prevRow2, lp));

        vec4 currClip = cam.proj * cam.view * vec4(primaryWorldPos, 1.0);
        vec2 currNDC = currClip.xy / currClip.w;
        vec2 currUV = vec2(currNDC.x * 0.5 + 0.5, 0.5 - currNDC.y * 0.5);
        vec4 prevClip = cam.projPrev * cam.viewPrev * vec4(prevWorldPos, 1.0);
        vec2 prevNDC = prevClip.xy / prevClip.w;
        vec2 prevUV = vec2(prevNDC.x * 0.5 + 0.5, 0.5 - prevNDC.y * 0.5);
        vec2 motionVector = prevUV - currUV;
        // 2.5D MV Z: view-space Z delta
        float currViewZ = (cam.view * vec4(primaryWorldPos, 1.0)).z;
        float prevViewZ = (cam.viewPrev * vec4(prevWorldPos, 1.0)).z;
        float mvZ = prevViewZ - currViewZ;
        imageStore(motionVectorsImg, pixel, vec4(motionVector, mvZ, 0));

        // Hit distances for denoiser (DLSS RR / NRD).
        // Diffuse: use secondary bounce distance (geometry-stable, not noise-dependent).
        // Specular: use primary hit distance (reflection at surface).
        // Both are stable across frames (depend on geometry, not stochastic sampling).
        float diffHitDist = secondaryHitDist > 0.0 ? secondaryHitDist : primaryHitDist;
        float specHitDist = primaryHitDist;

        // Demodulate diffuse for DLSS RR (separate albedo buffer is also passed).
        // Floor albedo at 0.1 to prevent noise amplification on very dark surfaces.
        vec3 albedo = max(primaryAlbedo, vec3(0.1));
        vec3 demodDiffuse = diffuseRadiance / albedo;

        imageStore(diffuseRadianceImg, pixel, NRD_PackRadiance(demodDiffuse, diffHitDist));
        imageStore(specularRadianceImg, pixel, NRD_PackRadiance(specularRadiance, specHitDist));
        // shadowableFraction: proportion of diffuse that should receive SIGMA shadow.
        // This includes direct sun + ambient (both are "sky-visible" light that gets
        // blocked by occluders). Only path-traced indirect GI is excluded since it
        // was already correctly shadowed during bounces.
        float shadowableFraction = 0.0;
        float totalDiffLum = dot(diffuseRadiance, vec3(0.2126, 0.7152, 0.0722));
        if (totalDiffLum > 1e-6) {
            float shadowableLum = dot(directSunDiffuse + ambientDiffuse, vec3(0.2126, 0.7152, 0.0722));
            shadowableFraction = clamp(shadowableLum / totalDiffLum, 0.0, 1.0);
        }
        imageStore(albedoBufferImg, pixel, vec4(primaryAlbedo, shadowableFraction));

        // Specular motion vectors (reflection MV from bounce 1 hit)
        imageStore(specularMVImg, pixel, vec4(specularMV, 0, 0));

        // Specular albedo (EnvBRDFApprox) for DLSS Ray Reconstruction
        {
            float NdotV = max(dot(primaryNormal, normalize((cam.viewInverse * vec4(0,0,0,1)).xyz - primaryWorldPos)), 0.001);
            float f0_d = (1.5 - 1.0) / (1.5 + 1.0); // default IOR 1.5
            f0_d = f0_d * f0_d;
            vec3 F0 = mix(vec3(f0_d * 0.5 * 2.0), primaryAlbedo, clamp(primaryRoughness, 0.0, 1.0) > 0.99 ? 0.0 : 0.0);
            // For metals, F0 = baseColor. For dielectrics, F0 = 0.04 (standard)
            float metallic = 0.0; // TODO: store metallic in G-buffer for accurate F0
            F0 = mix(vec3(0.04), primaryAlbedo, metallic);
            vec3 specAlbedo = EnvBRDFApprox(F0, primaryRoughness, NdotV);
            imageStore(specularAlbedoImg, pixel, vec4(specAlbedo, 0.0));
        }

        // DLSS depth: NDC depth [0,1] (Use_HW_Depth=1)
        vec4 clipPos = cam.proj * vec4(0.0, 0.0, primaryViewZ, 1.0);
        float ndcZ = clamp(clipPos.z / clipPos.w, 0.0, 1.0);
        imageStore(dlssDepthImg, pixel, vec4(ndcZ, 0, 0, 0));
        imageStore(hairVImg, pixel, vec4(primaryHairV, 0, 0, 0));
    } else {
        // Sky miss: write defaults for NRD
        imageStore(normalRoughnessImg, pixel, NRD_PackNormalRoughness(vec3(0, 0, 1), 1.0));
        imageStore(viewDepthImg, pixel, vec4(1e7, 0, 0, 0));

        // Sky motion vectors: use a virtual point far along the ray direction.
        // Without this, sky pixels get MV=0 and NRD ghosting occurs on camera rotation.
        vec3 skyFarPos = savedRayOrigin + savedRayDir * 50000.0;
        vec4 skyCurrClip = cam.proj * cam.view * vec4(skyFarPos, 1.0);
        vec2 skyCurrNDC = skyCurrClip.xy / skyCurrClip.w;
        vec2 skyCurrUV = vec2(skyCurrNDC.x * 0.5 + 0.5, 0.5 - skyCurrNDC.y * 0.5);
        vec4 skyPrevClip = cam.projPrev * cam.viewPrev * vec4(skyFarPos, 1.0);
        vec2 skyPrevNDC = skyPrevClip.xy / skyPrevClip.w;
        vec2 skyPrevUV = vec2(skyPrevNDC.x * 0.5 + 0.5, 0.5 - skyPrevNDC.y * 0.5);
        imageStore(motionVectorsImg, pixel, vec4(skyPrevUV - skyCurrUV, 0, 0));

        imageStore(diffuseRadianceImg, pixel, vec4(0, 0, 0, 0));
        imageStore(specularRadianceImg, pixel, vec4(0, 0, 0, 0));
        imageStore(albedoBufferImg, pixel, vec4(0, 0, 0, 0));
        imageStore(specularAlbedoImg, pixel, vec4(0, 0, 0, 0));
        imageStore(specularMVImg, pixel, vec4(0, 0, 0, 0));
        imageStore(dlssDepthImg, pixel, vec4(1.0, 0, 0, 0));
        imageStore(hairVImg, pixel, vec4(2.0, 0, 0, 0));  // sentinel: not hair
    }

    // Write penumbra for SIGMA shadow denoiser
    // NRD rule: NdotL <= 0 MUST write 0 (geometry facing away from sun)
    if (primaryHit && primaryNdotL > 0.0) {
        imageStore(penumbraImg, pixel, vec4(primaryPenumbra, 0, 0, 0));
    } else {
        imageStore(penumbraImg, pixel, vec4(0.0));
    }

    // Reactive + confidence masks: detect disocclusion and moving objects
    if (primaryHit) {
        uint rBase = uint(primaryInstanceId) * 3u;
        vec4 rRow0 = prevTransforms.data[rBase + 0u];
        vec4 rRow1 = prevTransforms.data[rBase + 1u];
        vec4 rRow2 = prevTransforms.data[rBase + 2u];
        vec4 rLp = vec4(primaryLocalPos, 1.0);
        vec3 rPrevWorldPos = vec3(dot(rRow0, rLp), dot(rRow1, rLp), dot(rRow2, rLp));
        float transformDelta = distance(primaryWorldPos, rPrevWorldPos);

        // Reactive mask: continuous value for DLSS (0=static, 1=fast moving)
        float reactivity = clamp(transformDelta * 50.0, 0.0, 1.0);
        imageStore(reactiveMaskImg, pixel, vec4(reactivity));

        // Confidence: detect disocclusion by checking if reprojected previous position
        // would have been visible (depth consistency check).
        // If the object moved, the pixel behind it has stale history → low confidence.
        vec4 prevClipCheck = cam.projPrev * cam.viewPrev * vec4(primaryWorldPos, 1.0);
        vec2 prevNDCCheck = prevClipCheck.xy / prevClipCheck.w;
        // Check if current surface was out of view last frame (disocclusion)
        bool wasOutOfView = abs(prevNDCCheck.x) > 1.05 || abs(prevNDCCheck.y) > 1.05;
        // Check if object moved enough to reveal what's behind
        bool objectMoved = transformDelta > 0.001;
        // Low confidence for potentially disoccluded pixels and moving objects
        float confidence = 1.0;
        if (wasOutOfView) confidence = 0.0;  // Definitely disoccluded
        if (objectMoved) confidence = min(confidence, 0.3);  // Moving object — don't trust history
        imageStore(diffConfidenceImg, pixel, vec4(confidence));
        imageStore(specConfidenceImg, pixel, vec4(confidence));
    } else {
        imageStore(reactiveMaskImg, pixel, vec4(0.0));
        imageStore(diffConfidenceImg, pixel, vec4(1.0));
        imageStore(specConfidenceImg, pixel, vec4(1.0));
    }

    // Debug views: all modes bypass DLSS/HDR pipeline (C++ routes output to interop).
    // Mode 1 (Lighting) keeps tonemap (HDR white-albedo shading).
    // Modes 2-5 skip tonemap (already LDR).
    bool isDebugView = (debugView >= 2u && debugView <= 7u);
    bool isDebugLDR = (debugView >= 2u && debugView <= 7u);

    // HDR output flag: when DLSS SR or RR is active, skip tonemap in raygen
    // (DLSS/RR processes HDR; a dedicated tonemap pass converts to LDR)
    // All debug views bypass HDR pipeline since DLSS is not running on debug output.
    bool hdrOutput = (cam.parameters.w != 0u) && !isDebugView;

    if (!hdrOutput && !isDebugLDR) {
        // Tonemap + gamma (composite overwrites geometry pixels; this survives for sky)
        float ptSaturation = cam.ptParams0.z;
        float ptContrast   = cam.ptParams0.w;
        uint  ptTonemapMode = uint(cam.jitterData.z);

        color *= exposure;
        color = applyTonemap(color, ptTonemapMode);
        float luma = dot(color, vec3(0.2126, 0.7152, 0.0722));
        color = mix(vec3(luma), color, ptSaturation);
        if (ptContrast > 0.01) {
            vec3 curved = color * color * (3.0 - 2.0 * color);
            color = mix(color, curved, ptContrast);
        }
        color = clamp(color, 0.0, 1.0);
        color = pow(color, vec3(1.0 / 2.2));
    } else if (isDebugLDR) {
        // LDR debug modes: clamp to [0,1] and apply gamma for display
        color = clamp(color, 0.0, 1.0);
        color = pow(color, vec3(1.0 / 2.2));
    }
    // else: write raw linear HDR (no exposure, no tonemap, no gamma)

    // Blue noise dithering (spatial-only — same pattern each frame so denoiser averages it out)
    if (!hdrOutput && !isDebugLDR) {
        ivec2 dnCoord = ivec2(pixel.x & 63, pixel.y & 63);
        float bn = texelFetch(blueNoiseTexture, dnCoord, 0).r;
        color += (bn - 0.5) * 0.8 / 255.0;
    }

    // Final output to display image
    imageStore(image, pixel, vec4(color, 1.0));
}
